---
// Farm Eolica Works — 共通レイアウト
// works配下ページの <html>/<head> ボイラープレートと共通CSS読み込みを一元化する。
// 導入: src/pages/works/faq.astro（パイロット）→ terms/privacy/tokushoho/contact/records
// （responsive_ux_proposal_20260718.md §7 タスク2-1 batch1）
//
// ogType / twitterCard / twitterSite は任意プロパティ化済み（既定値=旧固定値と等価）。
// 未展開ページ（index.astro / regional-sake-brewery.astro 等）を移行する際は、
// ogType="article" や twitterCard="summary_large_image" + twitterSite="@FarmEolica" を
// 明示的に渡すこと。
import { SITE_CONFIG } from '../config/site';
import '../styles/works-base.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
  twitterCard?: string;
  twitterSite?: string;
}

const {
  title,
  description,
  ogImage = 'https://farmeolica.com/images/about/hero.webp',
  canonical,
  ogType = 'website',
  twitterCard = 'summary',
  twitterSite,
} = Astro.props;

const ga4Id = SITE_CONFIG.seo.ga4Id;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content={ogType} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content={twitterCard} />
  {twitterSite && <meta name="twitter:site" content={twitterSite} />}
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>
<slot />
</body>
</html>
