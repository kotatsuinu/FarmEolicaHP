---
// Farm Eolica Works — 共通レイアウト
// works配下ページの <html>/<head> ボイラープレートと共通CSS読み込みを一元化する。
// 導入: src/pages/works/faq.astro（パイロット）→ terms/privacy/tokushoho/contact/records
// （responsive_ux_proposal_20260718.md §7 タスク2-1 batch1）
//
// ogType / twitterCard は任意プロパティ（既定値=旧固定値と等価）。ogType="article" 等が
// 必要なページ（case study等）は明示的に渡すこと。
// twitterSite は既定値 "@FarmEolica"（works配下の全ページで twitter:site を出す運用、
// SEO/AEO hygieneパス P0-B にて変更）。個別に上書きしたい場合のみ明示的に渡す。
// works配下の全ページ（本Layout経由）に <WorksStructuredData /> (Organization JSON-LD) を
// 描画する。works landing等で二重描画しないよう、個別ページ側で追加描画しないこと。
import { SITE_CONFIG } from '../config/site';
import '../styles/works-base.css';
import WorksStructuredData from '../components/seo/WorksStructuredData.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
  twitterCard?: string;
  twitterSite?: string;
}

const {
  title,
  description,
  ogImage = 'https://farmeolica.com/images/about/hero.webp',
  canonical,
  ogType = 'website',
  twitterCard = 'summary',
  twitterSite = '@FarmEolica',
} = Astro.props;

const ga4Id = SITE_CONFIG.seo.ga4Id;
const gscVerification = SITE_CONFIG.seo.gscVerification;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content={ogType} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content={twitterCard} />
  {twitterSite && <meta name="twitter:site" content={twitterSite} />}
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=Zen+Old+Mincho:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>
<slot />
<WorksStructuredData />
</body>
</html>
