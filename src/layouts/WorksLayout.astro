---
// Farm Eolica Works — 共通レイアウト
// works配下ページの <html>/<head> ボイラープレートと共通CSS読み込みを一元化する。
// パイロット導入: src/pages/works/faq.astro（responsive_ux_proposal_20260718.md §7 タスク2-1）
//
// 既知の制約（残14ページ展開時に要拡張）:
// - og:type は "website" 固定。regional-sake-brewery.astro 等の記事系ページは
//   "article" が必要なため、展開時に ogType?: string プロパティを追加すること。
// - twitter:card は "summary" 固定・twitter:site 無し。index.astro / regional-sake-brewery.astro
//   等は "summary_large_image" + twitter:site="@FarmEolica" を使っているため、展開時に
//   twitterCard?: string / twitterSite?: string 相当のプロパティ追加を検討すること。
import { SITE_CONFIG } from '../config/site';
import '../styles/works-base.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = 'https://farmeolica.com/images/about/hero.webp',
  canonical,
} = Astro.props;

const ga4Id = SITE_CONFIG.seo.ga4Id;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>
<slot />
</body>
</html>
