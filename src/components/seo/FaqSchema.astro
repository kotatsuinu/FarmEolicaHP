---
/**
 * FAQページ用構造化データ（FAQPage）
 * works/faq.astro等、Q&A形式のページに組み込んで使用
 */
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
