---
// Farm Eolica Works — Estimate Wizard（かんたん見積もり／C2+D統合）
// Self-contained Astro component: vanilla JS only, no client-side framework.
// Reuses /works/ navy tokens (--m/--a/--bg/--ink/--inks/--inkm/--hair + fonts).
// Used on src/pages/works/contact.astro, directly above .form-layout.
//
// MONEY-CRITICAL: all figures below are verbatim from
// farm-eolica-works/02_services/spec/pricing_and_contract.md v0.6
// (see scratchpad/c2d_estimate_design.md §4). Do not round or invent numbers.
---

<section class="estimate-section" id="estimate">
  <div class="wc">
    <details class="eq-card reveal" id="eq-card">
      <summary class="eq-summary">
        <span class="eq-summary-main">
          <span class="eq-summary-en">ESTIMATE</span>
          <span class="eq-summary-jp">かんたん見積もり（無料・目安）</span>
        </span>
        <span class="eq-summary-icon" aria-hidden="true"></span>
      </summary>

      <div class="eq-body">
        <div class="eq-group">
          <div class="eq-q">Q1. 何を作りたいですか？</div>
          <div class="eq-options">
            <label class="eq-radio">
              <input type="radio" name="eq1" value="single" checked />
              <span>1枚もの（1ページのHP・LP）</span>
            </label>
            <label class="eq-radio">
              <input type="radio" name="eq1" value="multi" />
              <span>複数ページのHP（会社紹介など5〜10ページ）</span>
            </label>
            <label class="eq-radio">
              <input type="radio" name="eq1" value="print" />
              <span>チラシ・名刺・ロゴなど印刷物・デザイン小物</span>
            </label>
            <label class="eq-radio">
              <input type="radio" name="eq1" value="partner" />
              <span>継続的にHP更新やAI活用を相談したい（月額）</span>
            </label>
          </div>
        </div>

        <div class="eq-group" id="eq-single-block">
          <div class="eq-q">Q2. 自分で内容を更新したいですか？</div>
          <p class="eq-hint">＝ホームページの文章や写真を、ご自分でスマホ・パソコンから書き換えられる仕組み（microCMS）のことです。</p>
          <div class="eq-options">
            <label class="eq-radio">
              <input type="radio" name="eq2" value="cms" checked />
              <span>はい、お知らせや文章を自分で更新したい → CMS付き（スタンダード）</span>
            </label>
            <label class="eq-radio">
              <input type="radio" name="eq2" value="nocms" />
              <span>いいえ、一度作って基本そのままでOK → CMSなし（シンプル）</span>
            </label>
          </div>

          <div class="eq-q eq-q-opt">Q3. オプション（任意）</div>
          <div class="eq-opts-row">
            <label class="eq-select-row">
              <span class="eq-select-label">ページ追加</span>
              <select id="eq-pages" class="eq-select">
                <option value="0">追加なし</option>
                <option value="1">+1ページ</option>
                <option value="2">+2ページ</option>
                <option value="3">+3ページ</option>
                <option value="4">+4ページ</option>
              </select>
              <span class="eq-select-note">+¥10,000／ページ</span>
            </label>
            <label class="eq-check">
              <input type="checkbox" id="eq-domain" />
              <span>独自ドメインの設定もお願いしたい（+¥5,000・ドメイン実費別）</span>
            </label>
            <label class="eq-check">
              <input type="checkbox" id="eq-pdf" />
              <span>印刷用PDF（チラシ等）も出したい（+¥15,000〜30,000）</span>
            </label>
          </div>
        </div>

        <div class="eq-result" id="eq-result" aria-live="polite"></div>

        <p class="eq-disclaimer">※あくまで目安です。正式なお見積もりは初回無料でお出しします。修正は通常2ターンまで無料・公開後30日以内の微修正は無料です。</p>

        <button type="button" class="eq-cta" id="eq-cta">この内容で相談する →</button>
      </div>
    </details>
  </div>
</section>

<script is:inline>
(function () {
  // ── Pricing table（v0.6 逐語・money-critical。丸めない・発明しない） ──
  var PRICING = {
    single: {
      cms:   { special: 50000, normal: 100000, label: 'スタンダード（microCMS付）' },
      nocms: { special: 40000, normal: 80000,  label: 'シンプル（CMSなし）' }
    },
    pagePrice: 10000,
    domainPrice: 5000,
    pdfMin: 15000,
    pdfMax: 30000,
    multi: { hint: 150000 },
    partner: {
      l15: { price: 20000, minMonths: 3, label: 'L1.5（お試し軽量）' },
      l2:  { price: 40000, firstMonth: 20000, minMonths: 3, label: 'L2（軽）' }
    },
    print: [
      { name: 'ロゴ＋ブランディング', min: 15000, max: 40000 },
      { name: '名刺', min: 4000, max: 7500 },
      { name: 'ショップカード', min: 5000, max: 9000 },
      { name: '店頭POP（5点）', min: 7500, max: 10000 },
      { name: 'チラシA4両面', min: 7500, max: 12500 },
      { name: '三つ折りリーフレット（簡易版）', min: 15000, max: 25000 }
    ]
  };

  function fmt(n) { return '¥' + n.toLocaleString('ja-JP'); }

  var els = {
    eq1: document.getElementsByName('eq1'),
    eq2: document.getElementsByName('eq2'),
    singleBlock: document.getElementById('eq-single-block'),
    pages: document.getElementById('eq-pages'),
    domain: document.getElementById('eq-domain'),
    pdf: document.getElementById('eq-pdf'),
    result: document.getElementById('eq-result'),
    cta: document.getElementById('eq-cta')
  };
  if (!els.result || !els.cta) return;

  function currentEq1() {
    for (var i = 0; i < els.eq1.length; i++) { if (els.eq1[i].checked) return els.eq1[i].value; }
    return 'single';
  }
  function currentEq2() {
    for (var i = 0; i < els.eq2.length; i++) { if (els.eq2[i].checked) return els.eq2[i].value; }
    return 'cms';
  }

  function computeSingle() {
    var plan = PRICING.single[currentEq2()];
    var pages = parseInt(els.pages.value, 10) || 0;
    var addOn = pages * PRICING.pagePrice + (els.domain.checked ? PRICING.domainPrice : 0);
    var pdfOn = els.pdf.checked;
    return {
      plan: plan,
      pages: pages,
      domain: els.domain.checked,
      pdf: pdfOn,
      specialMin: plan.special + addOn + (pdfOn ? PRICING.pdfMin : 0),
      specialMax: plan.special + addOn + (pdfOn ? PRICING.pdfMax : 0),
      normalMin: plan.normal + addOn + (pdfOn ? PRICING.pdfMin : 0),
      normalMax: plan.normal + addOn + (pdfOn ? PRICING.pdfMax : 0)
    };
  }

  function renderResult() {
    var branch = currentEq1();
    els.singleBlock.style.display = (branch === 'single') ? '' : 'none';
    var html = '';

    if (branch === 'single') {
      var c = computeSingle();
      var specialLabel = (c.specialMin === c.specialMax) ? fmt(c.specialMin) : fmt(c.specialMin) + '〜' + fmt(c.specialMax);
      var normalLabel = (c.normalMin === c.normalMax) ? fmt(c.normalMin) : fmt(c.normalMin) + '〜' + fmt(c.normalMax);
      var extra = [];
      if (c.pages > 0) extra.push('ページ追加 +' + c.pages + 'p（' + fmt(c.pages * PRICING.pagePrice) + '）');
      if (c.domain) extra.push('独自ドメイン設定（+' + fmt(PRICING.domainPrice) + '・ドメイン実費別）');
      if (c.pdf) extra.push('印刷用PDF出力（+' + fmt(PRICING.pdfMin) + '〜' + fmt(PRICING.pdfMax) + '）');
      html += '<div class="eq-result-plan">おすすめ：<b>' + c.plan.label + '</b></div>';
      html += '<div class="eq-result-price-row">'
        + '<div class="eq-result-price-block"><span class="eq-result-price-label">先着5名 特別価格</span><span class="eq-result-price">' + specialLabel + '〜</span></div>'
        + '<div class="eq-result-price-block eq-result-price-block-sub"><span class="eq-result-price-label">通常</span><span class="eq-result-price eq-result-price-sub">' + normalLabel + '〜</span></div>'
        + '</div>';
      if (extra.length) html += '<div class="eq-result-extra">' + extra.map(function (e) { return '・' + e; }).join('<br />') + '</div>';
    } else if (branch === 'multi') {
      html += '<div class="eq-result-plan">複数ページのHP（5〜10ページ）は内容により<b>応相談</b>です。</div>';
      html += '<div class="eq-result-price-row"><div class="eq-result-price-block"><span class="eq-result-price-label">目安</span><span class="eq-result-price">' + fmt(PRICING.multi.hint) + '〜</span></div></div>';
    } else if (branch === 'print') {
      html += '<div class="eq-result-plan">印刷物・デザイン小物は組み合わせ次第のため<b>応相談</b>です。参考価格：</div>';
      html += '<ul class="eq-result-list">' + PRICING.print.map(function (p) {
        return '<li>' + p.name + '　' + fmt(p.min) + '〜' + fmt(p.max) + '</li>';
      }).join('') + '</ul>';
    } else if (branch === 'partner') {
      html += '<div class="eq-result-plan">月額AIパートナー（継続的な更新・AI活用の伴走）</div>';
      html += '<ul class="eq-result-list">'
        + '<li>' + PRICING.partner.l15.label + '　' + fmt(PRICING.partner.l15.price) + '/月〜・最低' + PRICING.partner.l15.minMonths + 'ヶ月</li>'
        + '<li>' + PRICING.partner.l2.label + '　' + fmt(PRICING.partner.l2.price) + '/月（先着5名：初月' + fmt(PRICING.partner.l2.firstMonth) + '）・最低' + PRICING.partner.l2.minMonths + 'ヶ月</li>'
        + '</ul>';
      html += '<div class="eq-result-note">さらに踏み込んだ伴走（L3）は非公開・応相談です。</div>';
    }
    els.result.innerHTML = html;
  }

  [].slice.call(els.eq1).forEach(function (r) { r.addEventListener('change', renderResult); });
  [].slice.call(els.eq2).forEach(function (r) { r.addEventListener('change', renderResult); });
  els.pages.addEventListener('change', renderResult);
  els.domain.addEventListener('change', renderResult);
  els.pdf.addEventListener('change', renderResult);
  renderResult();

  // ── CTA: 同ページのフォームへ結線（URLクエリ跨ぎ不要） ──
  var MARK_START = '▼ かんたん見積もりからの内容 ▼';
  var MARK_END = '▲ ここまで ▲';

  function buildSummaryLines() {
    var branch = currentEq1();
    var lines = [];
    if (branch === 'single') {
      var c = computeSingle();
      var specialLabel = (c.specialMin === c.specialMax) ? fmt(c.specialMin) : fmt(c.specialMin) + '〜' + fmt(c.specialMax);
      var normalLabel = (c.normalMin === c.normalMax) ? fmt(c.normalMin) : fmt(c.normalMin) + '〜' + fmt(c.normalMax);
      lines.push('選択：1枚もの（1ページのHP・LP）／' + c.plan.label);
      if (c.pages > 0) lines.push('　・ページ追加 +' + c.pages + 'p');
      if (c.domain) lines.push('　・独自ドメイン設定あり');
      if (c.pdf) lines.push('　・印刷用PDF出力あり');
      lines.push('概算：' + specialLabel + '〜（先着5名特別価格） ／ 通常 ' + normalLabel + '〜');
    } else if (branch === 'multi') {
      lines.push('選択：複数ページのHP（5〜10ページ）');
      lines.push('概算：応相談（目安 ' + fmt(PRICING.multi.hint) + '〜）');
    } else if (branch === 'print') {
      lines.push('選択：印刷物・デザイン小物');
      lines.push('概算：応相談（参考価格は下記でご案内できます）');
    } else if (branch === 'partner') {
      lines.push('選択：月額AIパートナー（継続相談）');
      lines.push('概算：L1.5 ' + fmt(PRICING.partner.l15.price) + '/月〜 ／ L2 ' + fmt(PRICING.partner.l2.price) + '/月（先着5名初月' + fmt(PRICING.partner.l2.firstMonth) + '）');
    }
    lines.push('※あくまで目安です。正式なお見積もりはこの相談で無料でお出しします。');
    return lines;
  }

  function inquiryTypeFor(branch) {
    if (branch === 'single' || branch === 'multi') return 'hp';
    if (branch === 'print') return 'flyer';
    if (branch === 'partner') return 'ai-partner';
    return '';
  }

  els.cta.addEventListener('click', function () {
    var branch = currentEq1();
    var ta = document.getElementById('f-message');
    if (ta) {
      var block = MARK_START + '\n' + buildSummaryLines().join('\n') + '\n' + MARK_END;
      var current = ta.value || '';
      var s = current.indexOf(MARK_START);
      var e = current.indexOf(MARK_END);
      if (s !== -1 && e !== -1) {
        current = (current.slice(0, s) + current.slice(e + MARK_END.length)).trim();
      }
      ta.value = current ? (block + '\n\n' + current) : block;
    }
    var typeSel = document.getElementById('f-type');
    if (typeSel) {
      var t = inquiryTypeFor(branch);
      if (t) typeSel.value = t;
    }
    var formEl = document.getElementById('works-contact-form');
    if (formEl && formEl.scrollIntoView) {
      formEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if (ta) { setTimeout(function () { ta.focus(); }, 450); }
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'works_estimate_cta_click', { eq1: branch });
    }
  });
})();
</script>

<style>
.estimate-section{padding:56px 60px 0}

.eq-card{background:var(--bg);border:1px solid var(--hair)}
.eq-summary{
  cursor:pointer;list-style:none;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
  padding:26px 32px;
}
.eq-summary::-webkit-details-marker{display:none}
.eq-summary::marker{content:''}
.eq-summary-main{display:flex;flex-direction:column;gap:6px}
.eq-summary-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.eq-summary-jp{font-family:var(--sr);font-weight:500;font-size:22px;color:var(--m);letter-spacing:.03em}
.eq-summary-icon{flex-shrink:0;width:28px;height:28px;border:1px solid var(--m);border-radius:50%;position:relative}
.eq-summary-icon::before,.eq-summary-icon::after{content:'';position:absolute;background:var(--m);top:50%;left:50%;transform:translate(-50%,-50%)}
.eq-summary-icon::before{width:12px;height:1px}
.eq-summary-icon::after{width:1px;height:12px}
.eq-card[open] .eq-summary-icon::after{display:none}

.eq-body{padding:0 32px 36px;border-top:1px solid var(--hair)}
.eq-group{padding-top:28px}
.eq-q{font-family:var(--mn);font-size:11px;letter-spacing:.16em;color:var(--inkm);margin-bottom:14px}
.eq-q-opt{margin-top:28px;padding-top:24px;border-top:1px solid var(--hair)}
.eq-hint{font-size:13px;line-height:1.9;color:var(--inks);background:rgba(184,115,51,.06);padding:12px 16px;margin:0 0 18px}

.eq-options{display:flex;flex-direction:column;gap:12px}
.eq-radio{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.7;color:var(--ink);cursor:pointer}
.eq-radio input{margin-top:3px;flex-shrink:0;accent-color:var(--m);width:16px;height:16px}

.eq-opts-row{display:flex;flex-direction:column;gap:14px;margin-top:14px}
.eq-select-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;font-size:13.5px;color:var(--ink);cursor:default}
.eq-select-label{color:var(--inks)}
.eq-select{font-family:var(--sr);font-size:13.5px;color:var(--ink);border:1px solid var(--hair);background:white;padding:8px 12px;-webkit-appearance:none}
.eq-select-note{font-family:var(--mn);font-size:11px;color:var(--inkm);letter-spacing:.04em}
.eq-check{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;line-height:1.7;color:var(--ink);cursor:pointer}
.eq-check input{margin-top:3px;flex-shrink:0;accent-color:var(--m);width:16px;height:16px}

.eq-result{margin-top:32px;padding:26px 28px;background:var(--m);color:var(--bg)}
.eq-result-plan{font-family:var(--sr);font-size:16px;letter-spacing:.03em;margin-bottom:16px}
.eq-result-plan b{color:var(--a)}
.eq-result-price-row{display:flex;gap:28px;flex-wrap:wrap;padding-top:16px;border-top:1px solid rgba(242,242,240,.2)}
.eq-result-price-block{display:flex;flex-direction:column;gap:6px}
.eq-result-price-label{font-family:var(--mn);font-size:10px;letter-spacing:.16em;color:var(--a)}
.eq-result-price{font-family:var(--sr);font-size:24px;font-weight:600;letter-spacing:.02em}
.eq-result-price-block-sub .eq-result-price-label{color:rgba(242,242,240,.5)}
.eq-result-price-sub{font-size:17px;font-weight:500;color:rgba(242,242,240,.65)}
.eq-result-extra{margin-top:16px;padding-top:16px;border-top:1px solid rgba(242,242,240,.2);font-size:12.5px;line-height:1.9;color:rgba(242,242,240,.8)}
.eq-result-list{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:8px;font-size:13px;line-height:1.8;color:rgba(242,242,240,.85)}
.eq-result-note{margin-top:14px;font-size:12.5px;color:rgba(242,242,240,.65)}

.eq-disclaimer{margin-top:20px;font-size:12px;line-height:1.9;color:var(--inkm)}

.eq-cta{
  margin-top:22px;padding:14px 28px;background:var(--m);color:var(--bg);border:1px solid var(--m);
  font-family:var(--dp);font-size:12px;letter-spacing:.2em;cursor:pointer;transition:background .25s;
  -webkit-appearance:none;
}
.eq-cta:hover{background:#253a6b}
</style>
