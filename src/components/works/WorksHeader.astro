---
// Farm Eolica Works — Shared Header
// Used across all /works/ pages. Unifies nav markup + CSS that was
// previously duplicated per-page. Active state is self-detected from
// Astro.url.pathname (aria-current="page" + .is-active), so pages no
// longer need to pass `active` manually. The `active` prop is kept for
// backward compatibility (OR'd into the path-based detection) — passing
// it is harmless and never required.
interface Props {
  isHome?: boolean;
  active?: 'capabilities' | 'first-time' | 'contact';
}
const { active } = Astro.props;

// ── Current-path detection ──────────────────────────────────────────
// trailingSlash:'always' (astro.config.mjs) means built paths end in
// "/", but we normalize (strip trailing slash, keep root as-is) so this
// still works in dev/preview modes that may omit it.
const rawPath = Astro.url.pathname;
const norm = (p: string) => (p.length > 1 ? p.replace(/\/+$/, '') : p);
const cur = norm(rawPath);
const isPath = (p: string) => cur === norm(p);

const activeTop = isPath('/works/');
const activeHpLp = isPath('/works/hp-lp');
const activePartner = isPath('/works/partner');
const activeCapabilities = isPath('/works/capabilities') || active === 'capabilities';
const activeRecords = isPath('/works/records');
const activeFirstTime = isPath('/works/first-time') || active === 'first-time';
const activeFaq = isPath('/works/faq');
const activeContact = isPath('/works/contact') || active === 'contact';
const activePartnerGroup = activePartner || activeCapabilities || activeRecords;
---

<header class="wh">
  <a href="/works/" class="wh-logo">
    <span class="wh-logo-main">FARM&nbsp;EOLICA</span>
    <span class="wh-logo-sub">/ WORKS</span>
  </a>
  <nav class="wh-nav">
    <a href="/works/" aria-current={activeTop ? 'page' : undefined} class:list={{ 'is-active': activeTop }}>トップ</a>
    <a href="/works/hp-lp" aria-current={activeHpLp ? 'page' : undefined} class:list={{ 'is-active': activeHpLp }}>ホームページ制作</a>

    <div class="wh-drop">
      <button
        type="button"
        class="wh-drop-trigger"
        aria-haspopup="menu"
        aria-expanded="false"
        aria-current={activePartnerGroup ? 'page' : undefined}
        class:list={{ 'is-active': activePartnerGroup }}
      >
        業務代行<span class="wh-caret" aria-hidden="true">▾</span>
      </button>
      <ul class="wh-drop-menu" role="menu">
        <li role="none">
          <a role="menuitem" href="/works/partner" aria-current={activePartner ? 'page' : undefined} class:list={{ 'is-active': activePartner }}>業務代行とは</a>
        </li>
        <li role="none">
          <a role="menuitem" href="/works/capabilities" aria-current={activeCapabilities ? 'page' : undefined} class:list={{ 'is-active': activeCapabilities }}>できること</a>
        </li>
        <li role="none">
          <a role="menuitem" href="/works/records" aria-current={activeRecords ? 'page' : undefined} class:list={{ 'is-active': activeRecords }}>実績・システム例</a>
        </li>
      </ul>
    </div>

    <a href="/works/first-time" aria-current={activeFirstTime ? 'page' : undefined} class:list={{ 'is-active': activeFirstTime }}>初めての方へ</a>
    <a href="/works/faq" aria-current={activeFaq ? 'page' : undefined} class:list={{ 'is-active': activeFaq }}>FAQ</a>
    <a href="/works/contact" aria-current={activeContact ? 'page' : undefined} class:list={{ 'is-active': activeContact }}>コンタクト</a>
    <a href="/" class="wh-farm-link">農場HP ↗</a>
    <a href="/works/contact" class="wh-cta" aria-current={activeContact ? 'page' : undefined}>まずは話してみる →</a>
  </nav>

  <button
    type="button"
    id="wh-hamburger"
    class="wh-hamburger"
    aria-expanded="false"
    aria-controls="wh-overlay"
    aria-label="メニューを開く"
  >
    <span class="wh-hamburger-bar" aria-hidden="true"></span>
    <span class="wh-hamburger-bar" aria-hidden="true"></span>
    <span class="wh-hamburger-bar" aria-hidden="true"></span>
  </button>
</header>

<div class="wh-overlay" id="wh-overlay">
  <button type="button" id="wh-overlay-close" class="wh-overlay-close" aria-label="メニューを閉じる">
    <span class="wh-overlay-close-x" aria-hidden="true"></span>
    <span class="wh-overlay-close-x" aria-hidden="true"></span>
  </button>
  <nav class="wh-overlay-nav" id="wh-overlay-nav" aria-label="works モバイルメニュー">
    <a href="/works/" aria-current={activeTop ? 'page' : undefined} class:list={{ 'is-active': activeTop }}>トップ</a>
    <a href="/works/hp-lp" aria-current={activeHpLp ? 'page' : undefined} class:list={{ 'is-active': activeHpLp }}>ホームページ制作</a>

    <div class="wh-overlay-drop">
      <button
        type="button"
        id="wh-overlay-drop-trigger"
        class="wh-overlay-drop-trigger"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="wh-overlay-drop-menu"
        aria-current={activePartnerGroup ? 'page' : undefined}
        class:list={{ 'is-active': activePartnerGroup }}
      >
        業務代行<span class="wh-caret" aria-hidden="true">▾</span>
      </button>
      <div class="wh-overlay-drop-menu" id="wh-overlay-drop-menu">
        <a href="/works/partner" aria-current={activePartner ? 'page' : undefined} class:list={{ 'is-active': activePartner }}>業務代行とは</a>
        <a href="/works/capabilities" aria-current={activeCapabilities ? 'page' : undefined} class:list={{ 'is-active': activeCapabilities }}>できること</a>
        <a href="/works/records" aria-current={activeRecords ? 'page' : undefined} class:list={{ 'is-active': activeRecords }}>実績・システム例</a>
      </div>
    </div>

    <a href="/works/first-time" aria-current={activeFirstTime ? 'page' : undefined} class:list={{ 'is-active': activeFirstTime }}>初めての方へ</a>
    <a href="/works/faq" aria-current={activeFaq ? 'page' : undefined} class:list={{ 'is-active': activeFaq }}>FAQ</a>
    <a href="/works/contact" aria-current={activeContact ? 'page' : undefined} class:list={{ 'is-active': activeContact }}>コンタクト</a>
    <a href="/" class="wh-overlay-farm-link">農場HP ↗</a>
    <a href="/works/contact" class="wh-overlay-cta" aria-current={activeContact ? 'page' : undefined}>まずは話してみる →</a>
  </nav>
</div>

<style>
/* ── Header ── */
.wh{
  position:sticky;top:0;z-index:100;
  background:rgba(242,242,240,.92);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border-bottom:1px solid var(--hair);
  padding:20px 60px;
  display:flex;align-items:center;justify-content:space-between;
}
.wh-logo{display:flex;align-items:baseline;gap:10px}
.wh-logo-main{font-family:var(--dp);font-size:20px;letter-spacing:.22em;color:var(--m)}
.wh-logo-sub{font-family:var(--dp);font-size:12px;letter-spacing:.3em;color:var(--a)}
.wh-farm-link{font-family:var(--mn);font-size:10px;letter-spacing:.15em;color:var(--inkm);border:1px solid var(--hair);padding:5px 10px;transition:color .2s,border-color .2s}
.wh-farm-link:hover{color:var(--m);border-color:var(--m)}
.wh-nav{display:flex;align-items:center;gap:24px}
.wh-nav a{font-family:var(--sr);font-size:13px;letter-spacing:.1em;color:var(--ink);transition:color .2s}
.wh-nav a:hover,.wh-nav a[aria-current="page"]{color:var(--a)}
.wh-cta{
  padding:9px 18px;border:1px solid var(--m);
  color:var(--m)!important;
  font-family:var(--dp);font-size:11px;letter-spacing:.18em;
  transition:background .2s,color .2s!important;
}
.wh-cta:hover{background:var(--m);color:var(--bg)!important}
.wh-cta[aria-current="page"]{background:var(--m);color:var(--bg)!important}

/* ── Dropdown ("業務代行 ▾") ── */
.wh-drop{position:relative}
.wh-drop-trigger{
  display:inline-flex;align-items:center;gap:4px;
  background:none;border:none;padding:0;margin:0;cursor:pointer;
  font-family:var(--sr);font-size:13px;letter-spacing:.1em;color:var(--ink);
  transition:color .2s;
}
.wh-drop-trigger:hover,
.wh-drop-trigger[aria-current="page"],
.wh-drop.is-open .wh-drop-trigger{color:var(--a)}
.wh-caret{font-size:10px;line-height:1;transition:transform .2s ease}
.wh-drop.is-open .wh-caret{transform:rotate(180deg)}

.wh-drop-menu{
  list-style:none;margin:0;padding:8px 0;
  position:absolute;top:calc(100% + 16px);left:50%;transform:translateX(-50%);
  min-width:190px;
  background:rgba(242,242,240,.98);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border:1px solid var(--hair);
  box-shadow:0 14px 34px rgba(0,0,0,.09);
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity .18s ease,visibility .18s ease;
}
/* PC: hover opens; click/tap toggles .is-open (JS) for touch/keyboard parity */
.wh-drop:hover .wh-drop-menu,
.wh-drop.is-open .wh-drop-menu{
  opacity:1;visibility:visible;pointer-events:auto;
}
.wh-drop-menu li{margin:0}
.wh-drop-menu a{
  display:block;padding:9px 20px;white-space:nowrap;
  font-size:12px;letter-spacing:.08em;
}
.wh-drop-menu a:hover,.wh-drop-menu a[aria-current="page"]{color:var(--a);background:rgba(0,0,0,.035)}

/* ── Hamburger button (shown below 1024px) ── */
.wh-hamburger{
  display:none;
  flex-direction:column;align-items:center;justify-content:center;
  gap:5px;
  width:48px;height:48px;flex-shrink:0;
  background:none;border:none;padding:0;margin:0;cursor:pointer;
}
.wh-hamburger-bar{
  display:block;width:24px;height:2px;
  background:var(--ink);
  transition:transform .25s ease,opacity .2s ease;
}
.wh-hamburger[aria-expanded="true"] .wh-hamburger-bar:nth-child(1){transform:translateY(7px) rotate(45deg)}
.wh-hamburger[aria-expanded="true"] .wh-hamburger-bar:nth-child(2){opacity:0}
.wh-hamburger[aria-expanded="true"] .wh-hamburger-bar:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* ── Overlay menu (mobile nav, <1024px) ── */
.wh-overlay{
  position:fixed;inset:0;z-index:200;
  background:rgba(242,242,240,.98);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity .22s ease,visibility .22s ease;
  overflow-y:auto;
}
.wh-overlay.is-open{opacity:1;visibility:visible;pointer-events:auto}

.wh-overlay-close{
  position:absolute;top:14px;right:16px;z-index:1;
  width:48px;height:48px;
  display:flex;align-items:center;justify-content:center;
  background:none;border:none;padding:0;margin:0;cursor:pointer;
}
.wh-overlay-close-x{
  position:absolute;width:22px;height:2px;background:var(--ink);
  transition:background .2s;
}
.wh-overlay-close-x:nth-child(1){transform:rotate(45deg)}
.wh-overlay-close-x:nth-child(2){transform:rotate(-45deg)}
.wh-overlay-close:hover .wh-overlay-close-x{background:var(--a)}

.wh-overlay-nav{
  box-sizing:border-box;min-height:100%;width:100%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:20px;
  padding:100px 24px 60px;
}
.wh-overlay-nav > a{
  font-family:var(--sr);font-size:16px;letter-spacing:.08em;color:var(--ink);
  min-height:44px;padding:6px 4px;display:flex;align-items:center;
  transition:color .2s;
}
.wh-overlay-nav a:hover,.wh-overlay-nav a[aria-current="page"]{color:var(--a)}

.wh-overlay-drop{display:flex;flex-direction:column;align-items:center;gap:4px}
.wh-overlay-drop-trigger{
  display:inline-flex;align-items:center;gap:6px;
  min-height:44px;
  background:none;border:none;padding:6px 4px;margin:0;cursor:pointer;
  font-family:var(--sr);font-size:16px;letter-spacing:.08em;color:var(--ink);
  transition:color .2s;
}
.wh-overlay-drop-trigger:hover,
.wh-overlay-drop-trigger[aria-current="page"],
.wh-overlay-drop.is-open .wh-overlay-drop-trigger{color:var(--a)}
.wh-overlay-drop.is-open .wh-caret{transform:rotate(180deg)}

.wh-overlay-drop-menu{
  display:none;flex-direction:column;align-items:center;gap:2px;
  padding:4px 0 0;
}
.wh-overlay-drop.is-open .wh-overlay-drop-menu{display:flex}
.wh-overlay-drop-menu a{
  font-size:14px;opacity:.85;min-height:44px;
  padding:6px 4px;display:flex;align-items:center;
}

.wh-overlay-farm-link{
  margin-top:12px;
  font-family:var(--mn);font-size:11px;letter-spacing:.15em;color:var(--inkm);
  border:1px solid var(--hair);padding:9px 16px;
  transition:color .2s,border-color .2s;
}
.wh-overlay-farm-link:hover{color:var(--m);border-color:var(--m)}

.wh-overlay-cta{
  margin-top:8px;
  padding:13px 28px;border:1px solid var(--m);
  color:var(--m)!important;
  font-family:var(--dp);font-size:12px;letter-spacing:.18em;
  transition:background .2s,color .2s!important;
}
.wh-overlay-cta:hover{background:var(--m);color:var(--bg)!important}
.wh-overlay-cta[aria-current="page"]{background:var(--m);color:var(--bg)!important}

/* ── Responsive ── */
@media (max-width:1023.98px){
  .wh{padding:16px 20px}
  .wh-nav{display:none}
  .wh-hamburger{display:flex}
}
</style>

<script is:inline>
(function(){
  var drops = document.querySelectorAll('.wh-drop');
  drops.forEach(function(drop){
    var trigger = drop.querySelector('.wh-drop-trigger');
    if(!trigger) return;

    function closeDrop(){
      drop.classList.remove('is-open');
      trigger.setAttribute('aria-expanded','false');
    }
    function openDrop(){
      drop.classList.add('is-open');
      trigger.setAttribute('aria-expanded','true');
    }

    // Click/tap toggles (covers touch devices and keyboard Enter/Space
    // on the button, in addition to the CSS :hover reveal on desktop).
    trigger.addEventListener('click', function(e){
      e.stopPropagation();
      if(drop.classList.contains('is-open')){ closeDrop(); } else { openDrop(); }
    });

    // Outside click closes.
    document.addEventListener('click', function(e){
      if(!drop.contains(e.target)) closeDrop();
    });

    // Escape closes and returns focus to the trigger.
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && drop.classList.contains('is-open')){
        closeDrop();
        trigger.focus();
      }
    });
  });
})();

(function(){
  var hamburger = document.getElementById('wh-hamburger');
  var overlay = document.getElementById('wh-overlay');
  var overlayNav = document.getElementById('wh-overlay-nav');
  if(!hamburger || !overlay) return;

  function closeMenu(){
    overlay.classList.remove('is-open');
    hamburger.setAttribute('aria-expanded','false');
    hamburger.setAttribute('aria-label','メニューを開く');
    document.body.style.overflow = '';
  }
  function openMenu(){
    overlay.classList.add('is-open');
    hamburger.setAttribute('aria-expanded','true');
    hamburger.setAttribute('aria-label','メニューを閉じる');
    document.body.style.overflow = 'hidden';
  }

  hamburger.addEventListener('click', function(){
    if(overlay.classList.contains('is-open')){ closeMenu(); } else { openMenu(); }
  });

  // Clicking any link inside the overlay (top-level or submenu) closes it.
  overlay.querySelectorAll('a').forEach(function(link){
    link.addEventListener('click', closeMenu);
  });

  // Clicking the empty backdrop area (outside the nav content) closes it.
  overlay.addEventListener('click', function(e){
    if(e.target === overlay || e.target === overlayNav) closeMenu();
  });

  // Escape closes and returns focus to the hamburger button.
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && overlay.classList.contains('is-open')){
      closeMenu();
      hamburger.focus();
    }
  });

  // Dedicated close (×) button inside the overlay — the hamburger itself is
  // hidden behind the overlay when open, so this is the visible close affordance.
  var overlayClose = document.getElementById('wh-overlay-close');
  if(overlayClose){
    overlayClose.addEventListener('click', function(){ closeMenu(); hamburger.focus(); });
  }

  // If the viewport grows to desktop (>=1024px) while the menu is open, the
  // hamburger disappears — close the overlay so scroll never stays locked.
  window.addEventListener('resize', function(){
    if(window.innerWidth >= 1024 && overlay.classList.contains('is-open')) closeMenu();
  });

  // "業務代行" submenu: inline expand/collapse inside the overlay.
  var subTrigger = document.getElementById('wh-overlay-drop-trigger');
  var subWrap = subTrigger ? subTrigger.closest('.wh-overlay-drop') : null;
  if(subTrigger && subWrap){
    subTrigger.addEventListener('click', function(e){
      e.stopPropagation();
      var isOpen = subWrap.classList.contains('is-open');
      subWrap.classList.toggle('is-open', !isOpen);
      subTrigger.setAttribute('aria-expanded', String(!isOpen));
    });
  }
})();
</script>
