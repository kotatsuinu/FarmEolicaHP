---
/**
 * よくあるご質問（FAQ）ページ — root直下 /faq
 * SEO/AEO施策 P0-C: ロスフラワー通販・花材利用に関する質問を軸に構成。
 * 構造パターンは src/pages/works/faq.astro を踏襲しつつ、root Layout / デザイン言語に合わせて再実装。
 */
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FaqSchema from '../components/seo/FaqSchema.astro';
import lossFlowerHeroImage from '../assets/images/products/loss-flower-hero.jpg';

const title = 'よくあるご質問（FAQ）| Farm Eolica (ファームエオリカ)';
const description = 'ロスフラワーのご購入方法、送料、お届けできる花の種類、花材としてのご利用まで。Farm Eolicaによくいただくご質問にお答えします。';

type FaqItem = {
  q: string;
  a: string; // 表示用（\n\n で段落を区切る。white-space: pre-wrap で改行保持）
  link?: { href: string; label: string };
  needsConfirm?: boolean; // 要確認:卓磨 — 実データ未確定（回答は問い合わせ誘導にとどめている）
};
type FaqCategory = {
  category: string;
  items: FaqItem[];
};

const faqCategories: FaqCategory[] = [
  {
    category: 'ロスフラワーについて',
    items: [
      {
        q: 'ロスフラワーとは何ですか？',
        a: '切り花の生産過程で発生する「花頭（花の部分）」を活用した花材です。茎付きの切り花としては出荷できないものの、花そのものは美しい部分をお届けしています。\n\n福島県浪江町でトルコギキョウやスプレーマムなどを育てるなかで、仕立て作業（脇枝の整理や規格外の枝の選別）や摘心の際に「花頭」が発生します。花首が10〜20cmほど付いたものもあれば、ほとんど無いものもあります。Farm Eolicaでは、本来は廃棄されてしまうはずだったこの花材を、クラフトやドライフラワーの素材として、大切に使ってくださる方にお届けしています。',
        link: { href: '/products/loss-flower', label: 'ロスフラワーの商品ページを見る →' },
      },
      {
        q: 'どんな種類の花が届きますか？中身は選べますか？',
        a: 'その時々で発生した花のみをお届けするため、内容は毎回変わります。すべてのご希望にお応えできるわけではありませんが、事前にご相談いただければ可能な範囲で選別いたします。\n\nロスフラワーは規格外品のため、数量や品質をお約束できるものではなく、曲がり・色ムラ・サイズの不揃いを含みます。発生量にも限りがあり、季節によってお届けできる種類・数量は変動します。必要な用途や時期が事前にわかっている場合は、早めにご連絡いただければ、可能な限り選別してご用意いたします。',
        link: { href: '/products/loss-flower', label: '現在お届けできる花を見る →' },
      },
      {
        q: 'ロスフラワーはいつでも購入できますか？',
        a: 'いいえ、常時ご用意があるわけではありません。発生量に限りがあり、時期によっては商品がない場合もあります。\n\nロスフラワーは栽培・出荷の過程で結果的に発生するものであり、私たちが「出したくて出している」ものではありません。そのため、いつ・どれくらいご用意できるかを事前にお約束することができません。商品ページで随時、現在お届けできる花をご案内していますので、まずはそちらをご確認ください。',
        link: { href: '/products/loss-flower', label: '商品ページで在庫状況を見る →' },
      },
    ],
  },
  {
    category: 'ご購入・お届け',
    items: [
      {
        q: 'Farm Eolica のロスフラワーはどうやって購入できますか？',
        a: '商品ページから内容をご確認のうえ、お問い合わせ・ご注文フォーム、またはInstagramのDMからご連絡ください。\n\nフォームでは見積もり内容を引き継いだお問い合わせも可能です。ご不明な点があれば、ご注文前でもお気軽にご相談ください。',
        link: { href: '/contact?type=estimate', label: 'お問い合わせ・ご注文フォームへ →' },
      },
      {
        q: '送料はいくらですか？',
        a: '発送元は福島県、佐川急便での発送となり、地域ごとの目安（税込）は以下の通りです。\n\n東北〜関東・信越: 910円〜／東海・北陸: 1,040円〜／関西: 1,180円〜\n\n夏季（6〜9月）はクール便のご利用をおすすめしており、その場合は別途料金がかかります。サイズや地域により変動しますので、詳細はご注文時にお気軽にお問い合わせください。',
      },
      {
        q: '届いた花はどのくらい日持ちしますか？',
        a: '保存方法や花の状態によって幅があるため、正確な日持ちの日数については、お問い合わせの際に個別にご案内しています。\n\nロスフラワーは花瓶に生けて楽しむ切り花ではなく、ドライフラワーやレジン封入、クラフト素材としての活用を想定した花材です。そのため一般的な「花瓶での日持ち」とは性質が異なり、保存方法や花の品種・状態によっても変わってきます。具体的な取り扱い方法は、ご注文の際にご相談ください。',
        needsConfirm: true,
        link: { href: '/contact', label: 'お問い合わせはこちら →' },
      },
      {
        q: '注文の最低数量（ロット）はありますか？',
        a: '個人のお客様向けの最低注文数量については、現時点で明確な規定を設けておりません。\n\n価格は小箱・中箱・大箱の3サイズでご案内しています（商品ページ参照）。まとまった数量でのご相談を含め、詳しくはお問い合わせフォームからご相談ください。',
        needsConfirm: true,
        link: { href: '/products/loss-flower', label: '価格・サイズ一覧を見る →' },
      },
      {
        q: '支払い方法は何がありますか？',
        a: 'PayPay、銀行振込、請求書払いにご対応しています。\n\nいずれもご利用いただけますが、初回のお取引につきましては、原則としてご入金確認後の発送とさせていただいております。ご不明な点はお気軽にお問い合わせください。',
      },
    ],
  },
  {
    category: '花材・法人でのご利用',
    items: [
      {
        q: 'ハンドメイドやワークショップの花材として使えますか？',
        a: 'はい。もともとクラフト作家さんやハンドメイドを楽しむ方に向けてお届けしている花材です。\n\nドライフラワーやレジン封入、撮影小物など、切り花とは違う用途でそれぞれの花の美しさを活かしていただくための商品です。まとまった数量が必要なワークショップなどでのご利用については、事前に用途と時期をお知らせいただければ、可能な範囲でご相談に応じます。',
        link: { href: '/products/loss-flower', label: 'ロスフラワーの使い道を見る →' },
      },
      {
        q: '法人・店舗として定期的に仕入れることはできますか？',
        a: '恐れ入りますが、ロスフラワーとしての法人・店舗向け定期仕入れの制度は、現時点でご用意しておりません。\n\n発生量が不定期であるという商品特性上、定期的な仕入れをお約束できるかどうかはご相談の内容によります。法人・店舗でのご利用をご検討の場合は、まずはお問い合わせフォームからご希望の内容（頻度・数量・用途など）をお聞かせください。',
        needsConfirm: true,
        link: { href: '/contact', label: 'お問い合わせはこちら →' },
      },
    ],
  },
];

// JSON-LD 用: 表示用の \n\n 改行を空白に正規化してから渡す（生の改行をJSON-LDに含めない）
const schemaItems = faqCategories.flatMap((c) =>
  c.items.map((f) => ({
    q: f.q,
    a: f.a.replace(/\n{2,}/g, ' ').replace(/\s+/g, ' ').trim(),
  }))
);
---

<Layout title={title} description={description} image={lossFlowerHeroImage.src}>

<FaqSchema items={schemaItems} />

<div class="pt-32 pb-24 min-h-screen">
  <div class="max-w-4xl mx-auto px-6 lg:px-12">
    <div data-animate>
      <SectionHeader
        titleJa="よくあるご質問"
        titleEn="FAQ"
        description="ロスフラワーのご購入について、よくいただくご質問をまとめました。気になることがあれば、遠慮なくお問い合わせください。"
      />
    </div>

    <div class="space-y-16">
      {faqCategories.map((cat) => (
        <div data-animate>
          <h2 class="font-mono text-xs tracking-widest text-warm-gray-500 uppercase mb-6 pb-2 border-b border-warm-gray-200">
            {cat.category}
          </h2>
          <div class="space-y-4">
            {cat.items.map((item) => (
              <details class="group open:bg-old-copper/5 bg-stone-white/95 backdrop-blur-sm shadow-lab transition-colors duration-300">
                <summary class="cursor-pointer list-none flex justify-between items-start gap-4 p-6 md:p-8 hover:bg-warm-gray-50/50 transition-colors duration-200">
                  <span class="font-serif text-base md:text-lg text-wet-soil leading-relaxed">
                    {item.q}
                  </span>
                  <span class="font-mono text-xs text-old-copper flex-shrink-0 mt-1 group-open:rotate-180 transition-transform duration-300">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </summary>
                <div class="px-6 md:px-8 pb-6 md:pb-8">
                  <p class="faq-a text-sm text-warm-gray-600 font-serif leading-loose">{item.a}</p>
                  {item.needsConfirm && (
                    <>{/* 要確認:卓磨 — 実データ未確定 */}</>
                  )}
                  {item.link && (
                    <a
                      href={item.link.href}
                      class="inline-block mt-4 text-xs tracking-widest uppercase font-mono border-b border-old-copper text-old-copper pb-1 hover:border-eolica-green hover:text-eolica-green transition-colors duration-300"
                    >
                      {item.link.label}
                    </a>
                  )}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-20 text-center" data-animate>
      <p class="text-warm-gray-600 text-sm font-serif mb-8">
        ここに載っていないご質問は、お気軽にお問い合わせください。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/products/loss-flower"
          class="inline-block px-8 py-3 text-xs tracking-widest uppercase font-mono border-2 border-eolica-green text-eolica-green hover:bg-eolica-green hover:text-white transition-all duration-300"
        >
          ロスフラワーを見る →
        </a>
        <a
          href="/contact"
          class="inline-block px-8 py-3 text-xs tracking-widest uppercase font-mono border-2 border-old-copper text-old-copper hover:bg-old-copper hover:text-white transition-all duration-300"
        >
          お問い合わせ →
        </a>
      </div>
    </div>

    <!-- Back to Home -->
    <div class="mt-16 text-center" data-animate>
      <a
        href="/"
        class="inline-block text-xs tracking-widest uppercase font-mono border-b border-warm-gray-400 pb-1 hover:border-eolica-green hover:text-eolica-green transition-colors duration-300"
      >
        ← Back to Home
      </a>
    </div>
  </div>
</div>

<style>
  /* FAQ本文は \n\n を含む表示用テキストのため改行を保持する（schema側は正規化済みの別配列を渡している） */
  .faq-a {
    white-space: pre-wrap;
  }
</style>

</Layout>
