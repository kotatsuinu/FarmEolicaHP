---
// Farm Eolica Works — Records (実績・システム例)
// Design: Layout 3 "Tategaki Bento" (Navy × Copper) — self-contained
// Split out of capabilities.astro's RECORD section (2026-07) so the systems
// list can grow independently of the task-menu page. Structural template
// copied from capabilities.astro; system data comes from src/data/works-systems.
import { SITE_CONFIG } from '../../config/site';
import WorksHeader from '../../components/works/WorksHeader.astro';
import { worksSystems, doneCount, totalCount, lastUpdated } from '../../data/works-systems';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';

const title = '実績・システム例 | 業務代行〈AI活用〉| Farm Eolica';
const description = `Farm Eolica がこれまで作ってきたシステムの一覧です。個人事業主が自分の農園の業務効率化のために実際に手を動かし、これまでに${totalCount}件のシステムを作り、うち${doneCount}件が稼働中です。`;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/records/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/records/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ HERO ══════════ -->
<section class="cap-hero">
  <div class="wc">
    <div class="cap-hero-inner reveal reveal-hero reveal-d1">
      <div class="sh-top">
        <span class="sh-en">RECORD</span>
        <span class="sh-line"></span>
        <span class="sh-no">— {doneCount} DONE / {totalCount} TOTAL</span>
      </div>
      <h1 class="cap-h1">実績・システム例。</h1>
      <p class="cap-lead">
        Farm Eolica がこれまで作ってきたシステムの一覧です。<br />
        自分の農園の業務を効率化するために、実際に手を動かして作り、日々使ってきたものです。
      </p>
      <div class="cap-hero-cta">
        <a href="/works/capabilities/" class="contact-btn-ghost">頼めることを見る →</a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ CATEGORY NAV ══════════ -->
<nav class="cap-nav">
  <div class="cap-nav-inner">
    {worksSystems.map(cat => (
      <a href={`#${cat.id}`} class="cap-nav-pill">{cat.label}</a>
    ))}
  </div>
</nav>


<!-- ══════════ RECORD（実績の概要） ══════════ -->
<section class="ws" id="record">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">SYSTEMS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— {worksSystems.length} categories</span>
      </div>
      <h2 class="sh-jp">作ってきたシステム、{doneCount}件。</h2>
    </div>
    <p class="cap-record-lead reveal">
      経理・受注・販促・栽培記録まで、自分の農園の業務をひとつずつAIで組み替えてきた記録です。
    </p>
    <div class="rec-meta reveal">
      <span class="rec-meta-done">稼働中 {doneCount}件</span>
      <span class="rec-meta-sep">|</span>
      <span class="rec-meta-wip">実装中 {totalCount - doneCount}件</span>
      <span class="rec-meta-sep">|</span>
      <span class="rec-meta-date">{lastUpdated} 時点</span>
    </div>
  </div>
</section>


<!-- ══════════ CATEGORIES（実績カテゴリ） ══════════ -->
{worksSystems.map((cat, idx) => (
  <section class={`ws${idx % 2 === 1 ? ' ws-alt' : ''}`} id={cat.id}>
    <div class="wc">
      <div class="sh reveal">
        <div class="sh-top">
          <span class="sh-en">{cat.labelEn}</span>
          <span class="sh-line"></span>
          <span class="sh-no">— {String(idx + 1).padStart(2, '0')} / {String(worksSystems.length).padStart(2, '0')}</span>
        </div>
        <h2 class="sh-jp">{cat.label}</h2>
      </div>

      <div class="cap-grid">
        {cat.items.map(item => (
          <article class="cap-card reveal">
            <div class="cap-card-head">
              <h3 class="cap-card-title">{item.title}</h3>
              <span class={`cap-badge ${item.done ? 'cap-badge-done' : 'cap-badge-wip'}`}>
                {item.done ? '稼働中' : (item.note ?? '実装中')}
              </span>
            </div>
            <p class="cap-card-body">{item.description}</p>
            {item.noteUrl && (
              <a href={item.noteUrl} target="_blank" rel="noopener noreferrer" class="cap-card-note">
                note で詳しく読む →
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
))}


<!-- ══════════ CTA / CONTACT ══════════ -->
<section class="ws" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          気になる項目が<br />
          あれば、ご相談を。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          「こんな課題があるんだけど、相談できるか」<br />
          「自分の仕事に応用できないか知りたい」<br />
          その程度の話から始めましょう。初回は無料です。<br />
          これを毎月一緒に回すのが、業務代行〈AI活用〉です。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">相談する →</a>
          <a href="/works/partner/" class="contact-btn-ghost">業務代行〈AI活用〉を見る →</a>
          <a href="/works/" class="contact-btn-ghost">Works LP →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO FARM&nbsp;EOLICA WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root{
  --m:#1A2744;--a:#B87333;--bg:#F2F2F0;--ink:#4A3B32;
  --inks:rgba(74,59,50,0.72);--inkm:rgba(74,59,50,0.48);--hair:rgba(74,59,50,0.14);
  --sr:'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp:'Cinzel',serif;--mn:'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

/* Animations */
@keyframes fadeInUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(28px)}
.reveal.visible{animation:fadeInUp .75s cubic-bezier(.22,1,.36,1) forwards}
.reveal-d2{animation-delay:.15s}

/* Section commons */
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}
.wc{max-width:1320px;margin:0 auto}
.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:10px;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,2.8vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

/* Cap Hero */
.cap-hero{background:var(--m);padding:90px 60px 80px}
.cap-hero-inner{max-width:820px}
.cap-h1{font-family:var(--sr);font-weight:500;font-size:clamp(34px,3.5vw,54px);color:var(--bg);line-height:1.35;letter-spacing:.04em;margin:0 0 26px}
.cap-lead{font-size:16px;line-height:2;color:rgba(242,242,240,.8);letter-spacing:.04em;max-width:680px}
.cap-hero-cta{margin-top:32px}

/* Cap Nav */
.cap-nav{background:var(--bg);border-bottom:1px solid var(--hair);position:sticky;top:68px;z-index:90;overflow:hidden}
.cap-nav-inner{max-width:1320px;margin:0 auto;padding:0 60px;display:flex;overflow-x:auto;-ms-overflow-style:none;scrollbar-width:none}
.cap-nav-inner::-webkit-scrollbar{display:none}
.cap-nav-pill{font-family:var(--mn);font-size:11px;letter-spacing:.12em;color:var(--inkm);padding:14px 18px;border-bottom:2px solid transparent;white-space:nowrap;transition:color .2s,border-color .2s;flex-shrink:0}
.cap-nav-pill:hover{color:var(--m);border-bottom-color:var(--a)}

/* Cap Grid */
.cap-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}

/* Cap Card */
.cap-card{border:1px solid var(--hair);padding:26px 28px;background:var(--bg);transition:border-color .25s,box-shadow .25s}
.ws-alt .cap-card{background:#EAE6DF}
.cap-card:hover{border-color:rgba(184,115,51,.4);box-shadow:0 4px 20px rgba(26,39,68,.06)}
.cap-card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:14px}
.cap-card-title{font-family:var(--sr);font-size:17px;color:var(--m);letter-spacing:.04em;line-height:1.5;flex:1;margin:0}
.cap-badge{font-family:var(--mn);font-size:10px;letter-spacing:.15em;padding:3px 8px;flex-shrink:0;white-space:nowrap;margin-top:3px}
.cap-badge-done{border:1px solid var(--a);color:var(--a)}
.cap-badge-wip{border:1px solid var(--inkm);color:var(--inkm)}
.cap-card-body{font-size:13.5px;line-height:2;color:var(--inks)}
.cap-card-note{display:inline-block;margin-top:14px;font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--a);border-bottom:1px solid var(--a);padding-bottom:2px;transition:opacity .2s}
.cap-card-note:hover{opacity:.65}

/* Record intro (実績＝土台) */
.cap-record-lead{font-size:15px;line-height:2;color:var(--inks);letter-spacing:.03em;max-width:760px;margin:0 0 28px}
.rec-meta{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
.rec-meta-done{font-family:var(--mn);font-size:11px;letter-spacing:.2em;color:var(--a);border:1px solid var(--a);padding:4px 10px}
.rec-meta-wip{font-family:var(--mn);font-size:11px;letter-spacing:.2em;color:var(--inkm);border:1px solid var(--hair);padding:4px 10px}
.rec-meta-sep{color:var(--hair);font-family:var(--mn)}
.rec-meta-date{font-family:var(--mn);font-size:10px;letter-spacing:.15em;color:var(--inkm)}

/* Contact CTA (reuse from index) */
.contact-section{padding-bottom:100px}
.contact-panel{background:var(--m);color:var(--bg);padding:80px 70px;display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center}
.contact-label{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);margin:0;line-height:1.4;letter-spacing:.04em;color:var(--bg)}
.contact-body{font-size:16px;line-height:2.1;color:rgba(242,242,240,.8);letter-spacing:.04em;margin-bottom:40px;max-width:480px}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap}
.contact-btn-primary{padding:16px 26px;font-family:var(--dp);font-size:13px;letter-spacing:.22em;background:var(--a);color:var(--m);transition:background .25s}
.contact-btn-primary:hover{background:#c98a45}
.contact-btn-ghost{padding:16px 26px;font-family:var(--dp);font-size:13px;letter-spacing:.22em;border:1px solid rgba(242,242,240,.35);color:var(--bg);transition:border-color .25s}
.contact-btn-ghost:hover{border-color:rgba(242,242,240,.7)}

/* Footer */
.wfooter{padding:20px 60px 40px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--hair)}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  setTimeout(function(){
    document.querySelectorAll('.reveal-hero').forEach(function(el){el.classList.add('visible')});
  },30);
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
  els.forEach(function(el){
    if(!el.classList.contains('reveal-hero'))io.observe(el);
  });
  setTimeout(function(){
    document.querySelectorAll('.reveal:not(.visible)').forEach(function(el){el.classList.add('visible')});
  },1500);
})();
</script>

</body>
</html>
