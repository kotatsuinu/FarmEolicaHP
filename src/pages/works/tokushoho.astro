---
// Farm Eolica Works — 特定商取引法に基づく表記
// status: 法務レビュー前ドラフト・公開前に要レビュー
//   正本: farm-eolica-works/02_services/legal/legal_compliance.md（v0.3・2026-05-20時点）
// 注記（プレースホルダ・要ユーザー確認）:
//   - 所在地・電話番号は「ご請求をいただいた場合に遅滞なく開示」パターンで記載（住所・電話番号は掲載しない）
//   - 適格請求書発行事業者登録番号は T1810484782598（確定・反映済み）
//   - 事業者表記「関口卓磨（屋号: Farm Eolica Works）」は最終確定前提（ユーザー確認要）
//   - 問い合わせメールは既存の farmeolica@gmail.com を Works 窓口としても流用（確定・独自ドメインメールは新設しない）
// Self-contained page — independent from main HP design（他 works ページと同じデザイントークンを使用）
import WorksLayout from '../../layouts/WorksLayout.astro';
import WorksHeader from '../../components/works/WorksHeader.astro';
const siteUrl = 'https://farmeolica.com';
const title = '特定商取引法に基づく表記 | Farm Eolica Works';
const description = 'Farm Eolica Works（Web制作・AI活用支援事業）の特定商取引法に基づく表記です。';
const canonical = `${siteUrl}/works/tokushoho/`;
const lastUpdated = '2026年7月6日';
---

<WorksLayout title={title} description={description} canonical={canonical}>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ PAGE HEADER ══════════ -->
<section class="ph-section">
  <div class="wc">
    <div class="ph-top reveal">
      <span class="ph-en">LEGAL</span>
      <span class="ph-line"></span>
    </div>
    <h1 class="ph-title">特定商取引法に基づく表記</h1>
    <p class="ph-lead">
      「特定商取引に関する法律」第11条に基づき、以下のとおり表示します。
    </p>
  </div>
</section>


<!-- ══════════ CONTENT ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="lg-panel reveal">

      <div class="lg-rows">
        <div class="lg-row">
          <div class="lg-k">販売事業者</div>
          <div class="lg-v">関口 卓磨（屋号: Farm Eolica / サブブランド: Farm Eolica Works）</div>
        </div>
        <div class="lg-row">
          <div class="lg-k">運営統括責任者</div>
          <div class="lg-v">関口 卓磨</div>
        </div>
        <div class="lg-row">
          <div class="lg-k">所在地</div>
          <div class="lg-v">福島県双葉郡浪江町<br />（郵便番号・番地の詳細は、ご請求をいただいた場合に遅滞なく開示いたします）</div>
        </div>
        <div class="lg-row">
          <div class="lg-k">連絡先</div>
          <div class="lg-v">
            メールアドレス: farmeolica@gmail.com<br />
            お問い合わせフォーム: <a href="/works/contact">https://farmeolica.com/works/contact</a><br />
            電話番号: ご請求をいただいた場合に遅滞なく開示いたします
          </div>
        </div>
        <div class="lg-row">
          <div class="lg-k">適格請求書発行<br />事業者登録番号</div>
          <div class="lg-v">T1810484782598（インボイス制度対応）</div>
        </div>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">販売価格</h2>
        <p class="lg-body">各商品ページに記載（消費税込み価格）</p>

        <h3 class="lg-h3">成果物単発</h3>
        <ul class="lg-list">
          <li>ロゴ + ブランディングセット: ¥30,000〜¥80,000</li>
          <li>名刺デザイン: ¥8,000〜¥15,000</li>
          <li>ショップカード: ¥10,000〜¥18,000</li>
          <li>店頭POP・販促POP（5点パック）: ¥15,000〜¥20,000</li>
          <li>チラシ A4両面: ¥15,000〜¥25,000</li>
          <li>三つ折りリーフレット（簡易版）: ¥30,000〜¥50,000</li>
          <li>HP制作 スタンダード（1ページ + microCMS）: 通常¥100,000（立ち上げ記念キャンペーン先着5名様¥50,000）</li>
          <li>HP制作 シンプル（1ページ・CMSなし）: 通常¥80,000（立ち上げ記念キャンペーン先着5名様¥40,000）</li>
          <li>多ページ コーポレートHP: 応相談（目安¥150,000〜）</li>
        </ul>
        <p class="lg-body" style="margin-top:12px">オプション: ページ追加 +¥10,000/ページ、カスタムドメイン設定 +¥5,000（ドメイン代等の実費別途）、印刷用PDF出力 +¥15,000〜30,000</p>
        <p class="lg-body" style="margin-top:8px">修正: 通常2ターンまで無料、3ターン目以降は+¥3,000/ターン。公開後30日以内の誤字・軽微なレイアウト修正は無料。</p>

        <h3 class="lg-h3">月額契約</h3>
        <ul class="lg-list">
          <li>HP保守 ライト（自社制作1ページサイト限定）: ¥5,000/月</li>
          <li>HP保守 スタンダード（多ページ・GA4月次レポート付き）: ¥12,000/月（年払いの場合2ヶ月分割引）</li>
          <li>代行プラン（業務代行〈AI活用〉）: ¥20,000/月（月20タスクを上限の目安とし、順次対応）</li>
          <li>代行＋AI活用コーチングプラン（業務代行〈AI活用〉）: 通常¥40,000/月（立ち上げ記念キャンペーン先着5名様は初月¥20,000、2〜3ヶ月目以降は通常価格）。AI活用コーチング（月次レクチャー・相談枠）を含みます</li>
        </ul>
        <p class="lg-body" style="margin-top:8px">上位プラン（常駐・大型案件・自動化構築）は非公開・応相談です。</p>

        <h3 class="lg-h3">立ち上げ記念キャンペーン</h3>
        <p class="lg-body">
          HP制作の各商品（スタンダード/シンプル）ごとに独立して先着5名様限定の特別価格を提供します（6件目以降は通常価格）。ポートフォリオ掲載への同意及び完成後払い100%が条件となります。残枠は各商品ページに明示されます。
        </p>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">商品代金以外の必要料金</h2>
        <ul class="lg-list">
          <li>銀行振込手数料（振込時のみ、お客様負担）</li>
          <li>通信費（インターネット接続料金等、お客様負担）</li>
          <li>印刷費用（印刷物の場合、お客様負担）</li>
          <li>ドメイン・サーバー費用（HP制作の場合、お客様負担 or Cloudflare Pages無料運用案内）</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">支払方法</h2>
        <ul class="lg-list">
          <li>クレジットカード決済（Stripe 経由）</li>
          <li>銀行振込（請求書払い、月額契約・大型案件のみ）</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">支払時期</h2>
        <ul class="lg-list">
          <li>成果物単発（先着5名様・立ち上げ記念キャンペーン価格）: 完成後払い100%（前払いはいただきません）</li>
          <li>成果物単発（通常価格）: 着手前50%、納品時50%</li>
          <li>月額契約（HP保守/業務代行〈AI活用〉）: 毎月1日に当月分を自動課金、または請求書発行から15日以内</li>
          <li>月額契約を年払いで選択した場合: 契約締結時に全額前払い（2ヶ月分割引後の金額）</li>
          <li>大型成果物（多ページコーポレートHP ¥150,000超）: 着手前50%、納品時50%</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">商品の引渡時期</h2>
        <ul class="lg-list">
          <li>HP制作（スタンダード/シンプル・1ページ）: 最短10営業日〜（通常2〜3週間、繁忙期 4〜5週間）</li>
          <li>多ページ コーポレートHP: 6週間（繁忙期 8〜9週間）</li>
          <li>ロゴ + ブランディング: 2週間（繁忙期 3週間）</li>
          <li>名刺・ショップカード・POP・チラシ・三つ折りリーフレット（簡易版）: 1〜2週間</li>
          <li>業務代行〈AI活用〉（月額）: 契約締結後、初回打合せを経て翌月から正式開始</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">キャンセル・返金規定</h2>
        <ul class="lg-list">
          <li>通常価格（着手前50%を前払いいただく場合）の着手前キャンセル: 前払い分（50%）を返金いたします</li>
          <li>通常価格の着手後キャンセル: 返金はいたしません</li>
          <li>先着5名様（完成後払い100%・前払いなし）: 前払いがないため返金は発生しません。着手後にキャンセルされた場合は、それまでの作業分に相当する対価をご請求する場合があります</li>
          <li>提供者側の都合（病気・災害等）でサービス提供不可の場合: 全額返金</li>
          <li>HP保守（ライト・スタンダード）月額契約: 最低契約期間3ヶ月、以降1ヶ月単位で解約可（前月末日まで通告）</li>
          <li>代行プラン（月額契約）: 最低契約期間3ヶ月、以降1ヶ月単位で解約可（前月末日まで通告）</li>
          <li>代行＋AI活用コーチングプラン（月額契約）: 最低契約期間3ヶ月、以降1ヶ月単位で解約可（前月末日まで通告）</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">動作環境</h2>
        <p class="lg-body">特に指定なし。一般的なPC・スマートフォン・タブレットで利用可能です。Slack / LINE / Zoom のいずれかが使えること。</p>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">提供者の繁忙期について</h2>
        <p class="lg-body">
          販売事業者は花卉農業を本業としており、5月から10月は栽培の繁忙期となります。この期間は以下の対応となります。
        </p>
        <ul class="lg-list">
          <li>業務代行〈AI活用〉契約者向け応答SLA: 繁忙期は営業日3日以内（通常は24時間以内）</li>
          <li>制作期間: 通常の1.5倍に延長</li>
          <li>新規受注: 状況により応相談</li>
        </ul>
        <p class="lg-body">これらの条件をご了承いただける方とのみ契約させていただきます。</p>
      </div>

      <p class="lg-updated">最終更新日: {lastUpdated}</p>
    </div>

    <a href="/works/" class="lg-back">← BACK TO WORKS</a>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<!-- :root トークン / reset / @keyframes fadeInUp / .reveal / Google Fonts は
     src/styles/works-base.css（WorksLayout経由）に移設済み。
     以下はtokushoho固有の追加・上書きのみ。 -->
<style is:global>
/* tokushoho固有: .wc の max-width は works配下ページ間で不一致のため works-base.css には
   入れず、ページ側で明示指定。 */
.wc{max-width:900px}

/* Page header hero */
.ph-section{padding:80px 60px 60px;background:var(--m)}
.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.ph-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(2rem, 4vw + 1rem, 3rem);color:var(--bg);margin:0 0 16px;letter-spacing:.04em;line-height:1.3}
.ph-lead{font-family:var(--zo);font-size:0.9375rem;color:rgba(242,242,240,.7);letter-spacing:.05em;line-height:1.8;margin:0}

/* Content section */
.ws{padding:70px 60px 60px}
.lg-panel{background:#fff;border:1px solid var(--hair);padding:50px 56px}
.lg-rows{margin-bottom:40px}
.lg-row{display:grid;grid-template-columns:200px 1fr;gap:20px;padding:16px 0;border-bottom:1px solid var(--hair);align-items:baseline}
.lg-row:last-child{border-bottom:none}
.lg-k{font-family:var(--mn);font-size:0.75rem;letter-spacing:.08em;color:var(--inkm);line-height:1.6}
.lg-v{font-size:0.875rem;line-height:1.95;color:var(--ink)}
.lg-v a{color:var(--m);border-bottom:1px solid var(--hair)}
.lg-v a:hover{color:var(--a);border-bottom-color:var(--a)}
.lg-section{margin-bottom:40px}
.lg-section:last-of-type{margin-bottom:0}
.lg-h2{font-family:var(--sr);font-size:1.25rem;font-weight:500;color:var(--m);letter-spacing:.04em;margin:0 0 16px;padding-bottom:10px;border-bottom:1px solid var(--hair)}
.lg-h3{font-family:var(--sr);font-size:0.96875rem;font-weight:500;color:var(--m);letter-spacing:.03em;margin:22px 0 10px}
.lg-body{font-size:0.875rem;line-height:2;color:var(--inks);margin-bottom:12px}
.lg-body:last-child{margin-bottom:0}
.lg-list{list-style:disc;padding-left:22px;margin:0 0 12px;font-size:0.875rem;line-height:1.95;color:var(--inks)}
.lg-list li{margin-bottom:6px}
.lg-updated{text-align:right;font-family:var(--mn);font-size:0.75rem;letter-spacing:.1em;color:var(--inkm);margin-top:36px}
.lg-back{display:inline-block;margin-top:40px;font-family:var(--dp);font-size:0.75rem;letter-spacing:.22em;color:var(--m);border-bottom:1px solid var(--m);padding-bottom:2px}
.lg-back:hover{color:var(--a);border-bottom-color:var(--a)}

/* Footer */
.wfooter{padding:20px 60px 40px;display:flex;flex-wrap:wrap;gap:12px 24px;justify-content:space-between;align-items:center;border-top:1px solid var(--hair)}
.wfooter-back{font-family:var(--dp);font-size:0.75rem;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:0.75rem;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:0.75rem;letter-spacing:.18em;color:var(--inkm)}

@media (max-width:768px){
  .ph-section{padding:60px 24px 40px}
  .ws{padding:50px 24px 40px}
  .lg-panel{padding:32px 24px}
  .lg-row{grid-template-columns:1fr;gap:6px}
  .wfooter{padding:20px 24px 32px}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});
  } else {
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        e.target.classList.add('visible');io.unobserve(e.target);
      });
    },{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
    els.forEach(function(el){io.observe(el)});
  }
})();
</script>

</WorksLayout>
