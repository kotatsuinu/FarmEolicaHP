---
// Farm Eolica Works — はじめての方へ
// Self-contained page — independent from main HP design
import { SITE_CONFIG } from '../../config/site';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = 'はじめての方へ | Farm Eolica Works';
const description = '無料相談の理由、私のスタンス、どんな方と仕事したいか。Farm Eolica Works（農家×元編集者×AIエンジニア）と仕事する前に知ってほしいこと。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/first-time/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/first-time/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<header class="wh">
  <a href="/works/" class="wh-logo">
    <span class="wh-logo-main">FARM&nbsp;EOLICA</span>
    <span class="wh-logo-sub">/ WORKS</span>
  </a>
  <nav class="wh-nav">
    <a href="/works/#about">About</a>
    <a href="/works/#services">Services</a>
    <a href="/works/capabilities">できること</a>
    <a href="/works/first-time" class="wh-nav-active">はじめての方へ</a>
    <a href="/" class="wh-farm-link">農場HP ↗</a>
    <a href="/works/contact" class="wh-cta">まずは話してみる →</a>
  </nav>
</header>


<!-- ══════════ PAGE HEADER ══════════ -->
<section class="ph-section">
  <div class="wc">
    <div class="ph-top reveal">
      <span class="ph-en">FOR FIRST TIME</span>
      <span class="ph-line"></span>
    </div>
    <h1 class="ph-title reveal">はじめての方へ。</h1>
    <p class="ph-lead reveal">
      依頼する前に、少しだけ私のことを知ってもらえると嬉しいです。
    </p>
  </div>
</section>


<!-- ══════════ CONTENT ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="ftg">

      <!-- Block 1: なぜ無料相談か (wide) -->
      <div class="ft-block ft-block-wide reveal">
        <div class="ft-block-inner">
          <div class="ft-no">01</div>
          <div>
            <h2 class="ft-title">なぜ、無料相談なのか。</h2>
            <p class="ft-body">
              「無料と言いつつ、強引に契約を迫られた」そんな経験をお持ちの方もいると思います。私の無料相談はそのためではありません。
            </p>
            <p class="ft-body">
              60分お話しすることで、私自身が「どんな方がどんなことに困っているか」を学べます。相談の結果「やはり合わない」となっても、それはお互いにとって正直な答えです。無理な営業はしません。相談件数は、そのまま私の経験値になります。
            </p>
            <p class="ft-body">
              だから、無料なのです。
            </p>
          </div>
        </div>
      </div>

      <!-- Block 2: スタンス -->
      <div class="ft-block reveal">
        <div class="ft-block-inner">
          <div class="ft-no">02</div>
          <div>
            <h2 class="ft-title">私のスタンス。</h2>
            <p class="ft-body">
              「欲しいものを作ります」だけでは終わりません。「それ、目的に合っていますか？」という問いを横に置きながら仕事します。
            </p>
            <p class="ft-body">
              ホームページよりSNSが先かもしれない。予算を使う前に整理すべきことがあるかもしれない。チラシのデザインより、誰に届けるかの設計が先かもしれない。そういった視点も持ちながら、最終的にはあなたが達成したいことに向けて一緒に動きます。
            </p>
            <p class="ft-body">
              コンサルをします、という話ではありません。ただ、「欲しいもの」と「必要なもの」がズレているとき、そっと別の視点を添えることができる——それが私のやり方です。
            </p>
          </div>
        </div>
      </div>

      <!-- Block 3: 死んでも困らない納品 -->
      <div class="ft-block reveal">
        <div class="ft-block-inner">
          <div class="ft-no">03</div>
          <div>
            <h2 class="ft-title">死んでも困らない納品。</h2>
            <p class="ft-body">
              個人事業だからこそ気になるのが「もしこの人がいなくなったら、サイトはどうなるの」という不安だと思います。
            </p>
            <p class="ft-body">
              私の制作はAstroという静的サイト生成の技術を使います。WordPressのような複雑なサーバー環境も、月額のサーバー契約も必要ありません。攻撃を受けやすい仕組みを、そもそも持たない作り方です。
            </p>
            <p class="ft-body">
              納品物はHTML/CSS/JSのソースコード一式をGitHubリポジトリでまるごとお渡しし、公開先はお客様ご自身のCloudflareアカウント（無料枠）です。もし私に何かあってもサイトは動き続けますし、特定の業者に縛られる「ロックイン」もありません。
            </p>
          </div>
        </div>
      </div>

      <!-- Block 4: こんな方と仕事したい -->
      <div class="ft-block reveal">
        <div class="ft-block-inner">
          <div class="ft-no">04</div>
          <div>
            <h2 class="ft-title">こんな方と仕事したい。</h2>
            <div class="ft-list">
              <div class="ft-item ft-ok">
                <div class="ft-mark-wrap">
                  <span class="ft-mark">◎</span>
                  <span class="ft-mark-label">向いている方</span>
                </div>
                <p>食・農・工房・宿・個人店など、ローカルでストーリーを持って仕事をしている方（10名規模までの個人事業主・小規模事業者）。「全部任せます」も「一緒に考えたい」も歓迎。裁量を持って動ける方。目的に向かって、一緒に試行錯誤できる方。</p>
              </div>
              <div class="ft-item ft-caution">
                <div class="ft-mark-wrap">
                  <span class="ft-mark">△</span>
                  <span class="ft-mark-label">難しい場合</span>
                </div>
                <p>農家として個人で動いているため、大企業・大規模案件はお受けが難しい場合があります。農繁期（5〜10月）は応答が遅くなることもあります。そのような場合は他の専門企業をご紹介します。「安く早く大量に」を求める場合も、私より適した選択肢があると思います。</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Block 5: できること概要 (wide, CTA) -->
      <div class="ft-block ft-block-wide ft-block-cta reveal">
        <div class="ft-block-inner">
          <div class="ft-no">05</div>
          <div class="ft-cta-content">
            <div>
              <h2 class="ft-title">できること、もう少し詳しく。</h2>
              <div class="ft-services">
                {[
                  { k: 'HP・LP制作', v: 'スタンダード（1p+microCMS）先着5名¥50,000・通常¥100,000。シンプル（CMSなし）先着5名¥40,000・通常¥80,000。' },
                  { k: '簡易デザイン', v: '名刺・ショップカード・店頭POP・チラシ。PDF/EPS/PNG納品。' },
                  { k: '月額AIパートナー（制作後の伴走）', v: 'AI導入・業務自動化・サイト更新を月単位で伴走する「第2幕」。制作完了後にご案内。¥20,000/月〜。' },
                  { k: 'DXツール開発', v: '現場の小さな課題を自動化・システム化。ご相談ください。' },
                ].map(s => (
                  <div class="ft-svc-row">
                    <span class="ft-svc-k">{s.k}</span>
                    <span class="ft-svc-v">{s.v}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="ft-cta-btns">
              <a href="/works/capabilities" class="btn-ghost">農場で作ってきた36のシステムを見る →</a>
              <a href="/works/contact" class="btn-filled">まずは相談してみる →</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root {
  --m: #1A2744;
  --a: #B87333;
  --bg: #F2F2F0;
  --ink: #4A3B32;
  --inks: rgba(74,59,50,0.72);
  --inkm: rgba(74,59,50,0.48);
  --hair: rgba(74,59,50,0.14);
  --sr: 'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp: 'Cinzel',serif;
  --mn: 'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

@keyframes fadeInUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(24px)}
.reveal.visible{animation:fadeInUp .7s cubic-bezier(.22,1,.36,1) forwards}

/* ── Header ── */
.wh{
  position:sticky;top:0;z-index:100;
  background:rgba(242,242,240,.92);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border-bottom:1px solid var(--hair);
  padding:20px 60px;
  display:flex;align-items:center;justify-content:space-between;
}
.wh-logo{display:flex;align-items:baseline;gap:10px}
.wh-logo-main{font-family:var(--dp);font-size:20px;letter-spacing:.22em;color:var(--m)}
.wh-logo-sub{font-family:var(--dp);font-size:12px;letter-spacing:.3em;color:var(--a)}
.wh-farm-link{font-family:var(--mn);font-size:10px;letter-spacing:.15em;color:var(--inkm);border:1px solid var(--hair);padding:5px 10px;transition:color .2s,border-color .2s}
.wh-farm-link:hover{color:var(--m);border-color:var(--m)}
.wh-nav{display:flex;align-items:center;gap:28px}
.wh-nav a{font-family:var(--sr);font-size:13px;letter-spacing:.1em;color:var(--ink);transition:color .2s}
.wh-nav a:hover{color:var(--a)}
.wh-nav-active{color:var(--a)!important}
.wh-cta{
  padding:9px 18px;border:1px solid var(--m);
  color:var(--m)!important;
  font-family:var(--dp);font-size:11px;letter-spacing:.18em;
  transition:background .2s,color .2s!important;
}
.wh-cta:hover{background:var(--m);color:var(--bg)!important}

/* ── Page Header ── */
.ph-section{padding:80px 60px 60px;background:var(--m)}
.wc{max-width:1120px;margin:0 auto}
.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.ph-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(44px,4vw,64px);color:var(--bg);margin:0 0 20px;letter-spacing:.04em;line-height:1.2}
.ph-lead{font-family:var(--sr);font-size:16px;color:rgba(242,242,240,.7);letter-spacing:.06em;line-height:1.8;margin:0}

/* ── Section ── */
.ws{padding:80px 60px 100px}

/* ── Content Grid ── */
.ftg{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.ft-block{
  background:var(--bg);border:1px solid var(--hair);padding:0;overflow:hidden;
}
.ft-block-wide{grid-column:span 2}
.ft-block-cta{background:rgba(26,39,68,.04)}

.ft-block-inner{display:flex;gap:0}
.ft-no{
  font-family:var(--dp);font-size:11px;letter-spacing:.3em;color:var(--a);
  writing-mode:vertical-rl;text-orientation:mixed;
  padding:28px 16px;border-right:1px solid var(--hair);
  flex-shrink:0;
}
.ft-block-inner > div:last-child{padding:36px 32px;flex:1}

.ft-title{font-family:var(--sr);font-size:26px;color:var(--m);letter-spacing:.05em;margin:0 0 20px;line-height:1.3}
.ft-body{font-size:14.5px;line-height:2.1;color:var(--inks);margin-bottom:16px}
.ft-body:last-child{margin-bottom:0}

/* ── List ── */
.ft-list{display:flex;flex-direction:column;gap:28px;margin-top:8px}
.ft-item{display:flex;flex-direction:column;gap:10px}
.ft-mark-wrap{display:flex;align-items:center;gap:10px}
.ft-mark{font-family:var(--sr);font-size:18px;font-weight:600}
.ft-mark-label{font-family:var(--dp);font-size:10px;letter-spacing:.3em;color:var(--inkm)}
.ft-ok .ft-mark{color:var(--a)}
.ft-caution .ft-mark{color:var(--inkm)}
.ft-item p{font-size:14px;line-height:2;color:var(--inks);margin:0;padding-left:28px}

/* ── Services list ── */
.ft-services{margin-bottom:32px;border-top:1px solid var(--hair);margin-top:20px}
.ft-svc-row{
  display:grid;grid-template-columns:180px 1fr;gap:20px;
  padding:16px 0;border-bottom:1px solid var(--hair);
  align-items:baseline;
}
.ft-svc-k{font-family:var(--sr);font-size:15px;font-weight:500;color:var(--m);letter-spacing:.04em}
.ft-svc-v{font-size:13.5px;line-height:1.9;color:var(--inks)}

/* ── CTA content ── */
.ft-cta-content{display:flex;flex-direction:column;justify-content:space-between;height:100%}
.ft-cta-btns{display:flex;gap:16px;flex-wrap:wrap;padding-top:20px}

/* ── Buttons ── */
.btn-filled,.btn-ghost{
  display:inline-flex;align-items:center;
  padding:13px 22px;
  font-family:var(--dp);font-size:12px;letter-spacing:.22em;
  transition:all .25s;cursor:pointer;
}
.btn-filled{background:var(--m);color:var(--bg);border:1px solid var(--m)}
.btn-filled:hover{background:#253a6b;border-color:#253a6b}
.btn-ghost{background:transparent;color:var(--m);border:1px solid var(--m)}
.btn-ghost:hover{background:rgba(26,39,68,.07)}

/* ── Footer ── */
.wfooter{
  padding:20px 60px 40px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--hair);
}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-back:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');
      io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  setTimeout(function(){
    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible')});
  },60);
  els.forEach(function(el){io.observe(el)});
})();
</script>

</body>
</html>
