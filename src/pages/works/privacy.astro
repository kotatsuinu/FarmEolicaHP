---
// Farm Eolica Works — プライバシーポリシー
// status: 法務レビュー前ドラフト・公開前に要レビュー
//   正本: farm-eolica-works/02_services/legal/legal_compliance.md（v0.3・2026-05-20時点）
// 注記:
//   - これは Web制作事業（Works）専用のプライバシーポリシー。花卉ECサイト向けの既存 /privacy とは別内容・別ページ（URL衝突なし）
//   - 事業者表記「関口卓磨（屋号: Farm Eolica Works）」は最終確定前提（ユーザー確認要）
//   - 問い合わせメールは既存の farmeolica@gmail.com を Works 窓口としても流用（確定・独自ドメインメールは新設しない）
// Self-contained page — independent from main HP design（他 works ページと同じデザイントークンを使用）
import WorksLayout from '../../layouts/WorksLayout.astro';
import WorksHeader from '../../components/works/WorksHeader.astro';
const siteUrl = 'https://farmeolica.com';
const title = 'プライバシーポリシー | Farm Eolica Works';
const description = 'Farm Eolica Works（Web制作・AI活用支援事業）のプライバシーポリシーです。';
const canonical = `${siteUrl}/works/privacy/`;
const lastUpdated = '2026年7月3日';
---

<WorksLayout title={title} description={description} canonical={canonical}>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ PAGE HEADER ══════════ -->
<section class="ph-section">
  <div class="wc">
    <div class="ph-top reveal">
      <span class="ph-en">LEGAL</span>
      <span class="ph-line"></span>
    </div>
    <h1 class="ph-title">プライバシーポリシー</h1>
    <p class="ph-lead">
      Farm Eolica Works（以下「当事業者」）は、お客様からお預かりする個人情報を、以下の方針に基づき適切に取り扱います。
    </p>
  </div>
</section>


<!-- ══════════ CONTENT ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="lg-panel reveal">

      <div class="lg-section">
        <h2 class="lg-h2">1. 個人情報の定義</h2>
        <p class="lg-body">
          本ポリシーにおいて「個人情報」とは、個人情報保護法第2条第1項により定義される個人情報を指します。
        </p>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">2. 個人情報の取得</h2>
        <p class="lg-body">当事業者は、本サービスの提供にあたり、以下の個人情報を取得します。</p>
        <ul class="lg-list">
          <li>屋号・法人名</li>
          <li>担当者名</li>
          <li>メールアドレス</li>
          <li>電話番号（任意）</li>
          <li>業種・年商規模・所在地（都道府県のみ）</li>
          <li>依頼内容</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">3. 個人情報の利用目的</h2>
        <p class="lg-body">取得した個人情報は、以下の目的でのみ利用します。</p>
        <ul class="lg-list">
          <li>本サービスの提供</li>
          <li>お問い合わせへの回答</li>
          <li>請求書発行・決済</li>
          <li>サービス改善のための分析（個人を特定しない形式で）</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">4. 個人情報の第三者提供</h2>
        <p class="lg-body">
          当事業者は、お客様の同意なく個人情報を第三者に提供しません。ただし、以下の場合は除きます。
        </p>
        <ul class="lg-list">
          <li>法令に基づく開示要求</li>
          <li>人の生命・身体・財産の保護に必要な場合</li>
          <li>業務委託先（決済代行業者、メール配信業者等）への提供（最小限）</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">5. 個人情報の管理</h2>
        <ul class="lg-list">
          <li>Cloudflare R2 のプライベートバケットに暗号化保存</li>
          <li>業務PCに2要素認証</li>
          <li>5年以上未利用の個人情報は削除</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">6. 受領しない情報</h2>
        <p class="lg-body">当事業者は、以下の高機微情報を受領しません。</p>
        <ul class="lg-list">
          <li>クレジットカード番号</li>
          <li>マイナンバー</li>
          <li>銀行口座番号</li>
          <li>生体認証情報</li>
        </ul>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">7. Cookie等の利用</h2>
        <p class="lg-body">
          当事業者のHPは、Google Analytics 4 を利用してアクセス解析を行います。匿名化された統計データのみを取得し、個人を特定する情報は収集しません。
        </p>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">8. 開示・訂正・削除請求</h2>
        <p class="lg-body">
          お客様は、当事業者に対し、自己の個人情報の開示・訂正・削除を請求できます。請求は farmeolica@gmail.com までご連絡ください。
        </p>
      </div>

      <div class="lg-section">
        <h2 class="lg-h2">9. お問い合わせ窓口</h2>
        <div class="lg-rows">
          <div class="lg-row">
            <div class="lg-k">事業者</div>
            <div class="lg-v">関口 卓磨（屋号: Farm Eolica / サブブランド: Farm Eolica Works）</div>
          </div>
          <div class="lg-row">
            <div class="lg-k">メール</div>
            <div class="lg-v">farmeolica@gmail.com</div>
          </div>
        </div>
      </div>

      <p class="lg-updated">最終更新日: {lastUpdated}</p>
    </div>

    <a href="/works/" class="lg-back">← BACK TO WORKS</a>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<!-- :root トークン / reset / @keyframes fadeInUp / .reveal / Google Fonts は
     src/styles/works-base.css（WorksLayout経由）に移設済み。
     以下はprivacy固有の追加・上書きのみ。 -->
<style is:global>
/* privacy固有: .wc の max-width は works配下ページ間で不一致のため works-base.css には
   入れず、ページ側で明示指定。 */
.wc{max-width:900px}

/* Page header hero */
.ph-section{padding:80px 60px 60px;background:var(--m)}
.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.ph-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(32px,4vw,48px);color:var(--bg);margin:0 0 16px;letter-spacing:.04em;line-height:1.3}
.ph-lead{font-family:var(--sr);font-size:0.9375rem;color:rgba(242,242,240,.7);letter-spacing:.05em;line-height:1.8;margin:0}

/* Content section */
.ws{padding:70px 60px 60px}
.lg-panel{background:#fff;border:1px solid var(--hair);padding:50px 56px}
.lg-section{margin-bottom:36px}
.lg-section:last-of-type{margin-bottom:0}
.lg-h2{font-family:var(--sr);font-size:1.1875rem;font-weight:500;color:var(--m);letter-spacing:.04em;margin:0 0 14px;padding-bottom:10px;border-bottom:1px solid var(--hair)}
.lg-body{font-size:0.875rem;line-height:2;color:var(--inks);margin-bottom:12px}
.lg-body:last-child{margin-bottom:0}
.lg-list{list-style:disc;padding-left:22px;margin:0 0 12px;font-size:0.875rem;line-height:1.95;color:var(--inks)}
.lg-list li{margin-bottom:6px}
.lg-rows{margin-top:8px}
.lg-row{display:grid;grid-template-columns:120px 1fr;gap:20px;padding:12px 0;border-bottom:1px solid var(--hair);align-items:baseline}
.lg-row:last-child{border-bottom:none}
.lg-k{font-family:var(--mn);font-size:0.75rem;letter-spacing:.08em;color:var(--inkm)}
.lg-v{font-size:0.875rem;line-height:1.9;color:var(--ink)}
.lg-updated{text-align:right;font-family:var(--mn);font-size:0.75rem;letter-spacing:.1em;color:var(--inkm);margin-top:36px}
.lg-back{display:inline-block;margin-top:40px;font-family:var(--dp);font-size:0.75rem;letter-spacing:.22em;color:var(--m);border-bottom:1px solid var(--m);padding-bottom:2px}
.lg-back:hover{color:var(--a);border-bottom-color:var(--a)}

/* Footer */
.wfooter{padding:20px 60px 40px;display:flex;flex-wrap:wrap;gap:12px 24px;justify-content:space-between;align-items:center;border-top:1px solid var(--hair)}
.wfooter-back{font-family:var(--dp);font-size:0.75rem;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:0.75rem;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:0.75rem;letter-spacing:.18em;color:var(--inkm)}

@media (max-width:768px){
  .ph-section{padding:60px 24px 40px}
  .ws{padding:50px 24px 40px}
  .lg-panel{padding:32px 24px}
  .lg-row{grid-template-columns:1fr;gap:6px}
  .wfooter{padding:20px 24px 32px}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});
  } else {
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        e.target.classList.add('visible');io.unobserve(e.target);
      });
    },{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
    els.forEach(function(el){io.observe(el)});
  }
})();
</script>

</WorksLayout>
