</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root {
  --m: #1A2744;
  --a: #B87333;
  --bg: #F2F2F0;
  --ink: #4A3B32;
  --inks: rgba(74,59,50,0.72);
  --inkm: rgba(74,59,50,0.48);
  --hair: rgba(74,59,50,0.14);
  --sr: 'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp: 'Cinzel',serif;
  --mn: 'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

@keyframes fadeInUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(24px)}
.reveal.visible{animation:fadeInUp .7s cubic-bezier(.22,1,.36,1) forwards}

/* ── Common section wrappers ── */
.wc{max-width:1120px;margin:0 auto}
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}

.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.ph-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.ph-lead{font-family:var(--sr);font-size:16px;color:rgba(242,242,240,.7);letter-spacing:.06em;line-height:1.8;margin:0}

.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:10px;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

/* ── Hero (page header, navy) ── */
.pt-hero{padding:80px 60px 60px;background:var(--m)}
.pt-hero .ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(38px,4vw,58px);color:var(--bg);margin:0 0 20px;letter-spacing:.04em;line-height:1.4}
.pt-hero .ph-lead{margin-bottom:32px;max-width:680px}
.pt-hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.pt-hero-btns .btn-ghost{color:var(--bg);border-color:rgba(242,242,240,.5)}
.pt-hero-btns .btn-ghost:hover{background:rgba(242,242,240,.08)}
.pt-hero-btns .btn-filled{background:var(--a);border-color:var(--a);color:var(--m)}
.pt-hero-btns .btn-filled:hover{background:#c98a45;border-color:#c98a45}

/* ── Buttons ── */
.btn-filled,.btn-ghost{
  display:inline-flex;align-items:center;
  padding:13px 22px;
  font-family:var(--dp);font-size:12px;letter-spacing:.22em;
  transition:all .25s;cursor:pointer;
}
.btn-filled{background:var(--m);color:var(--bg);border:1px solid var(--m)}
.btn-filled:hover{background:#253a6b;border-color:#253a6b}
.btn-ghost{background:transparent;color:var(--m);border:1px solid var(--m)}
.btn-ghost:hover{background:rgba(26,39,68,.07)}

/* ── Content blocks / lists ── */
.cs-block{max-width:760px}
.cs-body{font-size:15px;line-height:2.1;color:var(--inks);letter-spacing:.03em;margin-bottom:18px}
.cs-body:last-child{margin-bottom:0}

.ft-list{display:flex;flex-direction:column;gap:14px;margin-top:28px}
.ft-item{display:flex;gap:14px;align-items:flex-start;font-size:14.5px;line-height:1.9;color:var(--inks)}
.ft-mark{font-family:var(--sr);font-size:14px;font-weight:600;flex-shrink:0;margin-top:2px;color:var(--a)}

/* ── Scene cards (for whom) ── */
.scene-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:36px}
.scene-card{
  background:var(--bg);border:1px solid var(--hair);
  padding:26px 26px 24px;
  display:flex;flex-direction:column;gap:14px;
  transition:border-color .25s,box-shadow .25s,transform .25s;
}
.scene-card:hover{border-color:var(--a);box-shadow:0 8px 32px rgba(26,39,68,.10);transform:translateY(-3px)}
.scene-tag{font-family:var(--sr);font-size:16.5px;color:var(--m);letter-spacing:.03em;line-height:1.5}
.scene-task{font-size:13px;line-height:1.8;color:var(--inks)}
.scene-shift{
  display:flex;align-items:baseline;gap:10px;
  font-family:var(--mn);font-size:11.5px;letter-spacing:.03em;
  padding-top:12px;border-top:1px dashed var(--hair);
}
.scene-before{color:var(--inkm)}
.scene-arrow{color:var(--a)}
.scene-after{color:var(--m);font-weight:600}
.scene-note{margin-top:28px;font-size:13px;max-width:760px}

/* ── Value proposition (draft → deliverable) ── */
.value-block{max-width:820px;margin-top:8px}
.value-item{padding:22px 0;border-bottom:1px solid var(--hair)}
.value-item:first-child{padding-top:0}
.value-item:last-child{border-bottom:none;padding-bottom:0}
.value-item-title{font-family:var(--sr);font-size:16px;color:var(--m);letter-spacing:.03em;margin-bottom:8px}
.value-item-body{font-size:14px;line-height:1.9;color:var(--inks);margin:0}

/* ── Section CTA repeater ── */
.section-cta-row{margin-top:52px;text-align:center}
.section-cta-link{
  display:inline-block;font-family:var(--dp);font-size:12px;letter-spacing:.22em;
  color:var(--m);border-bottom:1px solid var(--a);padding-bottom:4px;transition:color .2s;
}
.section-cta-link:hover{color:var(--a)}

/* ── Plans (pricing cards) ── */
.pt-plans-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;max-width:860px;margin:0 auto}
.svc-card{
  background:var(--bg);border:1px solid var(--hair);
  padding:28px 28px 26px;
  display:flex;flex-direction:column;justify-content:space-between;gap:20px;
  transition:border-color .25s,box-shadow .25s,transform .25s;
}
.svc-card:hover{border-color:var(--a);box-shadow:0 8px 32px rgba(26,39,68,.10);transform:translateY(-3px)}
.svc-card-featured{border-color:var(--a);box-shadow:0 8px 32px rgba(184,115,51,.14)}
.svc-cat{font-family:var(--dp);font-size:11px;letter-spacing:.28em;color:var(--a);margin-bottom:14px}
.svc-title{font-family:var(--sr);font-size:22px;color:var(--m);letter-spacing:.05em;margin-bottom:10px}
.svc-body{font-size:14px;line-height:2;color:var(--inks)}
.svc-footer{
  padding-top:18px;border-top:1px solid var(--hair);
  display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:8px;
}
.svc-price{font-family:var(--mn);font-size:15px;color:var(--m);letter-spacing:.06em}
.svc-unit{font-family:var(--mn);font-size:10px;color:var(--inkm);letter-spacing:.1em}
.svc-note{margin-top:24px;font-size:13px;line-height:1.9;color:var(--inks)}
.svc-note a{color:var(--m);border-bottom:1px solid var(--a);padding-bottom:1px}
.svc-note a:hover{color:var(--a)}

/* ── Trial flow ── */
.trial-block{
  margin-top:40px;
  background:rgba(74,59,50,0.03);
  border:1px solid var(--hair);
  padding:32px 36px;
  max-width:900px;
  margin-left:auto;margin-right:auto;
  text-align:left;
}
.trial-block-title{font-family:var(--sr);font-size:16px;color:var(--m);margin:0 0 12px;letter-spacing:.05em}
.trial-block-body{font-size:13.5px;line-height:1.9;color:var(--ink);margin:0 0 24px}
.trial-block .loop-flow{justify-content:flex-start;gap:16px}

.svc-limitations {
  margin-top: 40px;
  background: rgba(74, 59, 50, 0.03);
  border: 1px solid var(--hair);
  padding: 32px 36px;
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
  text-align: left;
}
.svc-limitations-title {
  font-family: var(--sr);
  font-size: 16px;
  color: var(--m);
  margin: 0 0 12px;
  letter-spacing: 0.05em;
}
.svc-limitations-body {
  font-size: 13px;
  line-height: 1.8;
  color: var(--inks);
  margin-bottom: 16px;
}
.svc-limitations-list {
  font-size: 13px;
  line-height: 1.9;
  color: var(--ink);
  margin: 0 0 20px;
  padding-left: 20px;
}
.svc-limitations-list li {
  margin-bottom: 8px;
}
.svc-limitations-list li:last-child {
  margin-bottom: 0;
}
.svc-limitations-footer {
  font-size: 13.5px;
  line-height: 1.9;
  color: var(--ink);
  border-top: 1px dashed var(--hair);
  padding-top: 16px;
  margin: 0;
}

/* ── Monthly cycle (loop) ── */
.loop-intro{max-width:760px;margin-bottom:48px}
.loop-flow{display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap}
.loop-flow-arrow{font-family:var(--sr);font-size:20px;color:var(--a);flex-shrink:0}

.loop-step-chip{background:var(--bg);border:1px solid var(--hair);padding:18px 22px;text-align:center;min-width:150px}
.loop-step-chip-t{font-family:var(--sr);font-size:15px;color:var(--m);letter-spacing:.04em;margin-bottom:6px}
.loop-step-chip-d{font-family:var(--mn);font-size:11px;letter-spacing:.04em;line-height:1.7;color:var(--inks)}

.loop-circle-wrap{position:relative;width:280px;max-width:100%;aspect-ratio:1/1;flex-shrink:0}
.loop-circle-dash{position:absolute;inset:0;border:2px dashed var(--a);border-radius:50%}
.loop-node{position:absolute;display:flex;flex-direction:column;align-items:center;gap:8px;transform:translate(-50%,-50%)}
.loop-node-top{left:50%;top:0%}
.loop-node-br{left:93.3%;top:75%}
.loop-node-bl{left:6.7%;top:75%}
.loop-node-badge{
  width:52px;height:52px;border-radius:50%;
  background:var(--bg);border:2px solid var(--m);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--dp);font-size:16px;color:var(--m);
}
.loop-node-label{font-family:var(--sr);font-size:13px;color:var(--ink);letter-spacing:.05em;white-space:nowrap}
.loop-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:2px}
.loop-center-icon{font-size:32px;color:var(--a);display:inline-block;animation:loopSpin 8s linear infinite}
.loop-center-text{font-family:var(--mn);font-size:10px;letter-spacing:.15em;color:var(--inkm);text-align:center;line-height:1.6}
@keyframes loopSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@media (prefers-reduced-motion:reduce){.loop-center-icon{animation:none}}

/* ── Proof (dogfooding results) ── */
.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.work-card{overflow:hidden;background:var(--bg);border:1px solid var(--hair);display:flex;flex-direction:column}
.work-ph{height:170px;overflow:hidden}
.work-ph .ph{border:none;height:100%}
.work-info{padding:22px 24px;border-top:1px solid var(--hair)}
.work-meta{display:flex;justify-content:space-between;font-family:var(--mn);font-size:10px;letter-spacing:.2em;color:var(--a);margin-bottom:8px}
.work-badge{display:inline-block;font-family:var(--mn);font-size:9px;letter-spacing:.22em;color:var(--bg);background:var(--a);padding:2px 8px;margin-bottom:7px}
.work-title{font-family:var(--sr);font-size:19px;color:var(--m);letter-spacing:.05em;margin-bottom:6px}
.work-desc{font-size:13px;line-height:1.9;color:var(--inks)}

/* Placeholder */
.ph{
  width:100%;height:100%;
  background:repeating-linear-gradient(135deg,rgba(74,59,50,.06) 0 10px,rgba(74,59,50,.02) 10px 20px);
  border:1px solid var(--hair);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mn);font-size:11px;letter-spacing:.08em;
  color:rgba(74,59,50,.55);text-transform:uppercase;
  text-align:center;padding:16px;
}
.ph-auto{aspect-ratio:16/9}
.ph:has(.work-img){padding:0}
.work-img{width:100%;height:100%;object-fit:cover;display:block}

/* ── Contact ── */
.contact-section{padding-bottom:100px}
.contact-panel{
  background:var(--m);color:var(--bg);padding:80px 70px;
  display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center;
}
.contact-label{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{
  font-family:var(--sr);font-weight:500;font-size:clamp(30px,3vw,44px);margin:0;
  line-height:1.4;letter-spacing:.04em;color:var(--bg);
}
.contact-body{
  font-size:15px;line-height:2.1;color:rgba(242,242,240,.8);
  letter-spacing:.04em;margin-bottom:36px;max-width:480px;
}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap}
.contact-btn-primary{
  padding:16px 26px;font-family:var(--dp);font-size:13px;letter-spacing:.22em;
  background:var(--a);color:var(--m);
  transition:background .25s;
}
.contact-btn-primary:hover{background:#c98a45}

/* ── Footer ── */
.wfooter{
  padding:20px 60px 40px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--hair);
}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}

/* ── Responsive ── */
@media (max-width: 900px){
  .pt-hero{padding:44px 24px 40px}
  .ws{padding:56px 24px 64px}

  .pt-plans-grid{grid-template-columns:1fr}
  .scene-grid{grid-template-columns:1fr}
  .proof-grid{grid-template-columns:1fr}
  .svc-limitations {
    padding: 24px 20px;
  }
  .trial-block{padding:24px 20px}

  .loop-flow{flex-direction:column}
  .loop-flow-arrow{transform:rotate(90deg)}
  .loop-circle-wrap{width:240px}

  .contact-panel{grid-template-columns:1fr;padding:48px 28px;gap:32px}
  .wfooter{flex-direction:column;gap:16px;padding:24px 24px 32px;text-align:center}
}

@media (max-width: 600px){
  .sh-no{display:none}
  .loop-circle-wrap{width:210px}
  .loop-node-badge{width:44px;height:44px;font-size:14px}
  .loop-node-label{font-size:12px}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');
      io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  setTimeout(function(){
    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible')});
  },60);
  els.forEach(function(el){io.observe(el)});
})();
</script>

