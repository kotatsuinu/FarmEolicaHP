---
// Farm Eolica Works — 業務代行〈AI活用〉
// Self-contained page — independent from main HP design
import { SITE_CONFIG } from '../../config/site';
import WorksHeader from '../../components/works/WorksHeader.astro';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = '業務代行〈AI活用〉 | Farm Eolica Works';
const description = '業務代行〈AI活用〉は、経理・発信・資料づくりなど日々の業務を、AIを使ってまるごと代行する月額サービスです。人がレビューし、そのまま使える成果物にして毎月お届けします。月¥20,000〜。';

// TODO: 数値（浮く時間・Before→After）はすべて仮置き。実測データが揃い次第、差し替えること
const scenes = [
  { situation: '経理・帳簿に追われている方へ', task: '台帳・領収書整理、請求書作成', before: '月5時間', after: '5分' },
  { situation: '情報発信が続かない方へ', task: 'SNS投稿文・画像・予約投稿', before: '週3時間', after: '30分' },
  { situation: '文章・資料づくりが苦手な方へ', task: '提案書・メール・POP・チラシ文', before: '半日', after: '30分' },
  { situation: '調べ物・リサーチに時間を取られる方へ', task: '競合・市場・制度調査＋要約', before: '数時間', after: '即日' },
  { situation: '毎月同じ作業を繰り返している方へ', task: '定型レポート・データ整理', before: '毎月の繰り返し作業', after: '仕組み化でゼロに' },
  { situation: 'AIを使ってみたいが手が回らない方へ', task: '導入・仕組み化を丸ごと代行', before: '導入・仕組み化の負担', after: 'まるごと肩代わり' },
];

const valueAngles = [
  { title: 'AIのお守りから解放', body: 'ChatGPTに投げてみたら出力が微妙で、5往復修正して、体裁を整えて——気づけば2時間。「投げるだけで完成品が返ってくる」状態に置き換えます。' },
  { title: 'チャットの「次」を代行', body: '叩き台どまりで終わっていた作業を、テンプレ化・自動整形・毎月自動生成の「仕組み」にして返します。単発の相談を、繰り返し使える資産に変えます。' },
  { title: 'コピペ地獄の解消', body: 'AIの出力を毎回手でコピー＆ペーストし、貼り直す——その手間を、ファイルや投稿先に直結したパイプラインにして消します。' },
  { title: '自力ChatGPT vs 代行', body: '自力で使うAIは、それっぽい要約で止まりがちです。代行では、出典を確認済みの根拠と、判断に使える比較表つきでお返しします。' },
  { title: '品質の壁（80点→100点）', body: 'AIが一発で出す答えは、だいたい80点——誤りが混ざっていることもあります。人間のレビューで誤りを取り除き、セキュリティにも配慮した「そのまま出せる」100点に仕上げます。' },
];
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/partner/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/partner/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta name="twitter:site" content="@FarmEolica" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />

<!-- TODO: 数値は仮置き。実測で差し替え -->

<!-- ══════════ 1. HERO ══════════ -->
<section class="pt-hero">
  <div class="wc">
    <div class="ph-top reveal">
      <span class="ph-en">AI TASK AGENCY</span>
      <span class="ph-line"></span>
    </div>
    <h1 class="ph-title reveal">
      業務代行〈AI活用〉<br />
      毎月、あなたの業務をAIで代行します。
    </h1>
    <p class="ph-lead reveal">
      経理、発信、資料づくり、調べ物——AIを使えば速くできることは増えました。ただ、それを「そのまま使える形」に仕上げる最後の一手間は、後回しにされがちです。<br />
      その一手間を、毎月まるごとお引き受けします。
    </p>
    <div class="pt-hero-btns reveal">
      <a href="#plans" class="btn-filled">プランを見る →</a>
      <a href="/works/contact" class="btn-ghost">まずは相談してみる</a>
    </div>
  </div>
</section>


<!-- ══════════ 2. 利用シーン別メリット ══════════ -->
<section class="ws" id="who">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">FOR WHOM</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 05</span>
      </div>
      <h2 class="sh-jp">こんな業務、まるごと代わりにやります。</h2>
    </div>

    <div class="cs-block reveal">
      <p class="cs-body">
        経理も、発信も、資料づくりも——本来は「作って終わり」ではなく、続けていくものです。ただ、そのために人をひとり雇うほどの業務量ではない。
        多くの小規模事業者が抱えるそのギャップを、AIを使って埋めるのが業務代行〈AI活用〉です。
      </p>
    </div>

    <div class="scene-grid reveal">
      {scenes.map(s => (
        <div class="scene-card">
          <div class="scene-tag">{s.situation}</div>
          <div class="scene-task">{s.task}</div>
          <div class="scene-shift">
            <span class="scene-before">{s.before}</span>
            <span class="scene-arrow">→</span>
            <span class="scene-after">{s.after}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="cs-body scene-note reveal">
      ※ 時間はすべて目安です。実際の効果は業務内容やボリュームにより変動します。ご依頼内容はすべて人がレビューし、そのまま使える成果物にしてお返しします。
    </p>
  </div>
</section>


<!-- ══════════ 3. 価値提案（叩き台→成果物） ══════════ -->
<section class="ws ws-alt" id="value">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">THE LAST MILE</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 05</span>
      </div>
      <h2 class="sh-jp">「叩き台」を、「成果物」に変える。</h2>
    </div>

    <div class="cs-block reveal">
      <p class="cs-body">
        AIで叩き台を出すだけなら、今は誰でもできます。けれど、それを「そのまま実務で使える成果物」に仕上げるための最後の一手間が、実は一番大変で、後回しにされがちです。
        業務代行〈AI活用〉は、その最後の一手間を丸ごと肩代わりします。
      </p>
    </div>

    <div class="value-block reveal">
      {valueAngles.map(v => (
        <div class="value-item">
          <div class="value-item-title">{v.title}</div>
          <p class="value-item-body">{v.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 4. 提供内容・プラン ══════════ -->
<section class="ws ws-alt" id="plans">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PLANS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 05</span>
      </div>
      <h2 class="sh-jp">プランと料金。</h2>
    </div>

    <div class="pt-plans-grid reveal">
      <div class="svc-card">
        <div>
          <div class="svc-cat">AGENCY PLAN</div>
          <div class="svc-title">代行プラン</div>
          <p class="svc-body">
            月20タスクまで、順次対応でたっぷりお任せいただけます。1タスクは、AI実働30分級・成果物1点が目安です（「できること」ページの「1タスクの目安」と同じ基準）。経理・発信・資料づくりなど、日々の「やることリスト」をまるごとお預けください。
            ちょっとしたAI活用のご相談も、LINE/Slackで気軽にどうぞ。
          </p>
        </div>
        <div class="svc-footer">
          <span class="svc-price">¥20,000</span>
          <span class="svc-unit">／月（最低契約3ヶ月）</span>
        </div>
      </div>

      <div class="svc-card svc-card-featured">
        <div>
          <div class="svc-cat">AGENCY + AI COACHING ・ 先着5名は初月特別価格</div>
          <div class="svc-title">代行＋AI活用コーチングプラン</div>
          <p class="svc-body">
            代行に加えて、AIを使いこなすためのコーチングをセットにしたプランです。実際に使っているプロンプトや型の共有、月次のレクチャー、使いこなし相談枠（オンライン）をご用意し、相談は回数無制限。
            「代行してもらいながら、自分でも使えるようになる」伴走を目指します。先着5名は初月¥20,000、2〜3ヶ月目以降は通常価格に移行します。
          </p>
        </div>
        <div class="svc-footer">
          <span class="svc-price">¥40,000</span>
          <span class="svc-unit">／月（先着5名は初月¥20,000・最低契約3ヶ月）</span>
        </div>
      </div>
    </div>

    <p class="svc-note">「タスク」で具体的に何をお願いできるかは、<a href="/works/capabilities">相談できることの一覧</a>でご確認いただけます。</p>
    <p class="svc-note">常駐対応・大型案件・自動化の仕組みづくりなど、さらに踏み込んだご相談は<a href="/works/contact">個別にご相談</a>ください。</p>

    <div class="trial-block reveal">
      <h3 class="trial-block-title">お試しについて</h3>
      <p class="trial-block-body">
        「1ヶ月無料」ではなく、<strong>初月は後払い・合わなければ料金はいただきません。</strong><br />
        実際に1ヶ月分のタスクをお試しいただいたうえで、判定面談で続けるかどうかご判断ください。続けていただく場合のみ初月分をご請求し、見送られる場合は初月分の請求はいたしません。
      </p>
      <div class="loop-flow">
        <div class="loop-step-chip">
          <div class="loop-step-chip-t">初回相談</div>
          <div class="loop-step-chip-d">無料</div>
        </div>
        <span class="loop-flow-arrow">→</span>
        <div class="loop-step-chip">
          <div class="loop-step-chip-t">1ヶ月お試し</div>
          <div class="loop-step-chip-d">実タスクを依頼<br />（後払い）</div>
        </div>
        <span class="loop-flow-arrow">→</span>
        <div class="loop-step-chip">
          <div class="loop-step-chip-t">判定面談</div>
          <div class="loop-step-chip-d">続けるかどうかを<br />ここで判断</div>
        </div>
        <span class="loop-flow-arrow">→</span>
        <div class="loop-step-chip">
          <div class="loop-step-chip-t">ご契約 or 見送り</div>
          <div class="loop-step-chip-d">続ける場合のみ<br />初月分をご請求</div>
        </div>
      </div>
    </div>

    <div class="svc-limitations reveal">
      <h3 class="svc-limitations-title">お引き受けできない業務と、進め方のポリシー</h3>
      <p class="svc-limitations-body">
        安全管理および法的・リソース的なリスクヘッジのため、恐れ入りますが以下の業務はお引き受けできません。
      </p>
      <ul class="svc-limitations-list">
        <li><strong>個人情報を扱うシステム構築・業務の直接代行</strong>（個人情報漏洩・管理リスク防止のため）</li>
        <li><strong>大規模なシステムの構築</strong>（月額の対応枠を超えるもの。別途お見積もりにて個別にご相談となります）</li>
        <li><strong>常時待機・即時リアルタイム対応</strong>（農繁期や農作業があるため、定時での即レス等は対応いたしかねます。基本はSlack等の非同期連絡、および週1回の定例ベースで進行します）</li>
        <li><strong>法規・税務等の専門的な最終確認</strong>（効率化の過程で生じる法的な確認等はアドバイスに留まり、最終判断はお客様自身でお願いいたします）</li>
        <li><strong>パスワードやクレジットカード情報の直接預かり</strong>（セキュリティ事故防止のため）</li>
        <li><strong>その他、個人の能力外と判断するもの</strong>、または生成AIの活用が適当でない仕事</li>
      </ul>
      <p class="svc-limitations-footer">
        私は、画一的に指示を処理する単なる「外注」ではなく、<strong>一緒に悩み、相談しながら業務の効率化を図っていくパートナー</strong>として伴走したいと考えております。コミュニケーションを重ねながら、柔軟にやり方を改善できる関係を大切にいたします。必要がなくなったと感じた際には、契約の縮小や終了もこちらからご提案します。
      </p>
    </div>

    <div class="section-cta-row reveal">
      <a href="/works/contact" class="section-cta-link">プランについて相談してみる →</a>
    </div>
  </div>
</section>


<!-- ══════════ 5. 流れ（月額運用サイクル） ══════════ -->
<section class="ws" id="cycle">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">MONTHLY CYCLE</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 04 / 05</span>
      </div>
      <h2 class="sh-jp">毎月、同じサイクルをまわします。</h2>
    </div>

    <p class="cs-body loop-intro reveal">
      HP・LP制作が「ヒアリングから公開まで」一度きりの流れで完成へ向かうのに対し、業務代行〈AI活用〉は同じサイクルを毎月くり返します。
    </p>

    <div class="loop-flow reveal">
      <div class="loop-step-chip">
        <div class="loop-step-chip-t">申込</div>
        <div class="loop-step-chip-d">最低契約3ヶ月〜</div>
      </div>
      <span class="loop-flow-arrow">→</span>
      <div class="loop-step-chip">
        <div class="loop-step-chip-t">初回ヒアリング</div>
        <div class="loop-step-chip-d">優先課題の整理</div>
      </div>
      <span class="loop-flow-arrow">→</span>

      <div class="loop-circle-wrap">
        <div class="loop-circle-dash"></div>
        <div class="loop-node loop-node-top">
          <span class="loop-node-badge">1</span>
          <span class="loop-node-label">相談</span>
        </div>
        <div class="loop-node loop-node-br">
          <span class="loop-node-badge">2</span>
          <span class="loop-node-label">実装</span>
        </div>
        <div class="loop-node loop-node-bl">
          <span class="loop-node-badge">3</span>
          <span class="loop-node-label">納品</span>
        </div>
        <div class="loop-center">
          <span class="loop-center-icon">↻</span>
          <span class="loop-center-text">毎月<br />反復</span>
        </div>
      </div>

      <span class="loop-flow-arrow">→</span>
      <div class="loop-step-chip">
        <div class="loop-step-chip-t">継続</div>
        <div class="loop-step-chip-d">必要な間、次の月へ</div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 6. 実績（ドッグフーディング） ══════════ -->
<section class="ws ws-alt" id="proof">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PROOF</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 05 / 05</span>
      </div>
      <h2 class="sh-jp">机上の提案ではありません。</h2>
    </div>

    <div class="cs-block reveal">
      <p class="cs-body">
        自分の農場を、実際にこの手で毎月回している——それが業務代行〈AI活用〉の一番の証拠です。
        農場の事務をAIで組み替えてきた実装の一部を紹介します。
      </p>
      <p class="cs-body">
        実装の結果だけでなく、どこをAIに任せ、どこを人の目でチェックしたかという「過程」も、成果物と一緒にお渡しします。自力でAIツールを使うのと何が違うかを、実際にご確認いただけます。
      </p>
    </div>

    <div class="proof-grid reveal">
      <div class="work-card">
        <div class="work-ph">
          <div class="ph ph-auto">
            <img src="/images/works/cultivation-app-card.jpg" alt="栽培管理アプリ" class="work-img" />
          </div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">AGRI & FARMING</span>
          </div>
          <span class="work-badge">自社実績</span>
          <div class="work-title">栽培管理アプリ</div>
          <div class="work-desc">作付けから収穫・出荷まで全データをスマホで一元管理するWebアプリ。今も自農場で稼働中。</div>
        </div>
      </div>

      <div class="work-card">
        <div class="work-ph">
          <div class="ph ph-auto">
            <img src="/images/works/automation-card.jpg" alt="自動化システム" class="work-img" />
          </div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">AUTOMATION</span>
          </div>
          <span class="work-badge">自社実績</span>
          <div class="work-title">業務・情報収集の自動化</div>
          <div class="work-desc">Slack上の自然言語で農業・業務処理を自動化するAIエージェント基盤を中心に、問い合わせ整理や記録の自動化を運用中。</div>
        </div>
      </div>

      <div class="work-card">
        <div class="work-ph">
          <div class="ph ph-auto">
            <img src="/images/works/finance-card.jpg" alt="財務・会計の自動化" class="work-img" />
          </div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">FINANCE & OPS</span>
          </div>
          <span class="work-badge">自社実績</span>
          <div class="work-title">財務・会計の自動化</div>
          <div class="work-desc">クラウド会計の全仕訳データを毎日自動でBigQueryへ転送し、収支分析・税務データ確認を即座に行える基盤を構築。</div>
        </div>
      </div>
    </div>

    <div class="section-cta-row reveal">
      <a href="/works/capabilities" class="section-cta-link">相談できることを全部見る →</a>
    </div>
  </div>
</section>


<!-- ══════════ 7. CTA ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          業務代行の相談を、<br />
          してみませんか。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          押し売りはしません。まずは今、手が回っていない業務をひとつ、聞かせてください。<br />
          HP・LP制作からの移行の場合、月額初月から3ヶ月間¥3,000 OFF（計¥9,000）でご案内します。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">業務代行の相談をする →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
