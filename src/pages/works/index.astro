---
// Farm Eolica Works — Landing Page
// Design: Layout 3 "Tategaki Bento" (Navy × Copper)
// Self-contained page — independent brand identity from main HP
import { SITE_CONFIG } from '../../config/site';
import WorksHeader from '../../components/works/WorksHeader.astro';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = 'Farm Eolica Works — あなたの仕事を、あなたの言葉で。';
const description = '福島・浪江の農家兼元編集者が、あなたのストーリーをWebページにします。1ページHP制作 先着5名¥40,000〜。2026年7月10日、福島中央テレビで放送予定の制作実績あり。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta name="twitter:site" content="@FarmEolica" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ 0. HEADER ══════════ -->
<WorksHeader isHome />


<!-- ══════════ 1. HERO — Bento Grid ══════════ -->
<section class="hero-section">
  <div class="bento reveal reveal-hero reveal-d1">

    <!-- A: Tategaki title — cols 1-2, rows 1-2 -->
    <div class="bc bc-title">
      <p class="tategaki">あなたの仕事を、あなたの言葉で。</p>
      <span class="bc-title-sub">FARM EOLICA / WORKS</span>
      <span class="bc-title-loc">福島県浪江町 / SINCE 2021</span>
    </div>

    <!-- B: Hero image — cols 3-4, row 1 -->
    <div class="bc bc-img reveal reveal-hero reveal-d2">
      <div class="hero-kb">
        <!-- 実写動画が用意できたらここに <video> を差し込み、再生後に静止画へフォールバック -->
        <div class="hero-kb-slide hero-kb-slide-1" style="background-image:url('/images/works/hero-field.jpg')"></div>
        <div class="hero-kb-slide hero-kb-slide-2" style="background-image:url('/images/works/hero-bloom.jpg')"></div>
        <div class="hero-kb-slide hero-kb-slide-3" style="background-image:url('/images/works/hero-atelier.jpg')"></div>
        <div class="hero-kb-overlay"></div>
      </div>
    </div>

    <!-- C: Copy + CTA — cols 3-4, row 2 -->
    <div class="bc bc-copy reveal reveal-hero reveal-d2">
      <p class="copy-hook">福島・浪江の農家兼元編集者が、あなたのストーリーをWebページにします。</p>
      <p class="copy-main">
        取材からデザイン、コーディング、公開まで。「本当に伝えたいこと」を、聞き手・書き手・作り手を兼ねてひとりで形にします。
      </p>
      <p class="copy-sub">— 1ページHP制作 先着5名 特別価格 ¥50,000 受付中</p>
      <div class="hero-btns">
        <a href="/works/contact" class="btn-filled">まずは相談してみる →</a>
        <a href="#works" class="btn-ghost">実績を見る</a>
      </div>
    </div>

    <!-- D: 4 stat cells — row 3 (customer-facing value props) -->
    {[
      { v: '先着5', l: 'launch price', jp: '1ページHP制作 特別価格 ¥50,000（通常¥100,000）' },
      { v: '無料', l: 'first consultation', jp: '初回60分ヒアリング・押し売りなし' },
      { v: '全国', l: 'online only', jp: 'オンライン完結・全国対応' },
      { v: '納品', l: 'source included', jp: 'ソース一式をGitHubで納品・ロックインなし' },
    ].map((s, i) => (
      <div class="bc bc-stat reveal reveal-hero reveal-d3">
        <div class="stat-no">/{String(i + 1).padStart(2, '0')}</div>
        <div>
          <div class="stat-num">{s.v}</div>
          <div class="stat-jp">{s.jp}</div>
          <div class="stat-en">{s.l}</div>
        </div>
      </div>
    ))}

  </div>
</section>


<!-- ══════════ 1.5 TV BANNER (7/10最優先) ══════════ -->
<section class="tv-banner-section">
  <div class="wc">
    <a href="/works/case/namie-rice-burger/" class="tv-banner reveal">
      <div class="tv-banner-left">
        <span class="tv-banner-label">TV放送予定 — 2026.7.10 福島中央テレビ</span>
        <p class="tv-banner-headline">
          浪江創成中学校の生徒が生んだ商品 —
          <span class="tv-banner-accent">「なみえライスバーガー」の公式LP</span>を制作しました。
        </p>
      </div>
      <div class="tv-banner-right">
        <span class="tv-banner-cta">なみえライスバーガーの制作実績を見る <span class="tv-banner-arrow">→</span></span>
      </div>
    </a>
  </div>
</section>


<!-- ══════════ 2. VALUE（提供価値） ══════════ -->
<section class="ws ws-alt" id="about">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">VALUE</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 06</span>
      </div>
      <h2 class="sh-jp">農家兼元編集者が、両方の言葉でつくる。</h2>
    </div>

    <div class="about-grid">
      <div class="reveal">
        <div class="ph ph-45">portrait / greenhouse</div>
        <p class="ph-cap">FIG.01 — 浪江町の圃場にて</p>
      </div>

      <div class="about-story">
        {[
          {
            n: '01', en: 'FARMER × EDITOR', tag: '農家兼元編集者',
            jp: '聞く力と、書く力を両方持っています',
            b: '震災後の浪江町で花き農家を営みながら、前職は出版社の編集者。取材で聞いた言葉を、そのまま届く文章とデザインに変える視点があります。',
          },
          {
            n: '02', en: 'BUILDER', tag: 'AI実装',
            jp: '実装力の裏付けがあります',
            b: '経理・受注・販促・記録。自農場の事務をAIで組み替え、現在36のシステムを稼働中。その実装力は、下の制作実績でも証明しています。',
          },
          {
            n: '03', en: 'CONTINUITY', tag: '死んでも困らない納品',
            jp: '納品するのは、あなたの資産です',
            b: 'Astro静的サイトで構築し、ソースコード一式をGitHubでまるごとお渡し。あなたのCloudflare無料アカウントで公開するので、もし私に何かあっても、サイトは動き続け、ソースはあなたの手元に残ります。特定の業者に縛られません。',
          },
        ].map(r => (
          <div class="story-item reveal">
            <div class="story-badge">
              {r.en}<span class="story-badge-jp"> · {r.tag}</span>
            </div>
            <h3 class="story-title">{r.jp}</h3>
            <p class="story-body">{r.b}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="section-cta-row reveal">
      <a href="/works/contact" class="section-cta-link">まずは相談してみる →</a>
    </div>
  </div>
</section>


<!-- ══════════ 2.5 PRODUCTS（サービス層） ══════════ -->
<section class="ws" id="products">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PRODUCTS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 06</span>
      </div>
      <h2 class="sh-jp">ふたつの商品。</h2>
    </div>

    <div class="products-grid">
      <a href="/works/hp-lp/" class="product-card product-card-main reveal">
        <div>
          <div class="product-cat">WEBSITE — 単発制作</div>
          <div class="product-title">1ページHP・LP制作</div>
          <p class="product-body">単発で、あなたの物語がちゃんと伝わるサイトを作ります。取材からデザイン、コーディング、公開まで、ひとりで一貫対応。</p>
          <p class="product-price">スタンダード（microCMS付）¥50,000〜／シンプル ¥40,000〜<span class="product-price-note">※先着5名・通常価格の半額。料金の詳細は次のページで。</span></p>
        </div>
        <span class="product-link">くわしく見る →</span>
      </a>

      <a href="/works/partner/" class="product-card reveal">
        <div>
          <div class="product-cat">AI PARTNER — 継続伴走・第2幕</div>
          <div class="product-title">月額AIパートナー</div>
          <p class="product-body">公開して終わりにせず、毎月あなたの隣で手を動かし、業務の自動化を一緒に回し続けます。HP制作にとどまらず、アプリ・システム開発から日々の業務の困りごとまで、まとめて相談できる継続パートナーです。</p>
          <p class="product-price">¥20,000／月〜（3ヶ月〜）<span class="product-price-note">くわしい内容は次のページで。</span></p>
        </div>
        <span class="product-link">くわしく見る →</span>
      </a>
    </div>
  </div>
</section>


<!-- ══════════ 3. WORKS (実績) ══════════ -->
<section class="ws" id="works">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">WORKS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 06</span>
      </div>
      <h2 class="sh-jp">これまでの仕事。</h2>
    </div>

    <div class="works-grid">

      <!-- 実績1: なみえライスバーガー（主役・実案件・TV放送） -->
      <a href="/works/case/namie-rice-burger/" class="work-card work-card-big reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / namie rice burger</div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">CASE STUDY</span>
            <span class="work-year">2026</span>
          </div>
          <span class="work-badge">TV放送 2026.7.10</span>
          <div class="work-title">なみえライスバーガー</div>
          <div class="work-desc">浪江創成中学校「ふるさと創造学」× 道の駅なみえ。生徒の言葉でつくったLP。開発ストーリーは浪江町公式チャンネルで公開中、福島中央テレビでも放送される制作実績。</div>
          <span class="work-more">詳しく見る →</span>
        </div>
      </a>

      <!-- 実績2: 三宅奈緒（制作ショーケース・ダミー案件） -->
      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / showcase</div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">SHOWCASE</span>
            <span class="work-year">2026</span>
          </div>
          <span class="work-badge">制作サンプル・架空</span>
          <div class="work-title">三宅奈緒 / Portfolio</div>
          <div class="work-desc">Astro + microCMS + Cloudflare Pages + Workers/Resend。全7セクション、フル実装の制作サンプルです（実在の依頼ではなく、制作力を示すための架空案件）。</div>
        </div>
      </div>

      <!-- 実績3: 地域の酒蔵（イメージ制作例・完全ダミー） -->
      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / concept mock</div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">CONCEPT</span>
            <span class="work-year">2026</span>
          </div>
          <span class="work-badge">イメージ制作例</span>
          <div class="work-title">地域の酒蔵 / ストーリーLP</div>
          <div class="work-desc">日英バイリンガル構成のコンセプトモック。地域の酒蔵をイメージした、ストーリー訴求の見せ方サンプルです。</div>
        </div>
      </div>

      <!-- 自社実績（補助・農家がWeb制作できる証拠） -->
      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / farm eolica hp</div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">WEBSITE</span>
            <span class="work-year">2025</span>
          </div>
          <span class="work-badge">自社実績</span>
          <div class="work-title">Farm Eolica 公式HP</div>
          <div class="work-desc">AstroでゼロからHP構築。商品・お問い合わせ・SEO対応まで一貫稼働中。</div>
        </div>
      </div>

      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / cultivation app</div>
        </div>
        <div class="work-info">
          <div class="work-meta">
            <span class="work-tag">AI SYSTEM</span>
            <span class="work-year">2024–</span>
          </div>
          <span class="work-badge">自社実績</span>
          <div class="work-title">栽培管理アプリ</div>
          <div class="work-desc">作付け記録のデジタル化。全工程をスマホで管理する独自Webアプリ、今も稼働中。</div>
        </div>
      </div>

    </div>

    <div class="section-cta-row reveal">
      <a href="/works/contact" class="section-cta-link">まずは相談してみる →</a>
    </div>
  </div>
</section>


<!-- ══════════ 4.5 できること BANNER ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="ai-banner reveal">
      <div>
        <div class="ai-banner-label">SINCE 2021 — NAMIE, FUKUSHIMA</div>
        <p class="ai-banner-headline">
          <span class="ai-banner-accent">36のシステム</span>と自動化を、<br />
          農場で実際に動かしています。
        </p>
        <p class="ai-banner-sub">その仕組みづくりの力を、月額AIパートナーとしてあなたの事業にも。</p>
      </div>
      <div class="ai-banner-right">
        <a href="/works/capabilities" class="ai-banner-cta">
          実際にできることを見る <span class="ai-banner-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 5. PROCESS ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PROCESS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 04 / 06</span>
      </div>
      <h2 class="sh-jp">ご依頼から納品まで。</h2>
    </div>

    <div class="process-grid reveal">
      <div class="process-hline"></div>
      {[
        { n: '01', t: 'ヒアリング', s: '60–90 min', d: 'オンラインで現状と背景を伺います。初回は資料も準備も不要です。' },
        { n: '02', t: '提案・お見積もり', s: '1 week', d: '方向性のラフ案と概算を、A4一枚にまとめてお送りします。' },
        { n: '03', t: '制作・調整', s: '2–4 weeks', d: 'AIでドラフト生成 → 人間がレビュー・調整。最低週1回、進行をご報告しながら固めます。' },
        { n: '04', t: '納品・運用', s: '1 day +', d: 'ソース一式とCloudflareへの公開作業、引き継ぎ資料をお渡しします。' },
      ].map(p => (
        <div class="process-item">
          <div class="process-badge">{p.n}</div>
          <div class="process-title">{p.t}</div>
          <div class="process-span">{p.s}</div>
          <p class="process-body">{p.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 5.5 はじめての方へ BANNER ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="ai-banner reveal">
      <div>
        <div class="ai-banner-label">FIRST TIME?</div>
        <p class="ai-banner-headline">
          Web制作もAI導入も、<span class="ai-banner-accent">初めてで大丈夫です。</span><br />
          よくある不安に、ひとつずつお答えします。
        </p>
      </div>
      <div class="ai-banner-right">
        <a href="/works/first-time" class="ai-banner-cta">
          はじめての方へ を読む <span class="ai-banner-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 6. FAQ ══════════ -->
<section class="ws" id="faq">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">FAQ</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 05 / 06</span>
      </div>
      <h2 class="sh-jp">よくいただく質問。</h2>
    </div>

    <div class="faq-grid">
      {[
        {
          q: '農家業との兼業で、対応は遅くなりませんか？',
          a: '繁忙期（5月〜7月、11月）は新規受付を絞っています。進行中の案件は週1の定例で品質を担保しており、納期はお見積もり時に明示します。',
          open: true,
        },
        {
          q: '対応エリアの制限はありますか？',
          a: '全国対応です。打ち合わせはオンラインが基本で、首都圏・東北圏は月1回程度の訪問にも応じます。',
          open: false,
        },
        {
          q: 'WordPressじゃなくて大丈夫ですか？',
          a: 'あえてAstro（静的サイト）で作っています。サーバー契約もプラグインの脆弱性リスクもなく、表示も高速。ソース一式をGitHubでお渡しするので、私に何かあっても他の制作者に引き継げます。ご事情に応じて、別の形式での納品にも柔軟に対応しますのでご相談ください。',
          open: true,
        },
        {
          q: '月額AIパートナーは何をやってくれるのですか？',
          a: '制作後の第2幕として、ご自身の業務を1〜2つ選び、AI/自動化に移し替える伴走です。まず現状の業務フローを整理し、自農場で実装済みの仕組みを現場に合わせて展開します。',
          open: false,
        },
        {
          q: '見積もりは無料ですか？',
          a: '初回ヒアリングと概算お見積もりまでは無料です。本見積もり以降に作業が発生する場合は事前にお知らせします。',
          open: false,
          wide: true,
        },
      ].map((f, i) => (
        <details class={`faq-card${f.wide ? ' faq-wide' : ''} reveal`} open={f.open}>
          <summary class="faq-header">
            <div class="faq-q-wrap">
              <span class="faq-no">Q.{String(i + 1).padStart(2, '0')}</span>
              <span class="faq-q">{f.q}</span>
            </div>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-a">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 7. CONTACT ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT / 06 / 06</div>
        <h2 class="contact-title">
          まずは、<br />
          あなたの話を、<br />
          聞かせてください。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          発注を急がせる営業はしません。<br />
          初回は60分、現状と背景を伺うところから。<br />
          フォームのほか、Farm Eolica 公式LINEでも気軽にどうぞ。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">まずは相談してみる →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 8. FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/" class="wfooter-back">← BACK TO FARM&nbsp;EOLICA</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
