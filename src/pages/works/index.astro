    if(!el.classList.contains('reveal-hero'))io.observe(el);
  });
  // Fallback
  setTimeout(function(){
    document.querySelectorAll('.reveal:not(.visible)').forEach(function(el){el.classList.add('visible')});
  },1500);
})();
</script>

</body>
</html>
