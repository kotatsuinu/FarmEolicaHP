---
// Farm Eolica Works — Landing Page
// Design: Layout 3 "Tategaki Bento" (Navy × Copper)
// Self-contained page — independent brand identity from main HP
import { SITE_CONFIG } from '../../config/site';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = 'Farm Eolica Works — AIと制作で、農家がおすそ分けする';
const description = '福島県浪江町の花き農家が、農場で組んできたAI・デジタル技術を士業・工務店向けに提供します。HP制作・チラシ・ロゴ・月額AIパートナー。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@FarmEolica" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ 0. HEADER ══════════ -->
<header class="wh">
  <a href="/works/" class="wh-logo">
    <img src="/favicon.svg" class="wh-logo-icon" alt="" aria-hidden="true" />
    <span class="wh-logo-main">FARM&nbsp;EOLICA</span>
    <span class="wh-logo-sub">/ WORKS</span>
  </a>
  <nav class="wh-nav">
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="/works/capabilities">できること</a>
    <a href="#contact">Contact</a>
    <a href="/" class="wh-farm-link">農場HP ↗</a>
    <a href="/works/contact" class="wh-cta">相談する →</a>
  </nav>
</header>


<!-- ══════════ 1. HERO — Bento Grid ══════════ -->
<section class="hero-section">
  <div class="bento reveal reveal-hero reveal-d1">

    <!-- A: Tategaki title — cols 1-2, rows 1-2 -->
    <div class="bc bc-title">
      <p class="tategaki">農家が、自分のために、作ってきた。</p>
      <span class="bc-title-sub">FARM EOLICA / WORKS</span>
      <span class="bc-title-loc">福島県浪江町 / SINCE 2021</span>
    </div>

    <!-- B: Hero image — cols 3-4, row 1 -->
    <div class="bc bc-img reveal reveal-hero reveal-d2">
      <div class="ph ph-auto">hero / hands at work</div>
    </div>

    <!-- C: Copy + CTA — cols 3-4, row 2 -->
    <div class="bc bc-copy reveal reveal-hero reveal-d2">
      <p class="copy-main">
        花を育てる傍ら、自分の農場のためにAIと業務システムを組んできました。
        その手仕事を、小さな事業体で奮闘している方へ、おすそ分けします。
      </p>
      <p class="copy-sub">— 農繁期も変わらず動く仕組みを、自分で作ってきたからわかることがある。</p>
      <div class="hero-btns">
        <a href="/works/contact" class="btn-filled">制作の相談 →</a>
        <a href="/works/capabilities" class="btn-ghost">実績を見る</a>
      </div>
    </div>

    <!-- D: 4 stat cells — row 3 (customer-facing value props) -->
    {[
      { v: '無料', l: 'first consultation', jp: '初回60分ヒアリング' },
      { v: '全国', l: 'online only', jp: 'オンライン完結・全国対応' },
      { v: '2週〜', l: 'delivery time', jp: 'チラシ制作の最短納期' },
      { v: '先着5', l: 'launch price', jp: 'ローンチ特別価格枠' },
    ].map((s, i) => (
      <div class="bc bc-stat reveal reveal-hero reveal-d3">
        <div class="stat-no">/{String(i + 1).padStart(2, '0')}</div>
        <div>
          <div class="stat-num">{s.v}</div>
          <div class="stat-jp">{s.jp}</div>
          <div class="stat-en">{s.l}</div>
        </div>
      </div>
    ))}

  </div>
</section>


<!-- ══════════ 2. ABOUT ══════════ -->
<section class="ws ws-alt" id="about">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">ABOUT</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 06</span>
      </div>
      <h2 class="sh-jp">３つの軸を、ひとりで往復しています。</h2>
    </div>

    <div class="about-grid">
      <div class="reveal">
        <div class="ph ph-45">portrait / greenhouse</div>
        <p class="ph-cap">FIG.01 — 浪江町の圃場にて</p>
      </div>

      <div class="about-story">
        {[
          {
            n: '01', en: 'FARMER', tag: '農家',
            jp: '花き農家として',
            b: '震災後の浪江町でトルコギキョウとカラーを育てる。毎朝5時、温度と相場を見ながら段取りを組み直す。',
          },
          {
            n: '02', en: 'EDITOR', tag: '元編集者',
            jp: '元編集者として',
            b: '前職は出版社編集。組版、見出しの強度、"読み手にどう届くか"を職業病のように設計してしまう。',
          },
          {
            n: '03', en: 'BUILDER', tag: 'AI実装',
            jp: 'AI実装屋として',
            b: '経理・受注・販促・記録。自農場の事務をAIで組み替え、現在36のシステムを稼働中。',
          },
        ].map(r => (
          <div class="story-item reveal">
            <div class="story-badge">
              {r.en}<span class="story-badge-jp"> · {r.tag}</span>
            </div>
            <h3 class="story-title">{r.jp}</h3>
            <p class="story-body">{r.b}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 3. SERVICES ══════════ -->
<section class="ws" id="services">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">SERVICES</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 06</span>
      </div>
      <h2 class="sh-jp">提供しているもの。</h2>
    </div>

    <div class="svc-grid">
      <!-- Featured: 月額AIパートナー (tall, dark) -->
      <div class="svc-featured reveal">
        <div>
          <div class="svc-cat">AI PARTNER — FEATURED</div>
          <div class="svc-featured-title">月額AIパートナー</div>
          <p class="svc-featured-body">
            事務所内のAI導入・自動化を月単位で伴走。自農場で動かしてきた36の仕組みを、現場に合わせて移植します。
          </p>
        </div>
        <div class="svc-featured-footer">
          <div class="svc-featured-price">¥20,000<span class="svc-price-unit"> ／ 月〜</span></div>
          <a href="#contact" class="svc-featured-link">詳細 →</a>
        </div>
      </div>

      <!-- S/01 チラシ -->
      <div class="svc-card reveal" style="grid-column: 2; grid-row: 1;">
        <div>
          <div class="svc-cat">FLYER & PRINT</div>
          <div class="svc-title">チラシ制作</div>
          <p class="svc-body">セミナー集客・新規顧問獲得のための1枚もの。コピーライティング・デザイン・印刷用PDF納品込み。</p>
        </div>
        <div class="svc-footer">
          <span class="svc-price">¥15,000 〜</span>
          <span class="svc-unit">／ 1点</span>
        </div>
      </div>

      <!-- S/02 HP -->
      <div class="svc-card reveal" style="grid-column: 3; grid-row: 1;">
        <div>
          <div class="svc-cat">WEBSITE</div>
          <div class="svc-title">ホームページ制作</div>
          <p class="svc-body">"相談前に読まれるサイト"を前提に設計。5〜10ページ。</p>
        </div>
        <div class="svc-footer">
          <span class="svc-price">¥150,000 〜</span>
          <span class="svc-unit">／ 一式</span>
        </div>
      </div>

      <!-- S/03 ロゴ (spans 2 cols) -->
      <div class="svc-card reveal" style="grid-column: 2 / span 2; grid-row: 2;">
        <div>
          <div class="svc-cat">IDENTITY</div>
          <div class="svc-title">ロゴ・デザイン</div>
          <p class="svc-body">事務所名の由来から書き起こすロゴ。代替わりにも対応。</p>
        </div>
        <div class="svc-footer">
          <span class="svc-price">¥30,000 〜</span>
          <span class="svc-unit">／ 1案</span>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 4. AI CAPABILITIES BANNER ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="ai-banner reveal">
      <div>
        <div class="ai-banner-label">SINCE 2021 — NAMIE, FUKUSHIMA</div>
        <p class="ai-banner-headline">
          <span class="ai-banner-accent">36のシステム</span>と自動化を、<br />
          農場で実際に動かしています。
        </p>
      </div>
      <div class="ai-banner-right">
        <a href="/works/capabilities" class="ai-banner-cta">
          できることリストを見る <span class="ai-banner-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 5. WORKS (実績) ══════════ -->
<section class="ws ws-alt" id="works">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">WORKS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 06</span>
      </div>
      <h2 class="sh-jp">これまでの仕事。</h2>
    </div>

    <div class="works-grid">
      {[
        { tag: 'WEBSITE', year: '2025', t: 'Farm Eolica 公式HP', d: '花き農家の農場HPをAstroで全面構築。商品ページ・問い合わせ・SEO対応。', big: true },
        { tag: 'AI SYSTEM', year: '2024–', t: '栽培管理アプリ', d: '作付けから出荷まで全工程をスマホで管理するWebアプリ。' },
        { tag: 'AI SYSTEM', year: '2024–', t: 'AI自動投稿システム', d: 'Instagram投稿を全自動化。農繁期も途切れない発信基盤。' },
        { tag: 'WEBSITE', year: '2026', t: 'ポートフォリオ準備中', d: '士業・工務店向けの制作実績を順次公開予定。お声がけください。', big: true },
        { tag: 'LP', year: '2026', t: 'ローンチ特別価格', d: 'ポートフォリオ掲載同意者限定で特別価格でご提供中。' },
        { tag: 'MONTHLY', year: '2026', t: '月額パートナー募集中', d: '3ヶ月以上のAI伴走プランを先着5社限定で受付中。' },
      ].map((w, i) => (
        <div class={`work-card reveal ${w.big ? 'work-card-big' : ''}`}>
          <div class="work-ph">
            <div class="ph ph-auto">work / {String(i + 1).padStart(2, '0')}</div>
          </div>
          <div class="work-info">
            <div class="work-meta">
              <span class="work-tag">{w.tag}</span>
              <span class="work-year">{w.year}</span>
            </div>
            <div class="work-title">{w.t}</div>
            <div class="work-desc">{w.d}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 6. PROCESS ══════════ -->
<section class="ws">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PROCESS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 04 / 06</span>
      </div>
      <h2 class="sh-jp">ご依頼から納品まで。</h2>
    </div>

    <div class="process-grid reveal">
      <div class="process-hline"></div>
      {[
        { n: '01', t: 'ヒアリング', s: '60–90 min', d: 'オンラインで現状と背景を伺います。初回は資料も準備も不要です。' },
        { n: '02', t: '提案・お見積もり', s: '1 week', d: '方向性のラフ案と概算を、A4一枚にまとめてお送りします。' },
        { n: '03', t: '制作・調整', s: '3–6 weeks', d: '週1で進行をご報告。固定ページを動かしながら詰めます。' },
        { n: '04', t: '納品・運用', s: '1 day +', d: '公開作業と引き継ぎ資料。月額契約の方はそのまま運用へ。' },
      ].map(p => (
        <div class="process-item">
          <div class="process-badge">{p.n}</div>
          <div class="process-title">{p.t}</div>
          <div class="process-span">{p.s}</div>
          <p class="process-body">{p.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 7. FAQ ══════════ -->
<section class="ws" id="faq">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">FAQ</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 05 / 06</span>
      </div>
      <h2 class="sh-jp">よくいただく質問。</h2>
    </div>

    <div class="faq-grid">
      {[
        {
          q: '農家業との兼業で、対応は遅くなりませんか？',
          a: '繁忙期（5月〜7月、11月）は新規受付を絞っています。進行中の案件は週1の定例で品質を担保しており、納期はお見積もり時に明示します。',
          open: true,
        },
        {
          q: '対応エリアの制限はありますか？',
          a: '全国対応です。打ち合わせはオンラインが基本で、首都圏・東北圏は月1回程度の訪問にも応じます。',
          open: false,
        },
        {
          q: 'WordPressやSTUDIO、どちらで作りますか？',
          a: '案件の運用体制で選びます。所員さんが更新するならSTUDIO、ブログ運用が中心ならWordPress、必要十分な静的サイトで足りる場合も多いです。',
          open: true,
        },
        {
          q: '月額AIパートナーは何をやってくれるのですか？',
          a: 'ご自身の業務を1〜2つ選び、AI/自動化に移し替える伴走です。まず現状の業務フローを整理し、自農場で実装済みの仕組みを現場に合わせて展開します。',
          open: false,
        },
        {
          q: '見積もりは無料ですか？',
          a: '初回ヒアリングと概算お見積もりまでは無料です。本見積もり以降に作業が発生する場合は事前にお知らせします。',
          open: false,
          wide: true,
        },
      ].map((f, i) => (
        <div class={`faq-card${f.open ? ' faq-open' : ''}${f.wide ? ' faq-wide' : ''} reveal`}>
          <div class="faq-header">
            <div class="faq-q-wrap">
              <span class="faq-no">Q.{String(i + 1).padStart(2, '0')}</span>
              <span class="faq-q">{f.q}</span>
            </div>
            <span class="faq-icon">{f.open ? '–' : '+'}</span>
          </div>
          {f.open && <p class="faq-a">{f.a}</p>}
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 8. CONTACT ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT / 06 / 06</div>
        <h2 class="contact-title">
          まずは、<br />
          あなたの話を、<br />
          聞かせてください。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          発注を急がせる営業はしません。<br />
          初回は60分、現状と背景を伺うところから。<br />
          フォームか、メールでお気軽にどうぞ。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">相談する →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 9. FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/" class="wfooter-back">← BACK TO FARM&nbsp;EOLICA</a>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root {
  --m: #1A2744;
  --a: #B87333;
  --bg: #F2F2F0;
  --ink: #4A3B32;
  --inks: rgba(74,59,50,0.72);
  --inkm: rgba(74,59,50,0.48);
  --hair: rgba(74,59,50,0.14);
  --sr: 'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp: 'Cinzel',serif;
  --mn: 'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

/* ── Animations ── */
@keyframes fadeInUp{
  from{opacity:0;transform:translateY(28px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(28px)}
.reveal.visible{animation:fadeInUp .75s cubic-bezier(.22,1,.36,1) forwards}
.reveal-d2{animation-delay:.15s}
.reveal-d3{animation-delay:.3s}

/* ── Header ── */
.wh{
  position:sticky;top:0;z-index:100;
  background:rgba(242,242,240,.92);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border-bottom:1px solid var(--hair);
  padding:20px 60px;
  display:flex;align-items:center;justify-content:space-between;
}
.wh-logo{display:flex;align-items:center;gap:10px}
.wh-logo-icon{width:28px;height:28px;display:block;flex-shrink:0;filter:hue-rotate(59deg) saturate(0.4) brightness(1.1)}
.wh-logo-main{font-family:var(--dp);font-size:20px;letter-spacing:.22em;color:var(--m)}
.wh-logo-sub{font-family:var(--dp);font-size:12px;letter-spacing:.3em;color:var(--a)}
.wh-farm-link{font-family:var(--mn);font-size:10px;letter-spacing:.15em;color:var(--inkm);border:1px solid var(--hair);padding:5px 10px;transition:color .2s,border-color .2s}
.wh-farm-link:hover{color:var(--m);border-color:var(--m)}
.wh-nav{display:flex;align-items:center;gap:34px}
.wh-nav a{font-family:var(--sr);font-size:13px;letter-spacing:.1em;color:var(--ink);transition:color .2s}
.wh-nav a:hover{color:var(--a)}
.wh-cta{
  padding:9px 18px;border:1px solid var(--m);
  color:var(--m)!important;
  font-family:var(--dp);font-size:11px;letter-spacing:.18em;
  transition:background .2s,color .2s!important;
}
.wh-cta:hover{background:var(--m);color:var(--bg)!important}

/* ── Hero ── */
.hero-section{padding:60px 60px 70px;min-height:80vh;display:flex;flex-direction:column;justify-content:flex-end}
.bento{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  grid-template-rows:min(230px,27vh) min(230px,27vh) min(160px,19vh);
  gap:18px;
  max-width:1320px;margin:0 auto;width:100%;
}

/* Placeholder */
.ph{
  width:100%;height:100%;
  background:repeating-linear-gradient(135deg,rgba(74,59,50,.06) 0 10px,rgba(74,59,50,.02) 10px 20px);
  border:1px solid var(--hair);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mn);font-size:11px;letter-spacing:.08em;
  color:rgba(74,59,50,.55);text-transform:uppercase;
}
.ph-auto{aspect-ratio:auto}
.ph-45{aspect-ratio:4/5}

/* Bento cells */
.bc{border:1px solid var(--hair);overflow:hidden;position:relative}

.bc-title{
  grid-column:1/span 2;grid-row:1/span 2;
  background:var(--m);color:var(--bg);
  padding:32px 28px;display:flex;align-items:center;justify-content:center;
}
.tategaki{
  writing-mode:vertical-rl;text-orientation:mixed;
  font-family:var(--sr);font-size:clamp(54px,5vw,78px);font-weight:500;
  line-height:1.4;letter-spacing:.1em;color:var(--bg);margin:0;
  max-height:calc(100% - 64px);overflow:hidden;
}
.bc-title-sub{
  position:absolute;left:36px;bottom:32px;
