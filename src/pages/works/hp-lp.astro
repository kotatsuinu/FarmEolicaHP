---
// Farm Eolica Works — 1ページHP・LP制作 商品詳細ページ
// Self-contained page — independent from main HP design
import { SITE_CONFIG } from '../../config/site';
import WorksHeader from '../../components/works/WorksHeader.astro';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = '1ページHP・LP制作 | Farm Eolica Works';
const description = '福島・浪江の農家兼元編集者が、あなたの物語を1ページのWebページにします。取材から公開まで一貫対応。先着5名 特別価格¥40,000〜（通常¥80,000〜）。ソース一式をGitHubで納品、ロックインなし。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/hp-lp/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/hp-lp/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ 1. HERO ══════════ -->
<section class="ph-section">
  <div class="wc">
    <div class="ph-top reveal">
      <span class="ph-en">WEBSITE / LP</span>
      <span class="ph-line"></span>
      <a href="/works/#products" class="cs-back-link">← Productsへ</a>
    </div>
    <h1 class="ph-title reveal">1ページで、あなたの物語がちゃんと伝わるサイトを。</h1>
    <p class="ph-lead reveal">
      ホームページほど大掛かりじゃなくていい。でも、広告っぽいLPも少し違う——そんな方のための、1ページ完結のWebページを作ります。
    </p>
    <div class="ph-hero-btns reveal">
      <a href="/works/contact" class="btn-filled">まずは相談してみる →</a>
      <a href="#plan" class="btn-ghost">料金・プランを見る</a>
    </div>
  </div>
</section>


<!-- ══════════ 2. TARGET（対象） ══════════ -->
<section class="ws" id="target">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">TARGET</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 05</span>
      </div>
      <h2 class="sh-jp">こんな方へ。</h2>
    </div>

    <div class="target-list reveal">
      {[
        '食・農・工房・宿・個人店など、地域に根ざしてストーリーを持って仕事をしている方',
        '名刺代わりに渡せる、自分の言葉で語られたページが欲しい方',
        'ホームページほど大掛かりでなくていい、けれど広告っぽいLPも少し違うと感じる方',
        '「全部お任せ」も「一緒に考えたい」も歓迎。ローカル・紹介のご縁を大事にしたい方',
      ].map(t => (
        <div class="target-item">
          <span class="target-mark">・</span>
          <p>{t}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 3. PLAN（提供内容・プラン） ══════════ -->
<section class="ws ws-alt" id="plan">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">PLAN</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 05</span>
      </div>
      <h2 class="sh-jp">料金と、できること。</h2>
    </div>

    <div class="plan-grid">
      <!-- スタンダード -->
      <div class="plan-card plan-card-featured reveal">
        <div>
          <span class="plan-badge">先着5名 特別価格</span>
          <h3 class="plan-title">スタンダード<br /><span class="plan-title-sub">（microCMS付）</span></h3>
          <div class="plan-list">
            {[
              'ヒアリング（取材・コピーライティング）',
              'デザイン2案提示',
              'コーディング（HTML / CSS / JS）',
              'スマートフォン対応',
              'microCMS設定（テキスト・写真・ヒーロー画像を自分で更新可能）',
              'Cloudflare Pages 公開設定',
              'お問い合わせフォーム',
              '初回GA4設置（希望に応じて）',
            ].map(i => (
              <div class="plan-list-item"><span class="target-mark">・</span><span>{i}</span></div>
            ))}
          </div>
        </div>
        <div class="plan-price-row">
          <div class="plan-price-block">
            <span class="plan-price-label">先着5名</span>
            <span class="plan-price">¥50,000</span>
          </div>
          <div class="plan-price-block plan-price-block-sub">
            <span class="plan-price-label">通常</span>
            <span class="plan-price plan-price-sub">¥100,000</span>
          </div>
        </div>
      </div>

      <!-- シンプル -->
      <div class="plan-card reveal">
        <div>
          <span class="plan-badge plan-badge-ghost">先着5名</span>
          <h3 class="plan-title">シンプル<br /><span class="plan-title-sub">（CMSなし）</span></h3>
          <div class="plan-list">
            {[
              'ヒアリング（取材・コピーライティング）',
              'デザイン2案提示',
              'コーディング（HTML / CSS / JS）',
              'スマートフォン対応',
              'Cloudflare Pages 公開設定',
              'お問い合わせフォーム',
            ].map(i => (
              <div class="plan-list-item"><span class="target-mark">・</span><span>{i}</span></div>
            ))}
          </div>
        </div>
        <div class="plan-price-row">
          <div class="plan-price-block">
            <span class="plan-price-label">先着5名</span>
            <span class="plan-price">¥40,000</span>
          </div>
          <div class="plan-price-block plan-price-block-sub">
            <span class="plan-price-label">通常</span>
            <span class="plan-price plan-price-sub">¥80,000</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 制作期間・納品物・拡張 facts -->
    <div class="cs-facts reveal">
      {[
        { k: '制作期間', v: '最短10営業日〜（通常2〜3週間。繁忙期5〜10月は最大4〜5週間）' },
        { k: '納品物', v: 'ソースコード（HTML/CSS/JS）一式をGitHubリポジトリ形式で。Cloudflare Pages公開設定込み——ロックインなし（他の納品形式のご希望もご相談ください）。' },
        { k: '拡張（応相談）', v: '5〜10ページのコーポレートHP。目安 ¥150,000〜。' },
      ].map(f => (
        <div class="cs-fact">
          <div class="cs-fact-k">{f.k}</div>
          <div class="cs-fact-v">{f.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 4. FLOW（制作フロー） ══════════ -->
<section class="ws" id="flow">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">FLOW</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 05</span>
      </div>
      <h2 class="sh-jp">ご依頼から、その先まで。</h2>
    </div>

    <div class="flow-grid reveal">
      <div class="flow-hline"></div>
      {[
        { n: '01', t: '問い合わせ' },
        { n: '02', t: 'ヒアリング' },
        { n: '03', t: '制作' },
        { n: '04', t: '修正2ターン無料', accent: true },
        { n: '05', t: '公開' },
        { n: '06', t: '公開後30日以内の微修正無料', accent: true },
      ].map(s => (
        <div class={`flow-step${s.accent ? ' flow-step-accent' : ''}`}>
          <div class="flow-badge">{s.n}</div>
          <div class="flow-title">{s.t}</div>
        </div>
      ))}
    </div>
    <p class="flow-note reveal">※ 3ターン目以降は¥3,000/ターン（1ターン＝1回のフィードバック往復）</p>
  </div>
</section>


<!-- ══════════ 5. OPTIONS（料金補足） ══════════ -->
<section class="ws ws-alt" id="options">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">OPTION</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 04 / 05</span>
      </div>
      <h2 class="sh-jp">料金補足（有料オプション）。</h2>
    </div>

    <div class="target-list reveal">
      {[
        'ページ追加　+¥10,000／ページ',
        'カスタムドメイン設定　+¥5,000（ドメイン実費別）',
        'LP＋印刷用PDF出力　+¥15,000〜30,000',
      ].map(t => (
        <div class="target-item">
          <span class="target-mark">・</span>
          <p>{t}</p>
        </div>
      ))}
    </div>

    <div class="option-note reveal">
      <div class="option-note-label">直接取引（自社HP経由）特典</div>
      <p class="option-note-body">
        打合せ+2回・修正+1ターンを追加でご利用いただけます。月額AIパートナーへ移行される場合は、最初の3ヶ月各¥3,000 OFF（計¥9,000）になります。
      </p>
    </div>
  </div>
</section>


<!-- ══════════ 6. WORKS（実績） ══════════ -->
<section class="ws" id="works">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">WORKS</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 05 / 05</span>
      </div>
      <h2 class="sh-jp">制作実績。</h2>
    </div>

    <div class="works-grid-3">
      <!-- なみえライスバーガー（実名・TV放送） -->
      <a href="/works/case/namie-rice-burger/" class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / namie rice burger</div>
        </div>
        <div class="work-info">
          <span class="work-badge">TV放送 2026.7.10</span>
          <div class="work-title">なみえライスバーガー</div>
          <div class="work-desc">浪江創成中学校「ふるさと創造学」× 道の駅なみえ。生徒の言葉でつくったLP。</div>
          <span class="work-more">詳しく見る →</span>
        </div>
      </a>

      <!-- 三宅奈緒（制作サンプル・架空） -->
      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / showcase</div>
        </div>
        <div class="work-info">
          <span class="work-badge work-badge-ghost">制作サンプル・架空</span>
          <div class="work-title">三宅奈緒 / Portfolio</div>
          <div class="work-desc">Astro + microCMSでの実装例をお見せするための制作サンプルです。実在の依頼ではありません。</div>
        </div>
      </div>

      <!-- 地域の酒蔵（完全匿名イメージ例） -->
      <div class="work-card reveal">
        <div class="work-ph">
          <div class="ph ph-auto">work / concept mock</div>
        </div>
        <div class="work-info">
          <span class="work-badge work-badge-ghost">完全匿名イメージ例</span>
          <div class="work-title">地域の酒蔵 / ストーリーLP</div>
          <div class="work-desc">特定の事業者をモデルにしない、完全に匿名のコンセプトモックです。ストーリー訴求の見せ方サンプルとして掲載しています。</div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 7. CTA ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          あなたの物語も、<br />
          こんなふうに。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          「伝えたいことはあるけれど、うまく形にできない」——<br />
          そんなお話を、まずは60分聞かせてください。押し売りはしません。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">まずは相談する（無料） →</a>
        </div>
        <a href="/works/partner" class="contact-sub-link">公開後の継続運用は、月額AIパートナーへ →</a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root {
  --m: #1A2744;
  --a: #B87333;
  --bg: #F2F2F0;
  --ink: #4A3B32;
  --inks: rgba(74,59,50,0.72);
  --inkm: rgba(74,59,50,0.48);
  --hair: rgba(74,59,50,0.14);
  --sr: 'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp: 'Cinzel',serif;
  --mn: 'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

@keyframes fadeInUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(24px)}
.reveal.visible{animation:fadeInUp .7s cubic-bezier(.22,1,.36,1) forwards}

/* ── Page Header (hero) ── */
.ph-section{padding:80px 60px 60px;background:var(--m)}
.wc{max-width:1120px;margin:0 auto}
.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px;flex-wrap:wrap}
.ph-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.cs-back-link{font-family:var(--mn);font-size:11px;letter-spacing:.1em;color:rgba(242,242,240,.65);transition:color .2s;margin-left:auto}
.cs-back-link:hover{color:var(--a)}
.ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(34px,3.6vw,56px);color:var(--bg);margin:0 0 20px;letter-spacing:.04em;line-height:1.4;max-width:820px}
.ph-lead{font-family:var(--sr);font-size:16px;color:rgba(242,242,240,.7);letter-spacing:.06em;line-height:1.8;margin:0 0 32px;max-width:640px}
.ph-hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.ph-hero-btns .btn-ghost{color:var(--bg);border-color:rgba(242,242,240,.5)}
.ph-hero-btns .btn-ghost:hover{background:rgba(242,242,240,.08)}
.ph-hero-btns .btn-filled{background:var(--a);border-color:var(--a);color:var(--m)}
.ph-hero-btns .btn-filled:hover{background:#c98a45;border-color:#c98a45}

/* ── Section commons ── */
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}

.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:10px;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

/* ── Buttons ── */
.btn-filled,.btn-ghost{
  display:inline-flex;align-items:center;
  padding:13px 22px;
  font-family:var(--dp);font-size:12px;letter-spacing:.22em;
  transition:all .25s;cursor:pointer;
}
.btn-filled{background:var(--m);color:var(--bg);border:1px solid var(--m)}
.btn-filled:hover{background:#253a6b;border-color:#253a6b}
.btn-ghost{background:transparent;color:var(--m);border:1px solid var(--m)}
.btn-ghost:hover{background:rgba(26,39,68,.07)}

/* ── Target list (bullet list) ── */
.target-list{display:flex;flex-direction:column;gap:20px;max-width:760px}
.target-item{display:flex;gap:14px;align-items:flex-start}
.target-mark{font-family:var(--sr);font-size:15px;font-weight:600;color:var(--a);flex-shrink:0;margin-top:2px}
.target-item p{font-size:14.5px;line-height:2;color:var(--inks)}

/* ── Plan cards ── */
.plan-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px}
.plan-card{
  background:var(--bg);border:1px solid var(--hair);
  padding:36px 32px;display:flex;flex-direction:column;justify-content:space-between;gap:28px;
}
.plan-card-featured{background:var(--m);color:var(--bg);border-color:var(--m)}
.plan-badge{
  display:inline-block;font-family:var(--dp);font-size:10px;letter-spacing:.28em;
  color:var(--a);border:1px solid var(--a);padding:5px 12px;margin-bottom:20px;
}
.plan-badge-ghost{color:var(--m);border-color:var(--m)}
.plan-title{font-family:var(--sr);font-size:26px;letter-spacing:.05em;margin:0 0 24px;line-height:1.4;color:inherit}
.plan-title-sub{font-size:15px;color:var(--inkm);letter-spacing:.03em}
.plan-card-featured .plan-title-sub{color:rgba(242,242,240,.55)}
.plan-list{display:flex;flex-direction:column;gap:11px}
.plan-list-item{display:flex;gap:10px;align-items:flex-start;font-size:13.5px;line-height:1.8}
.plan-list-item .target-mark{color:var(--a)}
.plan-card-featured .plan-list-item{color:rgba(242,242,240,.85)}
.plan-card:not(.plan-card-featured) .plan-list-item{color:var(--inks)}

.plan-price-row{
  display:flex;gap:24px;padding-top:24px;
  border-top:1px solid var(--hair);
}
.plan-card-featured .plan-price-row{border-top-color:rgba(242,242,240,.2)}
.plan-price-block{display:flex;flex-direction:column;gap:6px}
.plan-price-label{font-family:var(--mn);font-size:10px;letter-spacing:.16em;color:var(--a)}
.plan-price{font-family:var(--sr);font-size:26px;font-weight:600;letter-spacing:.02em}
.plan-price-block-sub .plan-price-label{color:var(--inkm)}
.plan-card-featured .plan-price-block-sub .plan-price-label{color:rgba(242,242,240,.5)}
.plan-price-sub{font-size:18px;font-weight:500;color:var(--inkm)}
.plan-card-featured .plan-price-sub{color:rgba(242,242,240,.65)}

/* ── Facts (制作期間/納品物/拡張) ── */
.cs-facts{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  background:var(--hair);border:1px solid var(--hair);
}
.cs-fact{background:var(--bg);padding:22px 24px}
.cs-fact-k{font-family:var(--mn);font-size:10px;letter-spacing:.16em;color:var(--a);margin-bottom:10px}
.cs-fact-v{font-size:13.5px;line-height:1.9;color:var(--ink)}

/* ── Flow (制作フロー) ── */
.flow-grid{
  display:grid;grid-template-columns:repeat(6,1fr);gap:14px;
  position:relative;margin-bottom:20px;
}
.flow-hline{position:absolute;left:5%;right:5%;top:26px;height:1px;background:var(--hair)}
.flow-step{position:relative;display:flex;flex-direction:column;align-items:flex-start;gap:14px}
.flow-badge{
  width:52px;height:52px;border-radius:50%;
  background:var(--bg);border:1px solid var(--m);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--dp);font-size:14px;color:var(--m);letter-spacing:.08em;
  position:relative;z-index:2;
}
.flow-step-accent .flow-badge{background:var(--a);border-color:var(--a);color:var(--m)}
.flow-title{font-family:var(--sr);font-size:14px;color:var(--m);letter-spacing:.03em;line-height:1.6}
.flow-step-accent .flow-title{color:var(--a);font-weight:600}
.flow-note{font-family:var(--mn);font-size:11px;letter-spacing:.06em;color:var(--inkm);margin-top:4px}

/* ── Option note panel ── */
.option-note{
  margin-top:36px;background:rgba(184,115,51,.08);border:1px solid var(--hair);
  padding:28px 32px;max-width:760px;
}
.option-note-label{font-family:var(--dp);font-size:11px;letter-spacing:.2em;color:var(--a);margin-bottom:12px}
.option-note-body{font-size:13.5px;line-height:2;color:var(--inks)}

/* ── Works (3 cards) ── */
.works-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.work-card{
  overflow:hidden;background:var(--bg);border:1px solid var(--hair);
  display:flex;flex-direction:column;
  transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s;
}
a.work-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(26,39,68,.12)}
.work-ph{overflow:hidden}
.work-ph .ph{border:none;aspect-ratio:4/3}
.ph{
  width:100%;height:100%;
  background:repeating-linear-gradient(135deg,rgba(74,59,50,.06) 0 10px,rgba(74,59,50,.02) 10px 20px);
  border:1px solid var(--hair);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mn);font-size:11px;letter-spacing:.08em;
  color:rgba(74,59,50,.55);text-transform:uppercase;text-align:center;padding:16px;
}
.work-info{padding:22px 24px;border-top:1px solid var(--hair);flex:1;display:flex;flex-direction:column}
.work-badge{display:inline-block;width:fit-content;font-family:var(--mn);font-size:9px;letter-spacing:.2em;color:var(--bg);background:var(--a);padding:3px 9px;margin-bottom:10px}
.work-badge-ghost{color:var(--a);background:transparent;border:1px solid var(--a)}
.work-title{font-family:var(--sr);font-size:19px;color:var(--m);letter-spacing:.05em;margin-bottom:8px}
.work-desc{font-size:13px;line-height:1.9;color:var(--inks)}
.work-more{display:inline-block;margin-top:12px;font-family:var(--dp);font-size:11px;letter-spacing:.18em;color:var(--a)}

/* ── Contact ── */
.contact-section{padding-bottom:100px}
.contact-panel{
  background:var(--m);color:var(--bg);padding:80px 70px;
  display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center;
}
.contact-label{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{
  font-family:var(--sr);font-weight:500;font-size:clamp(30px,3vw,44px);margin:0;
  line-height:1.4;letter-spacing:.04em;color:var(--bg);
}
.contact-body{
  font-size:15px;line-height:2.1;color:rgba(242,242,240,.8);
  letter-spacing:.04em;margin-bottom:28px;max-width:480px;
}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:18px}
.contact-btn-primary{
  padding:16px 26px;font-family:var(--dp);font-size:13px;letter-spacing:.22em;
  background:var(--a);color:var(--m);
  transition:background .25s;display:inline-block;
}
.contact-btn-primary:hover{background:#c98a45}
.contact-sub-link{
  display:inline-block;font-family:var(--mn);font-size:11px;letter-spacing:.08em;
  color:rgba(242,242,240,.7);border-bottom:1px solid rgba(242,242,240,.35);padding-bottom:3px;
  transition:color .2s,border-color .2s;
}
.contact-sub-link:hover{color:var(--a);border-color:var(--a)}

/* ── Footer ── */
.wfooter{
  padding:20px 60px 40px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--hair);
}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}

/* ── Responsive ── */
@media (max-width: 900px){
  .ph-section{padding:56px 24px 44px}
  .ws{padding:56px 24px 64px}

  .plan-grid{grid-template-columns:1fr}
  .cs-facts{grid-template-columns:1fr}

  .flow-grid{grid-template-columns:repeat(3,1fr);row-gap:32px}
  .flow-hline{display:none}

  .works-grid-3{grid-template-columns:1fr}

  .contact-panel{grid-template-columns:1fr;padding:48px 28px;gap:32px}
  .wfooter{flex-direction:column;gap:16px;padding:24px 24px 32px;text-align:center}
}

@media (max-width: 600px){
  .sh-no{display:none}
  .flow-grid{grid-template-columns:repeat(2,1fr)}
  .contact-title{font-size:clamp(26px,7vw,36px)}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');
      io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  setTimeout(function(){
    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible')});
  },60);
  els.forEach(function(el){io.observe(el)});
})();
</script>

</body>
</html>
