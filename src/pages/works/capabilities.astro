  </div>
</section>


<!-- ══════════ SCOPE OUT（対応外・明確な線引き） ══════════ -->
<section class="ws ws-alt" id="scope-out">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">OUT OF SCOPE</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 対応の線引き</span>
      </div>
