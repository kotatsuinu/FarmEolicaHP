</section>


<!-- ══════════ CATEGORIES（実績カテゴリ） ══════════ -->
{categories.map((cat, idx) => (
  <section class={`ws${idx % 2 === 1 ? ' ws-alt' : ''}`} id={cat.id}>
    <div class="wc">
      <div class="sh reveal">
        <div class="sh-top">
          <span class="sh-en">{cat.labelEn}</span>
          <span class="sh-line"></span>
          <span class="sh-no">— {String(idx + 1).padStart(2, '0')} / {String(categories.length).padStart(2, '0')}</span>
