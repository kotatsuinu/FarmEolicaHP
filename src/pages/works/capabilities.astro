---
// Farm Eolica Works — Capabilities (What You Can Ask For)
// Design: Layout 3 "Tategaki Bento" (Navy × Copper) — self-contained
// Structure: 1) Hero (reframe as capabilities) 2) Task menu (main content, 8 categories)
//            3) Notes（ご相談のポイント／対象外の業務） 4) CTA
// 実績36システムは records.astro へ移設済み（本ページには含めない）
import { SITE_CONFIG } from '../../config/site';
import WorksHeader from '../../components/works/WorksHeader.astro';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';

// ─── 頼めるタスク一覧（主コンテンツ） ───
type TaskCategory = {
  id: string;
  label: string;
  labelEn: string;
  note?: string; // カテゴリ単位の対応範囲の補足（税務除外・件数目安など）
  items: string[];
};

const taskCategories: TaskCategory[] = [
  {
    id: 'doc',
    label: '文章・資料づくり',
    labelEn: 'DOCUMENTS & WRITING',
    items: [
      '提案書・企画書ドラフト',
      '取引先向けメール文案',
      '店頭POP・チラシのコピー',
      '議事録・打合せメモの整形・清書',
      '求人広告文',
      '面接質問リストの整理',
      '業務マニュアル下書き',
      '見積・契約文書の雛形整理',
    ],
  },
  {
    id: 'content',
    label: '情報発信',
    labelEn: 'CONTENT & SNS',
    items: [
      'SNS投稿文（Instagram/X等）',
      'リール・ショート動画の台本',
      'ブログのドラフト・リライト',
      '口コミ・コメント返信',
      'LINE公式の配信文',
      'お知らせの月次まとめ更新',
      'プレスリリース文案',
    ],
  },
  {
    id: 'books',
    label: '経理・帳簿まわり',
    labelEn: 'BOOKKEEPING',
    note: '※税務判断・申告書の作成/提出は対象外です',
    items: [
      '領収書・レシート整理・台帳転記',
      '請求書作成（複数まとめて）',
      '経費入力・仕訳の下書き整理（最終確認はお客様側）',
      '売上・経費の月次集計表',
      '支払状況の一覧化・催促リスト',
      '帳票PDF化・保管ファイリング',
    ],
  },
  {
    id: 'research',
    label: 'リサーチ・要約',
    labelEn: 'RESEARCH & SUMMARY',
    items: [
      '競合・業者調査＋比較レポート化',
      '市場・業界動向リサーチ＋要約',
      '補助金・制度リサーチ（※申請書類の作成代行は対象外）',
      '顧客アンケートの設計・集計分析',
      '資料・記事・論文の要約',
      '月次経営レポート作成',
    ],
  },
  {
    id: 'data',
    label: 'データ整理・変換',
    labelEn: 'DATA ORGANIZING',
    items: [
      '表計算の整理・並べ替え・集計',
      '名簿・顧客リストの名寄せ・重複チェック',
      'PDF⇔Word/Excel等の形式変換',
      '画像・文書の変換・圧縮',
      'フォルダ・ファイル整理・命名統一',
      '生データ集計・グラフ化（※目安50件超の大量手入力は要相談）',
    ],
  },
  {
    id: 'slide',
    label: 'スライド・動画',
    labelEn: 'SLIDES & VIDEO',
    note: '※内容が重い場合は実測のうえ上位プランをご提案することがあります',
    items: [
      '提案書・報告書スライド作成（構成〜デザイン）',
      '会議・プレゼン資料のブラッシュアップ',
      '簡単な動画編集（カット・テロップ・BGM挿入）',
      '静止画からの簡易スライドショー動画',
      'SNS用ショート動画の簡易編集',
    ],
  },
  {
    id: 'auto',
    label: '定型業務の自動化・仕組み化',
    labelEn: 'WORKFLOW AUTOMATION',
    note: '※初回の仕組み化のみ1タスク扱い・以降はノーカウントです',
    items: [
      '毎月の定型レポートのテンプレ化・自動生成',
      'SNS投稿・ブログのパターンをテンプレ化',
      '問い合わせ・口コミ返信のテンプレ化',
      '請求・見積の雛形化で作成ゼロに',
      'データ集計の自動化（関数・簡易マクロ等）',
    ],
  },
  {
    id: 'coach',
    label: 'AI活用のレクチャー・ノウハウ',
    labelEn: 'AI COACHING',
    note: '※¥40,000プラン以上の付加価値です（代行プランでも軽い質問には対応します）',
    items: [
      '卓磨が実際に使っているプロンプトの共有',
      '月次レクチャー・使いこなし相談枠（オンライン）',
      '業務別の自動化指南',
      'LINE・Slack相談無制限',
    ],
  },
];

const taskUnitExamples = [
  'レポート作成1点',
  'ブログ記事の生成・リライト1本',
  'ブログネタのリサーチ→制作1本',
  'SNS数週間分の投稿文',
  'キャンペーン告知文',
  '資料1点の骨子設計',
  '編集可能なポップデザイン1点',
  'データ整理1回（規模による）',
];

// ─── ご相談の上で最適な形を決める3つの観点（注意事項ブロック1） ───
type NotePoint = {
  title: string;
  body: string;
};

const notePoints: NotePoint[] = [
  {
    title: '機密・個人情報',
    body: '個人情報・企業の根幹機密は原則お預かりしません（第三者への受け渡しは法的にもNGです）。ただし「この範囲なら共有OK」「AIに渡す分にはここまで」というお客さまとの取り決め・ご了承がある範囲は、ご相談の上でお引き受け可能です。',
  },
  {
    title: 'アナログ・物理物',
    body: '紙原本のお預かり（保管責任が発生します）や物理的な手作業は原則対象外です。ただしスキャン等でデータ化できれば対応可能ですし、繰り返す作業は自動化の仕組み化もご提案できます。データであれば扱いやすい、というのがポイントです。',
  },
  {
    title: 'アカウント・権限・連携',
    body: 'こちらで完結できる場合はお客さまの作業は不要です。お客さま自身にPC操作・アカウント承認・API連携・権限設定をお願いする必要がある場合はハードルがあります。ヒアリングの上でこちらからご提案します。',
  },
];

// ─── 対象外の業務（注意事項ブロック2） ───
const outOfScope = [
  '士業の独占業務（法律相談・契約書作成そのもの、税務相談・確定申告、医療効能の保証等）',
  '補助金・許認可の申請書類そのものの作成代行（※情報リサーチ・計画書ドラフトまでは対応します）',
  '事実の完全保証はしません（AIの誤りを含む可能性があり、最終判断はお客さま側でお願いしています）',
  'クレジットカード番号・マイナンバー・銀行口座等の機微情報はお預かりしません',
];

const navItems = [
  { href: '#tasks', label: '頼めること' },
  { href: '#notes', label: 'ご相談のポイント' },
  { href: '#scope-out', label: '対象外' },
];

const title = 'こんな作業、まるごと頼めます。 | Farm Eolica Works';
const description = '文章づくり・情報発信・経理・リサーチ・データ整理・スライド動画・仕組み化・AI活用レクチャーまで。業務代行〈AI活用〉で頼めるタスクの一覧と、ご相談前に知っておきたい3つのポイントをまとめました。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/capabilities/`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/works/capabilities/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader active="capabilities" />


<!-- ══════════ HERO ══════════ -->
<section class="cap-hero">
  <div class="wc">
    <div class="cap-hero-inner reveal reveal-hero reveal-d1">
      <div class="sh-top">
        <span class="sh-en">CAPABILITIES</span>
        <span class="sh-line"></span>
        <span class="sh-no">— {taskCategories.length} CATEGORIES OF TASKS</span>
      </div>
      <h1 class="cap-h1">こんな作業、<br />まるごと頼めます。</h1>
      <p class="cap-lead">
        AIを使える方ほど、「議事録まとめくらい自分でやる」と思うかもしれません。<br />
        でも、その"くらい"の作業が10も20も積み重なると、結局まとまった時間を奪われます。<br />
        ひとつひとつは小さくても丸ごと預けられること。そして本当に面倒な"仕組み化"や"リサーチ"まで、同じ窓口で頼めること。<br />
        それが業務代行〈AI活用〉の価値です。
      </p>
      <div class="cap-hero-cta">
        <a href="/works/partner/" class="contact-btn-ghost">業務代行〈AI活用〉を見る →</a>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ CATEGORY NAV ══════════ -->
<nav class="cap-nav">
  <div class="cap-nav-inner">
    {navItems.map(n => (
      <a href={n.href} class="cap-nav-pill">{n.label}</a>
    ))}
  </div>
</nav>


<!-- ══════════ TASKS（頼めるタスク一覧・主コンテンツ） ══════════ -->
<section class="ws" id="tasks">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">WHAT YOU CAN ASK</span>
        <span class="sh-line"></span>
        <span class="sh-no">— {String(taskCategories.length).padStart(2, '0')} categories</span>
      </div>
      <h2 class="sh-jp">頼めるタスク一覧</h2>
    </div>

    <p class="cap-tasks-lead reveal">
      "自分でもできるけど、地味に面倒"な作業から、"やりたくても手が回らない"仕組み化まで——まとめて、同じ窓口で引き受けます。
    </p>

    <div class="task-grid">
      {taskCategories.map((cat, idx) => (
        <article class="task-card reveal">
          <div class="task-card-head">
            <span class="task-card-num">{String(idx + 1).padStart(2, '0')}</span>
            <h3 class="task-card-title">{cat.label}</h3>
          </div>
          <div class="task-card-en">{cat.labelEn}</div>
          {cat.note && <p class="task-card-scope-note">{cat.note}</p>}
          <ul class="task-card-list">
            {cat.items.map(item => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>

    <div class="task-unit-box reveal">
      <div class="task-unit-label">1タスクの目安</div>
      <ul class="task-unit-list">
        {taskUnitExamples.map(ex => <li>{ex}</li>)}
      </ul>
      <p class="task-unit-note">※AI実働30分級・成果物1点が目安。どれも自分でやると1.5〜2時間以上かかる作業を、プロのAI活用で最低3倍速に仕上げます。大きく超える依頼は分割か上位プランをご提案します。</p>
      <p class="task-unit-more">月にどのくらいお願いできるかは、<a href="/works/partner/">料金プラン</a>をご覧ください。</p>
    </div>
  </div>
</section>


<!-- ══════════ NOTES（ご相談の上で最適な形を決める3つの観点） ══════════ -->
<section class="ws ws-alt" id="notes">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">BEFORE YOU ASK</span>
        <span class="sh-line"></span>
        <span class="sh-no">— ご相談のポイント</span>
      </div>
      <h2 class="sh-jp">ご相談の上で、<br />最適な形を決めます。</h2>
    </div>
    <p class="notes-lead reveal">
      タスクは一例です。物により導入難易度やお客さまの負担が変わるため、お悩みをヒアリングした上でこちらから最適な形をご提案します。
    </p>
    <ul class="notes-list reveal">
      {notePoints.map((n, idx) => (
        <li>
          <span class="notes-num">{String(idx + 1).padStart(2, '0')}</span>
          <div class="notes-body-wrap">
            <h3 class="notes-title">{n.title}</h3>
            <p class="notes-body">{n.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>


<!-- ══════════ SCOPE OUT（対象外の業務・明確な線引き） ══════════ -->
<section class="ws" id="scope-out">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">OUT OF SCOPE</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 対象外の業務</span>
      </div>
      <h2 class="sh-jp">お引き受けできないこと。</h2>
    </div>
    <ul class="scope-out-list reveal">
      {outOfScope.map(item => <li>{item}</li>)}
    </ul>
  </div>
</section>


<!-- ══════════ CTA / CONTACT ══════════ -->
<section class="ws" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          気になる項目が<br />
          あれば、ご相談を。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          「こんな課題があるんだけど、相談できるか」<br />
          「自分の仕事に応用できないか知りたい」<br />
          その程度の話から始めましょう。初回は無料です。<br />
          これを毎月一緒に回すのが、業務代行〈AI活用〉です。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">相談する →</a>
          <a href="/works/partner/" class="contact-btn-ghost">業務代行〈AI活用〉を見る →</a>
          <a href="/works/" class="contact-btn-ghost">Works LP →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO FARM&nbsp;EOLICA WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root{
  --m:#1A2744;--a:#B87333;--bg:#F2F2F0;--ink:#4A3B32;
  --inks:rgba(74,59,50,0.72);--inkm:rgba(74,59,50,0.48);--hair:rgba(74,59,50,0.14);
  --sr:'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp:'Cinzel',serif;--mn:'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

/* Animations */
@keyframes fadeInUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(28px)}
.reveal.visible{animation:fadeInUp .75s cubic-bezier(.22,1,.36,1) forwards}
.reveal-d2{animation-delay:.15s}

/* Section commons */
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}
.wc{max-width:1320px;margin:0 auto}
.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:0.75rem;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,2.8vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

/* Cap Hero */
.cap-hero{background:var(--m);padding:90px 60px 80px}
.cap-hero-inner{max-width:820px}
.cap-h1{font-family:var(--sr);font-weight:500;font-size:clamp(34px,3.5vw,54px);color:var(--bg);line-height:1.35;letter-spacing:.04em;margin:0 0 26px}
.cap-lead{font-size:1rem;line-height:2;color:rgba(242,242,240,.8);letter-spacing:.04em;max-width:680px}
.cap-hero-cta{margin-top:32px}

/* Cap Nav */
.cap-nav{background:var(--bg);border-bottom:1px solid var(--hair);position:sticky;top:68px;z-index:90;overflow:hidden}
.cap-nav-inner{max-width:1320px;margin:0 auto;padding:0 60px;display:flex;overflow-x:auto;-ms-overflow-style:none;scrollbar-width:none}
.cap-nav-inner::-webkit-scrollbar{display:none}
.cap-nav-pill{font-family:var(--mn);font-size:0.75rem;letter-spacing:.12em;color:var(--inkm);padding:14px 18px;border-bottom:2px solid transparent;white-space:nowrap;transition:color .2s,border-color .2s;flex-shrink:0}
.cap-nav-pill:hover{color:var(--m);border-bottom-color:var(--a)}

/* Cap Tasks (頼めるタスク一覧・新設) */
.cap-tasks-lead{font-size:0.9375rem;line-height:2;color:var(--inks);letter-spacing:.03em;max-width:760px;margin:0 0 40px}
.task-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.task-card{border:1px solid var(--hair);padding:26px 28px;background:var(--bg);transition:border-color .25s,box-shadow .25s}
.ws-alt .task-card{background:#EAE6DF}
.task-card:hover{border-color:rgba(184,115,51,.4);box-shadow:0 4px 20px rgba(26,39,68,.06)}
.task-card-head{display:flex;align-items:baseline;gap:12px;margin-bottom:2px}
.task-card-num{font-family:var(--mn);font-size:0.75rem;letter-spacing:.1em;color:var(--a)}
.task-card-title{font-family:var(--sr);font-size:1.0625rem;color:var(--m);letter-spacing:.04em;margin:0}
.task-card-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.2em;color:var(--inkm);margin:0 0 14px 28px}
.task-card-scope-note{font-family:var(--mn);font-size:0.75rem;letter-spacing:.03em;color:var(--inkm);margin:0 0 14px;padding:8px 10px;border-left:2px solid var(--a);background:rgba(184,115,51,.06)}
.task-card-list{margin:0;padding:0;list-style:none}
.task-card-list li{font-size:0.84375rem;line-height:1.9;color:var(--inks);padding-left:1.1em;position:relative}
.task-card-list li::before{content:'—';position:absolute;left:0;color:var(--a)}

/* Task Unit box (1タスクの目安) */
.task-unit-box{margin-top:40px;padding:30px 34px;background:var(--m)}
.task-unit-label{font-family:var(--dp);font-size:0.75rem;letter-spacing:.3em;color:var(--a);margin-bottom:16px}
.task-unit-list{display:flex;flex-wrap:wrap;gap:10px 14px;margin:0 0 16px;padding:0;list-style:none}
.task-unit-list li{font-family:var(--mn);font-size:0.75rem;letter-spacing:.04em;color:rgba(242,242,240,.85);padding:5px 12px;border:1px solid rgba(242,242,240,.25)}
.task-unit-note{font-size:0.75rem;letter-spacing:.03em;color:rgba(242,242,240,.55);line-height:1.8}
.task-unit-more{margin-top:16px;font-size:0.75rem;letter-spacing:.03em;color:rgba(242,242,240,.65)}
.task-unit-more a{color:var(--a);border-bottom:1px solid var(--a);padding-bottom:1px;transition:opacity .2s}
.task-unit-more a:hover{opacity:.7}

/* Notes (ご相談の上で最適な形を決める3つの観点) */
.notes-lead{font-size:0.9375rem;line-height:2;color:var(--inks);letter-spacing:.03em;max-width:760px;margin:0 0 40px}
.notes-list{margin:0;padding:0;list-style:none;display:grid;gap:18px}
.notes-list li{display:flex;gap:22px;border:1px solid var(--hair);padding:26px 28px;background:var(--bg)}
.notes-num{font-family:var(--mn);font-size:0.8125rem;letter-spacing:.1em;color:var(--a);flex-shrink:0}
.notes-body-wrap{flex:1;min-width:0}
.notes-title{font-family:var(--sr);font-size:1.0625rem;color:var(--m);letter-spacing:.04em;margin:0 0 10px}
.notes-body{font-size:0.84375rem;line-height:2;color:var(--inks);margin:0}

/* Scope Out (対象外の業務) */
.scope-out-list{margin:0;padding:0;list-style:none;max-width:920px}
.scope-out-list li{font-size:0.875rem;line-height:1.9;color:var(--inks);padding:18px 0 18px 1.6em;border-bottom:1px solid var(--hair);position:relative}
.scope-out-list li:first-child{padding-top:0}
.scope-out-list li:last-child{border-bottom:none}
.scope-out-list li::before{content:'×';position:absolute;left:0;top:18px;color:var(--a);font-family:var(--mn);font-size:0.8125rem}
.scope-out-list li:first-child::before{top:0}

/* Contact CTA (reuse from index) */
.contact-section{padding-bottom:100px}
.contact-panel{background:var(--m);color:var(--bg);padding:80px 70px;display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center}
.contact-label{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);margin:0;line-height:1.4;letter-spacing:.04em;color:var(--bg)}
.contact-body{font-size:1rem;line-height:2.1;color:rgba(242,242,240,.8);letter-spacing:.04em;margin-bottom:40px;max-width:480px}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap}
.contact-btn-primary{padding:16px 26px;font-family:var(--dp);font-size:0.8125rem;letter-spacing:.22em;background:var(--a);color:var(--m);transition:background .25s}
.contact-btn-primary:hover{background:#c98a45}
.contact-btn-ghost{padding:16px 26px;font-family:var(--dp);font-size:0.8125rem;letter-spacing:.22em;border:1px solid rgba(242,242,240,.35);color:var(--bg);transition:border-color .25s}
.contact-btn-ghost:hover{border-color:rgba(242,242,240,.7)}

/* Footer */
.wfooter{padding:20px 60px 40px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--hair)}
.wfooter-back{font-family:var(--dp);font-size:0.75rem;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:0.75rem;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:0.75rem;letter-spacing:.18em;color:var(--inkm)}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  setTimeout(function(){
    document.querySelectorAll('.reveal-hero').forEach(function(el){el.classList.add('visible')});
  },30);
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
  els.forEach(function(el){
    if(!el.classList.contains('reveal-hero'))io.observe(el);
  });
  setTimeout(function(){
    document.querySelectorAll('.reveal:not(.visible)').forEach(function(el){el.classList.add('visible')});
  },1500);
})();
</script>

</body>
</html>
