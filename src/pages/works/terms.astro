<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root{
  --m:#1A2744;--a:#B87333;--bg:#F2F2F0;--ink:#4A3B32;
  --inks:rgba(74,59,50,0.72);--inkm:rgba(74,59,50,0.48);--hair:rgba(74,59,50,0.14);
  --sr:'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp:'Cinzel',serif;--mn:'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(24px)}
.reveal.visible{animation:fadeInUp .7s cubic-bezier(.22,1,.36,1) forwards}

/* Page header hero */
.ph-section{padding:80px 60px 60px;background:var(--m)}
.wc{max-width:900px;margin:0 auto}
.ph-top{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.ph-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}
.ph-title{font-family:var(--sr);font-weight:500;font-size:clamp(28px,4vw,44px);color:var(--bg);margin:0 0 16px;letter-spacing:.04em;line-height:1.3}
.ph-lead{font-family:var(--sr);font-size:15px;color:rgba(242,242,240,.7);letter-spacing:.05em;line-height:1.8;margin:0}

/* Content section */
.ws{padding:70px 60px 60px}
.lg-panel{background:#fff;border:1px solid var(--hair);padding:50px 56px}
.lg-section{margin-bottom:36px}
.lg-section:last-of-type{margin-bottom:0}
.lg-h2{font-family:var(--sr);font-size:19px;font-weight:500;color:var(--m);letter-spacing:.04em;margin:0 0 14px;padding-bottom:10px;border-bottom:1px solid var(--hair)}
.lg-body{font-size:14px;line-height:2;color:var(--inks);margin-bottom:12px}
.lg-body:last-child{margin-bottom:0}
.lg-list{list-style:disc;padding-left:22px;margin:0 0 12px;font-size:14px;line-height:1.95;color:var(--inks)}
.lg-list li{margin-bottom:6px}
.lg-updated{text-align:right;font-family:var(--mn);font-size:11px;letter-spacing:.1em;color:var(--inkm);margin-top:36px}
.lg-back{display:inline-block;margin-top:40px;font-family:var(--dp);font-size:12px;letter-spacing:.22em;color:var(--m);border-bottom:1px solid var(--m);padding-bottom:2px}
.lg-back:hover{color:var(--a);border-bottom-color:var(--a)}

/* Footer */
.wfooter{padding:20px 60px 40px;display:flex;flex-wrap:wrap;gap:12px 24px;justify-content:space-between;align-items:center;border-top:1px solid var(--hair)}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}

@media (max-width:768px){
  .ph-section{padding:60px 24px 40px}
  .ws{padding:50px 24px 40px}
  .lg-panel{padding:32px 24px}
  .wfooter{padding:20px 24px 32px}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});
  } else {
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        e.target.classList.add('visible');io.unobserve(e.target);
      });
    },{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
    els.forEach(function(el){io.observe(el)});
  }
})();
</script>

</body>
