---
// Farm Eolica Works — Case Study: 栽培管理アプリ（Cultivation Manager）
// Self-contained page — independent from main HP design
import { Image } from 'astro:assets';
import WorksLayout from '../../../layouts/WorksLayout.astro';
import WorksHeader from '../../../components/works/WorksHeader.astro';
import listShot from '../../../assets/images/works/cases/cultivation-app-list.jpg';
import taskShot from '../../../assets/images/works/cases/cultivation-app-task.jpg';
import dashboardShot from '../../../assets/images/works/cases/cultivation-app-dashboard.jpg';
import mobileShot from '../../../assets/images/works/cases/cultivation-app-mobile.jpg';
const siteUrl = 'https://farmeolica.com';
const title = '栽培管理アプリ（Cultivation Manager）制作実績 | Farm Eolica Works';
const description = '自社農園Farm Eolicaのために自社開発し、今も現場で稼働中の栽培管理アプリ。作付けから収穫・出荷まで一元管理し、作業テンプレート自動展開・タスク管理・BigQuery分析連携までを一つのアプリで完結させています。';
const canonical = `${siteUrl}/works/case/cultivation-manager/`;
const ogImage = `${siteUrl}/images/works/cultivation-app-card.jpg`;
---

<WorksLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogType="article" twitterCard="summary_large_image" twitterSite="@FarmEolica">

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ 1. HERO ══════════ -->
<section class="cs-hero">
  <div class="wc">
    <div class="cs-hero-top reveal">
      <span class="ph-en">CASE STUDY</span>
      <span class="ph-line"></span>
      <a href="/works/#works" class="cs-back-link">← 実績一覧へ</a>
    </div>

    <div class="cs-tv-badge reveal">
      <span class="cs-tv-dot"></span>
      自社開発・自社農園で稼働中
    </div>

    <h1 class="cs-title reveal">
      栽培管理アプリ
      <span class="cs-title-en">CULTIVATION MANAGER</span>
    </h1>
    <p class="cs-lead reveal">
      自社農園の作業記録をデジタル化するために自分で設計・開発し、今も日々使っているWebアプリです。
    </p>

    <div class="cs-hero-btns reveal">
      <a href="/works/contact" class="btn-filled">同じように作りたい方はこちら</a>
    </div>
  </div>
</section>


<!-- ══════════ 2. 背景・課題 ══════════ -->
<section class="ws" id="background">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">BACKGROUND</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 03</span>
      </div>
      <h2 class="sh-jp">紙とメモ帳の限界。</h2>
    </div>

    <div class="cs-block reveal">
      <p class="cs-body">
        Farm Eolicaは福島県浪江町で花き・農産物を育てる個人経営の農園です。
        作付けの記録、日々の作業内容、収穫・出荷のデータ——これらを長らく紙のメモやその場の記憶に頼って管理していました。
      </p>
      <p class="cs-body">
        繁忙期になるほど記録は後回しになり、「あの作付けはいつ何をやったか」を思い出すのに時間を取られる。
        振り返って経営判断に使おうにも、データが手元に残っていない。そんな課題を自分の手で解決するために作ったのが、この栽培管理アプリです。
      </p>
    </div>

    <div class="cs-facts reveal">
      {[
        { k: '開発主体', v: 'Farm Eolica（自社開発）' },
        { k: '用途', v: '自社農園の作付け・作業・出荷データの一元管理' },
        { k: '稼働状況', v: '現場で日常的に稼働中' },
        { k: '公開状況', v: '社内アプリ（一般非公開）' },
      ].map(f => (
        <div class="cs-fact">
          <div class="cs-fact-k">{f.k}</div>
          <div class="cs-fact-v">{f.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 3. アプローチ・工程 ══════════ -->
<section class="ws ws-alt" id="approach">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">APPROACH</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 03</span>
      </div>
      <h2 class="sh-jp">スマホひとつで、圃場から経営まで。</h2>
    </div>

    <div class="cs-approach-grid">
      <div class="cs-block reveal">
        <p class="cs-body">
          目指したのは「圃場に立ったまま、スマホひとつで記録が完結すること」。
          作付けから収穫・出荷までの全データを一つのWebアプリで一元管理できる構成にしました。
        </p>
        <p class="cs-body">
          さらに、記録して終わりにせず、記録したデータがそのまま次の作業計画やタスクにつながる仕組みを組み込んでいます。
          分析基盤（BigQuery）とも連携させ、蓄積したデータを経営判断に使える形にしています。
        </p>
      </div>

      <div class="cs-approach-list reveal">
        {[
          { n: '01', t: 'スマホでの一元管理', d: '作付けから収穫・出荷まで全データをスマホ一つで記録・閲覧' },
          { n: '02', t: '作業テンプレートの自動展開', d: '作付けに応じた定型作業をテンプレートとして自動で展開' },
          { n: '03', t: 'タスク管理', d: '展開された作業をタスクとして管理し、やり忘れを防止' },
          { n: '04', t: 'BigQuery分析連携', d: '蓄積したデータをBigQueryに連携し、分析・経営判断に活用' },
        ].map(a => (
          <div class="cs-approach-item">
            <div class="cs-approach-no">{a.n}</div>
            <div>
              <div class="cs-approach-t">{a.t}</div>
              <div class="cs-approach-d">{a.d}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 4. できたもの ══════════ -->
<section class="ws" id="result">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">RESULT</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 03</span>
      </div>
      <h2 class="sh-jp">今も、現場で動いています。</h2>
    </div>

    <div class="cs-shots reveal">
      <div class="cs-shot cs-shot-main">
        <div class="ph ph-auto">
          <Image src={listShot} alt="App screenshot — 作付け一覧" class="work-img" widths={[600, 1000, 1400]} sizes="(max-width: 900px) 100vw, 640px" format="webp" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-auto">
          <Image src={taskShot} alt="App screenshot — タスク管理" class="work-img" widths={[400, 700, 1000]} sizes="(max-width: 900px) 50vw, 320px" format="webp" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-auto">
          <Image src={dashboardShot} alt="App screenshot — 分析ダッシュボード" class="work-img" widths={[400, 700, 1000]} sizes="(max-width: 900px) 50vw, 320px" format="webp" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-45">
          <Image src={mobileShot} alt="App screenshot — スマホ画面" class="work-img" widths={[400, 700, 1000]} sizes="(max-width: 900px) 50vw, 320px" format="webp" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>

    <p class="cs-note reveal">
      ※社内で稼働中のため一般公開はしていません（スクリーンショットは順次追加します）。
    </p>
  </div>
</section>


<!-- ══════════ 5. CTA ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          あなたの現場の記録も、<br />
          アプリにできます。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          紙やメモに頼っていた記録を、スマホひとつで完結する仕組みに。<br />
          自社農園で実際に使い続けているからこそ、現場目線でご相談に乗れます。<br />
          まずは60分、お話を聞かせてください。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">まずは相談してみる →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<!-- :root トークン / reset / @keyframes fadeInUp / .reveal / .reveal.visible(24px/.7s) は
     src/styles/works-base.css（WorksLayout経由）に移設済み。以下はページ固有の追加・上書きのみ。 -->
<style is:global>
/* ── Section commons ── */
.wc{max-width:1120px}
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}

.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:0.75rem;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

.ph-en{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}

/* Placeholder */
.ph{
  width:100%;height:100%;
  background:repeating-linear-gradient(135deg,rgba(74,59,50,.06) 0 10px,rgba(74,59,50,.02) 10px 20px);
  border:1px solid var(--hair);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mn);font-size:0.75rem;letter-spacing:.08em;
  color:rgba(74,59,50,.55);text-transform:uppercase;
  text-align:center;padding:16px;
}
.ph-auto{aspect-ratio:16/9}
.ph-45{aspect-ratio:4/5}
.ph:has(.work-img){padding:0}
.work-img{width:100%;height:100%;object-fit:cover;display:block}

/* ── Buttons ── */
.btn-filled,.btn-ghost{
  display:inline-flex;align-items:center;
  padding:13px 22px;
  font-family:var(--dp);font-size:0.75rem;letter-spacing:.22em;
  transition:all .25s;cursor:pointer;
}
.btn-filled{background:var(--m);color:var(--bg);border:1px solid var(--m)}
.btn-filled:hover{background:#253a6b;border-color:#253a6b}
.btn-ghost{background:transparent;color:var(--m);border:1px solid var(--m)}
.btn-ghost:hover{background:rgba(26,39,68,.07)}

/* ── Hero ── */
.cs-hero{padding:56px 60px 60px;background:var(--m);color:var(--bg)}
.cs-hero-top{display:flex;align-items:center;justify-content:space-between;gap:20px;margin-bottom:28px;flex-wrap:wrap}
.cs-back-link{font-family:var(--mn);font-size:0.75rem;letter-spacing:.1em;color:rgba(242,242,240,.65);transition:color .2s}
.cs-back-link:hover{color:var(--a)}

.cs-tv-badge{
  display:inline-flex;align-items:center;gap:10px;
  padding:8px 16px;border:1px solid var(--a);
  font-family:var(--mn);font-size:0.75rem;letter-spacing:.14em;color:var(--a);
  margin-bottom:24px;
}
.cs-tv-dot{width:7px;height:7px;border-radius:50%;background:var(--a);flex-shrink:0}

.cs-title{
  font-family:var(--sr);font-weight:600;font-size:clamp(36px,4.2vw,58px);
  color:var(--bg);margin:0 0 16px;letter-spacing:.04em;line-height:1.3;
  display:flex;flex-direction:column;gap:8px;
}
.cs-title-en{font-family:var(--dp);font-size:0.875rem;letter-spacing:.28em;color:rgba(242,242,240,.6);font-weight:400}
.cs-lead{font-family:var(--sr);font-size:1rem;color:rgba(242,242,240,.78);letter-spacing:.05em;line-height:1.8;margin:0 0 32px;max-width:640px}
.cs-hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.cs-hero-btns .btn-ghost{color:var(--bg);border-color:rgba(242,242,240,.5)}
.cs-hero-btns .btn-ghost:hover{background:rgba(242,242,240,.08)}
.cs-hero-btns .btn-filled{background:var(--a);border-color:var(--a);color:var(--m)}
.cs-hero-btns .btn-filled:hover{background:#c98a45;border-color:#c98a45}

/* ── Content blocks ── */
.cs-block{max-width:760px}
.cs-body{font-size:0.9375rem;line-height:2.1;color:var(--inks);letter-spacing:.03em;margin-bottom:18px}
.cs-body:last-child{margin-bottom:0}

/* ── Facts ── */
.cs-facts{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--hair);border:1px solid var(--hair);margin-top:44px;
}
.cs-fact{background:var(--bg);padding:22px 20px}
.cs-fact-k{font-family:var(--mn);font-size:0.75rem;letter-spacing:.16em;color:var(--a);margin-bottom:10px}
.cs-fact-v{font-size:0.84375rem;line-height:1.8;color:var(--ink)}

/* ── Approach ── */
.cs-approach-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:start}
.cs-approach-list{display:flex;flex-direction:column;gap:24px}
.cs-approach-item{display:flex;gap:18px;border-left:1px solid var(--hair);padding-left:20px}
.cs-approach-no{font-family:var(--dp);font-size:0.8125rem;letter-spacing:.15em;color:var(--a);flex-shrink:0;padding-top:2px}
.cs-approach-t{font-family:var(--sr);font-size:1rem;color:var(--m);letter-spacing:.03em;margin-bottom:6px}
.cs-approach-d{font-size:0.8125rem;line-height:1.8;color:var(--inks)}

/* ── Result shots ── */
.cs-shots{
  display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:18px;
}
.cs-shot-main{grid-row:1/span 1}
.cs-shot .ph{min-height:200px}
.cs-shot-cta{margin-top:32px;display:flex;justify-content:center}
.cs-note{margin-top:28px;font-family:var(--mn);font-size:0.75rem;letter-spacing:.06em;color:var(--inkm);text-align:center}

/* ── Media panel ── */
.cs-media-panel{display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:center}
.cs-tv-badge-lg{padding:10px 18px;font-size:0.75rem;margin-bottom:22px}
.cs-media-body{max-width:520px}

/* ── Contact ── */
.contact-section{padding-bottom:100px}
.contact-panel{
  background:var(--m);color:var(--bg);padding:80px 70px;
  display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center;
}
.contact-label{font-family:var(--dp);font-size:0.75rem;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{
  font-family:var(--sr);font-weight:500;font-size:clamp(30px,3vw,44px);margin:0;
  line-height:1.4;letter-spacing:.04em;color:var(--bg);
}
.contact-body{
  font-size:0.9375rem;line-height:2.1;color:rgba(242,242,240,.8);
  letter-spacing:.04em;margin-bottom:36px;max-width:480px;
}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap}
.contact-btn-primary{
  padding:16px 26px;font-family:var(--dp);font-size:0.8125rem;letter-spacing:.22em;
  background:var(--a);color:var(--m);
  transition:background .25s;
}
.contact-btn-primary:hover{background:#c98a45}

/* ── Footer ── */
.wfooter{
  padding:20px 60px 40px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--hair);
}
.wfooter-back{font-family:var(--dp);font-size:0.75rem;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:0.75rem;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:0.75rem;letter-spacing:.18em;color:var(--inkm)}

/* ── Responsive ── */
@media (max-width: 1024px){
  .cs-hero{padding:40px 24px 44px}
  .ws{padding:56px 24px 64px}
  .cs-approach-grid{grid-template-columns:1fr;gap:36px}
  .cs-facts{grid-template-columns:1fr 1fr}
  .cs-shots{grid-template-columns:1fr}
  .cs-media-panel{grid-template-columns:1fr;gap:28px}
  .contact-panel{grid-template-columns:1fr;padding:48px 28px;gap:32px}
  .wfooter{flex-direction:column;gap:16px;padding:24px 24px 32px;text-align:center}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');
      io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  setTimeout(function(){
    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible')});
  },60);
  els.forEach(function(el){io.observe(el)});
})();
</script>

</WorksLayout>
