---
// Farm Eolica Works — Case Study: 地域の酒蔵のストーリーLP（匿名コンセプトモック）
// Self-contained page — independent from main HP design
import { SITE_CONFIG } from '../../../config/site';
import WorksHeader from '../../../components/works/WorksHeader.astro';
const ga4Id = SITE_CONFIG.seo.ga4Id;
const siteUrl = 'https://farmeolica.com';
const title = '地域の酒蔵のストーリーLP（匿名コンセプトモック）| Farm Eolica Works';
const description = '実在の特定の酒蔵ではなく、地域の酒蔵の魅力を国内外へ伝えるために制作した、架空・匿名のコンセプトモック。マガジン型レイアウト×日英バイリンガルのストーリーLP制作実績。';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="canonical" href={`${siteUrl}/works/case/regional-sake-brewery/`} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={`${siteUrl}/works/case/regional-sake-brewery/`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={`${siteUrl}/images/about/hero.webp`} />
  <meta name="twitter:site" content="@FarmEolica" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
  <script define:vars={{ ga4Id }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', ga4Id);
  </script>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<WorksHeader />


<!-- ══════════ 1. HERO ══════════ -->
<section class="cs-hero">
  <div class="wc">
    <div class="cs-hero-top reveal">
      <span class="ph-en">CASE STUDY</span>
      <span class="ph-line"></span>
      <a href="/works/#works" class="cs-back-link">← 実績一覧へ</a>
    </div>

    <div class="cs-tv-badge reveal">
      <span class="cs-tv-dot"></span>
      架空・匿名のコンセプトモック
    </div>

    <h1 class="cs-title reveal">
      地域の酒蔵のストーリーLP
      <span class="cs-title-en">ANONYMOUS CONCEPT MOCK</span>
    </h1>
    <p class="cs-lead reveal">
      実在の特定の酒蔵ではなく、地域の酒蔵の魅力を国内外へ伝えるために制作した、匿名のコンセプトモックです。
    </p>

    <div class="cs-hero-btns reveal">
      <a href="/works/contact" class="btn-filled">同じように作りたい方はこちら →</a>
    </div>
  </div>
</section>


<!-- ══════════ 2. 背景・コンセプト ══════════ -->
<section class="ws" id="background">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">BACKGROUND</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 01 / 03</span>
      </div>
      <h2 class="sh-jp">商品ではなく、物語を届ける。</h2>
    </div>

    <div class="cs-block reveal">
      <p class="cs-body">
        地域には、長い歴史を持つ酒蔵が数多くあります。どの蔵にも、そこでしか語れない歴史と、造り手の想いがあります。
      </p>
      <p class="cs-body">
        けれど、多くの酒蔵のWebサイトは商品カタログにとどまりがちで、その物語まで届けきれていません。
        このコンセプトモックは、困難を乗り越えて醸造を続けてきた地域の酒蔵を題材に、「商品ページ」ではなく「読み物」として、その物語を国内外の読み手に届けるためのアイデアです。
      </p>
    </div>

    <div class="cs-facts reveal">
      {[
        { k: '対象', v: '地域の酒蔵（架空・匿名のコンセプトモック）' },
        { k: '想定読者', v: '国内外の酒好き・地域ファン（インバウンド想定）' },
        { k: '構成', v: 'トップLP＋独立ページ4本（物語／マリアージュ／レシピ／アクセス）' },
        { k: '言語', v: '日本語・英語バイリンガル（言語トグル）' },
      ].map(f => (
        <div class="cs-fact">
          <div class="cs-fact-k">{f.k}</div>
          <div class="cs-fact-v">{f.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ 3. アプローチ・工程 ══════════ -->
<section class="ws ws-alt" id="approach">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">APPROACH</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 02 / 03</span>
      </div>
      <h2 class="sh-jp">雑誌のような、読み物の構成に。</h2>
    </div>

    <div class="cs-approach-grid">
      <div class="cs-block reveal">
        <p class="cs-body">
          このコンセプトモックで大切にしたのは、「酒蔵の商品ページ」ではなく「酒蔵を巡る読み物」として作ることです。
          地域の酒蔵の歴史や、造り手の想いを、雑誌のような誌面でじっくり届ける構成を考えました。
        </p>
        <p class="cs-body">
          国内外どちらの読み手にも同じ物語が届くよう、日英バイリンガル対応（言語トグル）を前提に設計しています。
        </p>
        <p class="cs-body">
          トップのLPで世界観を伝えたあと、「酒蔵の物語」「料理とのマリアージュ」「レシピ×ペアリング」「アクセス」という4つの独立ページへ読み進められる構成にしました。
        </p>
      </div>

      <div class="cs-approach-list reveal">
        {[
          { n: '01', t: 'マガジン型レイアウト', d: '商品訴求ではなく「読み物」として楽しめる誌面構成' },
          { n: '02', t: '日英バイリンガル', d: '言語トグルで国内外の読み手に同じ物語を届ける' },
          { n: '03', t: 'トップLP＋独立ページ構成', d: '酒蔵の物語／マリアージュ／レシピ×ペアリング／アクセスの4ページ' },
          { n: '04', t: 'Astro静的サイト', d: '軽量・高速・保守しやすい構成を想定' },
        ].map(a => (
          <div class="cs-approach-item">
            <div class="cs-approach-no">{a.n}</div>
            <div>
              <div class="cs-approach-t">{a.t}</div>
              <div class="cs-approach-d">{a.d}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ══════════ 4. できたもの ══════════ -->
<section class="ws" id="result">
  <div class="wc">
    <div class="sh reveal">
      <div class="sh-top">
        <span class="sh-en">RESULT</span>
        <span class="sh-line"></span>
        <span class="sh-no">— 03 / 03</span>
      </div>
      <h2 class="sh-jp">描いた、誌面のイメージ。</h2>
    </div>

    <div class="cs-shots reveal">
      <div class="cs-shot cs-shot-main">
        <div class="ph ph-auto">Mockup — トップLP</div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-45">Mockup — 酒蔵の物語ページ</div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-45">Mockup — マリアージュページ</div>
      </div>
      <div class="cs-shot">
        <div class="ph ph-45">Mockup — レシピページ</div>
      </div>
    </div>

    <div class="cs-shot-cta reveal">
      <p class="cs-body" style="text-align:center;margin:0;">※匿名のコンセプトモックのため公開サイトはありません（画面は制作イメージです）。</p>
    </div>
  </div>
</section>


<!-- ══════════ 5. CTA ══════════ -->
<section class="ws contact-section" id="contact">
  <div class="wc">
    <div class="contact-panel reveal">
      <div class="contact-left">
        <div class="contact-label">— CONTACT</div>
        <h2 class="contact-title">
          あなたのお店の物語も、<br />
          こんなふうに。
        </h2>
      </div>
      <div class="contact-right">
        <p class="contact-body">
          「伝えたいことはあるけれど、うまく形にできない」——<br />
          そんなお店・商品のストーリーを、一緒にページにします。<br />
          まずは60分、お話を聞かせてください。
        </p>
        <div class="contact-btns">
          <a href="/works/contact" class="contact-btn-primary">まずは相談してみる →</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════ FOOTER ══════════ -->
<footer class="wfooter">
  <a href="/works/" class="wfooter-back">← BACK TO WORKS</a>
  <nav class="wfooter-legal">
    <a href="/works/tokushoho">特定商取引法に基づく表記</a>
    <a href="/works/terms">利用規約</a>
    <a href="/works/privacy">プライバシーポリシー</a>
  </nav>
  <div class="wfooter-copy">&copy; FARM EOLICA WORKS / 福島県浪江町 / 関口卓磨</div>
</footer>


<!-- ══════════ STYLES ══════════ -->
<style is:global>
:root {
  --m: #1A2744;
  --a: #B87333;
  --bg: #F2F2F0;
  --ink: #4A3B32;
  --inks: rgba(74,59,50,0.72);
  --inkm: rgba(74,59,50,0.48);
  --hair: rgba(74,59,50,0.14);
  --sr: 'Shippori Mincho','Hiragino Mincho ProN',serif;
  --dp: 'Cinzel',serif;
  --mn: 'JetBrains Mono','Courier New',monospace;
}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sr);-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
p{margin:0}

@keyframes fadeInUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(24px)}
.reveal.visible{animation:fadeInUp .7s cubic-bezier(.22,1,.36,1) forwards}

/* ── Section commons ── */
.wc{max-width:1120px;margin:0 auto}
.ws{padding:80px 60px 100px}
.ws-alt{background:#EAE6DF}

.sh{margin-bottom:56px}
.sh-top{display:flex;align-items:baseline;gap:22px;margin-bottom:18px}
.sh-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.sh-line{display:inline-block;width:56px;height:1px;background:var(--a);vertical-align:middle}
.sh-no{font-family:var(--mn);font-size:10px;letter-spacing:.2em;color:var(--inkm)}
.sh-jp{font-family:var(--sr);font-weight:500;font-size:clamp(32px,3vw,48px);color:var(--m);margin:0;letter-spacing:.04em;line-height:1.2}

.ph-en{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a)}
.ph-line{display:inline-block;width:56px;height:1px;background:var(--a)}

/* Placeholder */
.ph{
  width:100%;height:100%;
  background:repeating-linear-gradient(135deg,rgba(74,59,50,.06) 0 10px,rgba(74,59,50,.02) 10px 20px);
  border:1px solid var(--hair);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mn);font-size:11px;letter-spacing:.08em;
  color:rgba(74,59,50,.55);text-transform:uppercase;
  text-align:center;padding:16px;
}
.ph-auto{aspect-ratio:16/9}
.ph-45{aspect-ratio:4/5}

/* ── Buttons ── */
.btn-filled,.btn-ghost{
  display:inline-flex;align-items:center;
  padding:13px 22px;
  font-family:var(--dp);font-size:12px;letter-spacing:.22em;
  transition:all .25s;cursor:pointer;
}
.btn-filled{background:var(--m);color:var(--bg);border:1px solid var(--m)}
.btn-filled:hover{background:#253a6b;border-color:#253a6b}
.btn-ghost{background:transparent;color:var(--m);border:1px solid var(--m)}
.btn-ghost:hover{background:rgba(26,39,68,.07)}

/* ── Hero ── */
.cs-hero{padding:56px 60px 60px;background:var(--m);color:var(--bg)}
.cs-hero-top{display:flex;align-items:center;justify-content:space-between;gap:20px;margin-bottom:28px;flex-wrap:wrap}
.cs-back-link{font-family:var(--mn);font-size:11px;letter-spacing:.1em;color:rgba(242,242,240,.65);transition:color .2s}
.cs-back-link:hover{color:var(--a)}

.cs-tv-badge{
  display:inline-flex;align-items:center;gap:10px;
  padding:8px 16px;border:1px solid var(--a);
  font-family:var(--mn);font-size:11px;letter-spacing:.14em;color:var(--a);
  margin-bottom:24px;
}
.cs-tv-dot{width:7px;height:7px;border-radius:50%;background:var(--a);flex-shrink:0}

.cs-title{
  font-family:var(--sr);font-weight:600;font-size:clamp(36px,4.2vw,58px);
  color:var(--bg);margin:0 0 16px;letter-spacing:.04em;line-height:1.3;
  display:flex;flex-direction:column;gap:8px;
}
.cs-title-en{font-family:var(--dp);font-size:14px;letter-spacing:.28em;color:rgba(242,242,240,.6);font-weight:400}
.cs-lead{font-family:var(--sr);font-size:16px;color:rgba(242,242,240,.78);letter-spacing:.05em;line-height:1.8;margin:0 0 32px;max-width:640px}
.cs-hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.cs-hero-btns .btn-ghost{color:var(--bg);border-color:rgba(242,242,240,.5)}
.cs-hero-btns .btn-ghost:hover{background:rgba(242,242,240,.08)}
.cs-hero-btns .btn-filled{background:var(--a);border-color:var(--a);color:var(--m)}
.cs-hero-btns .btn-filled:hover{background:#c98a45;border-color:#c98a45}

/* ── Content blocks ── */
.cs-block{max-width:760px}
.cs-body{font-size:15px;line-height:2.1;color:var(--inks);letter-spacing:.03em;margin-bottom:18px}
.cs-body:last-child{margin-bottom:0}

/* ── Facts ── */
.cs-facts{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--hair);border:1px solid var(--hair);margin-top:44px;
}
.cs-fact{background:var(--bg);padding:22px 20px}
.cs-fact-k{font-family:var(--mn);font-size:10px;letter-spacing:.16em;color:var(--a);margin-bottom:10px}
.cs-fact-v{font-size:13.5px;line-height:1.8;color:var(--ink)}

/* ── Approach ── */
.cs-approach-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:start}
.cs-approach-list{display:flex;flex-direction:column;gap:24px}
.cs-approach-item{display:flex;gap:18px;border-left:1px solid var(--hair);padding-left:20px}
.cs-approach-no{font-family:var(--dp);font-size:13px;letter-spacing:.15em;color:var(--a);flex-shrink:0;padding-top:2px}
.cs-approach-t{font-family:var(--sr);font-size:16px;color:var(--m);letter-spacing:.03em;margin-bottom:6px}
.cs-approach-d{font-size:13px;line-height:1.8;color:var(--inks)}

/* ── Result shots ── */
.cs-shots{
  display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:18px;
}
.cs-shot-main{grid-row:1/span 1}
.cs-shot .ph{min-height:200px}
.cs-shot-cta{margin-top:32px;display:flex;justify-content:center}

/* ── Media panel ── */
.cs-media-panel{display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:center}
.cs-tv-badge-lg{padding:10px 18px;font-size:12px;margin-bottom:22px}
.cs-media-body{max-width:520px}

/* ── Contact ── */
.contact-section{padding-bottom:100px}
.contact-panel{
  background:var(--m);color:var(--bg);padding:80px 70px;
  display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center;
}
.contact-label{font-family:var(--dp);font-size:11px;letter-spacing:.4em;color:var(--a);margin-bottom:20px}
.contact-title{
  font-family:var(--sr);font-weight:500;font-size:clamp(30px,3vw,44px);margin:0;
  line-height:1.4;letter-spacing:.04em;color:var(--bg);
}
.contact-body{
  font-size:15px;line-height:2.1;color:rgba(242,242,240,.8);
  letter-spacing:.04em;margin-bottom:36px;max-width:480px;
}
.contact-btns{display:flex;gap:16px;flex-wrap:wrap}
.contact-btn-primary{
  padding:16px 26px;font-family:var(--dp);font-size:13px;letter-spacing:.22em;
  background:var(--a);color:var(--m);
  transition:background .25s;
}
.contact-btn-primary:hover{background:#c98a45}

/* ── Footer ── */
.wfooter{
  padding:20px 60px 40px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--hair);
}
.wfooter-back{font-family:var(--dp);font-size:12px;letter-spacing:.25em;color:var(--m);transition:color .2s}
.wfooter-back:hover{color:var(--a)}
.wfooter-legal{display:flex;gap:22px;flex-wrap:wrap}
.wfooter-legal a{font-family:var(--mn);font-size:10px;letter-spacing:.12em;color:var(--inkm);transition:color .2s}
.wfooter-legal a:hover{color:var(--a)}
.wfooter-copy{font-family:var(--mn);font-size:10px;letter-spacing:.18em;color:var(--inkm)}

/* ── Responsive ── */
@media (max-width: 900px){
  .cs-hero{padding:40px 24px 44px}
  .ws{padding:56px 24px 64px}
  .cs-approach-grid{grid-template-columns:1fr;gap:36px}
  .cs-facts{grid-template-columns:1fr 1fr}
  .cs-shots{grid-template-columns:1fr}
  .cs-media-panel{grid-template-columns:1fr;gap:28px}
  .contact-panel{grid-template-columns:1fr;padding:48px 28px;gap:32px}
  .wfooter{flex-direction:column;gap:16px;padding:24px 24px 32px;text-align:center}
}
</style>


<!-- ══════════ SCRIPTS ══════════ -->
<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){
    els.forEach(function(el){el.classList.add('visible')});return;
  }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      e.target.classList.add('visible');
      io.unobserve(e.target);
    });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  setTimeout(function(){
    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible')});
  },60);
  els.forEach(function(el){io.observe(el)});
})();
</script>

</body>
</html>
