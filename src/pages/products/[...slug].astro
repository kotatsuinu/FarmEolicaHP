---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { SITE_CONFIG } from '../../config/site';

import EstimateCalculator from '../../components/products/EstimateCalculator';
import QuantityEstimateCalculator from '../../components/products/QuantityEstimateCalculator';
import QualityGradeTabs from '../../components/products/QualityGradeTabs';
import { ProductGalleryHero, ProductGalleryGrid } from '../../components/products/ProductGallery';
import ProductSchema from '../../components/seo/ProductSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { Content } = await product.render();

// カテゴリの日本語表示
const categoryLabels = {
  loss_flower: 'ロスフラワー',
  imperfect: '規格外切り花',
  market: '市場出荷品',
  dried_flower: 'ドライフラワー',
};

// カテゴリの戻り先URL
const categoryBackLinks = {
  loss_flower: '/products/loss-flower',
  imperfect: '/products/imperfect',
  market: '/products/market',
  dried_flower: '/products/dry-flower',
};

// 季節の日本語表示
const seasonLabels = {
  spring: '春',
  summer: '夏',
  autumn: '秋',
  winter: '冬',
};

// カテゴリ判定
const isLossFlower = product.data.category === 'loss_flower';
const isImperfect = product.data.category === 'imperfect';
const isMarket = product.data.category === 'market';
const isDriedFlower = product.data.category === 'dried_flower';
// ドライフラワーのうち、ロングステムは宅配便（80サイズ）配送
// ヘッドはクリックポスト全国一律
const isLongStem = isDriedFlower && product.data.tags?.includes('ロングステム');
const isDriedHead = isDriedFlower && !isLongStem;

// 販売中かどうか
const isAvailable = product.data.saleStatus === 'available';
const isDiscontinued = product.data.saleStatus === 'discontinued';

// 戻り先URL
const backUrl = categoryBackLinks[product.data.category] || '/products';

// 本数ベース見積もり（規格外品: priceTiers + boxCapacity がある場合）
const hasQuantityPricing = product.data.priceTiers && product.data.boxCapacity;

// レガシー見積もりオプション（ロスフラワー等: priceTable ベース）
let estimateOptions = [];
if (!hasQuantityPricing) {
  if (product.data.priceTable) {
    estimateOptions = product.data.priceTable.map((p: any) => {
      // ロングステムは80サイズ固定、それ以外はラベルから数字抽出
      let size: number;
      if (isLongStem) {
        size = 80;
      } else {
        const sizeMatch = p.size.toString().match(/\d+/);
        size = sizeMatch ? parseInt(sizeMatch[0]) : 100;
      }
      return {
        label: `${p.size}（${p.quantity}）`,
        price: p.price,
        size: size
      };
    });
  } else if (product.data.price) {
    estimateOptions = [{
      label: '標準サイズ',
      price: product.data.price,
      size: 100
    }];
  } else if (isLossFlower) {
    estimateOptions = [
      { label: '小箱（60サイズ）', price: 1300, size: 60 },
      { label: '中箱（80サイズ）', price: 2000, size: 80 },
      { label: '大箱（100サイズ）', price: 3200, size: 100 }
    ];
  }
}

// メイン画像とギャラリー画像を1配列に集約 (スライドショー & ライトボックス共通)
const combinedImages: { src: string; width?: number; height?: number }[] = [];
if (product.data.image) {
  combinedImages.push({
    src: product.data.image.src,
    width: product.data.image.width,
    height: product.data.image.height,
  });
}
if (product.data.gallery && product.data.gallery.length > 0) {
  for (const img of product.data.gallery) {
    combinedImages.push({ src: img.src, width: img.width, height: img.height });
  }
}
---

<Layout title={`${product.data.flowerType} | Farm Eolica`} description={product.data.description} image={product.data.image?.src}>
  <ProductSchema
    name={product.data.name}
    description={product.data.description}
    image={product.data.image?.src}
    category={categoryLabels[product.data.category] || product.data.category}
    saleStatus={product.data.saleStatus}
    url={Astro.url.pathname}
    price={product.data.price}
    priceTiers={product.data.priceTiers}
    boxPricing={product.data.priceTable}
    flowerType={product.data.flowerType}
  />
  <BreadcrumbSchema items={[
    { name: 'ホーム', url: '/' },
    { name: categoryLabels[product.data.category] || '商品', url: backUrl },
    { name: product.data.flowerType || product.data.name, url: Astro.url.pathname },
  ]} />
  <div class="pt-32 pb-24 min-h-screen">
    <!-- Breadcrumb (Top) -->
    <div class="max-w-7xl mx-auto px-6 lg:px-12 mb-6">
      <Breadcrumb items={[
        { name: 'ホーム', url: '/' },
        { name: '商品', url: '/products' },
        { name: categoryLabels[product.data.category] || '商品', url: backUrl },
        { name: product.data.flowerType || product.data.name },
      ]} />
    </div>

    <!-- Hero Image Section -->
    <section class="mb-16" data-animate>
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <!-- Main Image (Slideshow + Lightbox) -->
          <ProductGalleryHero
            client:visible
            images={combinedImages}
            productName={product.data.flowerType || product.data.name}
            isDiscontinued={isDiscontinued}
          />

          <!-- Product Info -->
          <div class="lg:sticky lg:top-32">
            <div class="mb-6">
              <!-- Category Badge (目立つ形式) -->
              <div class="mb-4 flex items-center gap-3">
                <span class:list={[
                  "inline-block px-4 py-2 font-mono text-xs tracking-widest",
                  isLossFlower && "bg-old-copper/10 text-old-copper border border-old-copper/30",
                  isImperfect && "bg-eolica-green/10 text-eolica-green border border-eolica-green/30",
                  isMarket && "bg-wet-soil/10 text-wet-soil border border-wet-soil/30",
                  isDriedFlower && "bg-dried-gold/10 text-dried-gold border border-dried-gold/30",
                  !isLossFlower && !isImperfect && !isMarket && !isDriedFlower && "bg-warm-gray-100 text-warm-gray-600"
                ]}>
                  {categoryLabels[product.data.category]}
                </span>
                {/* 作付番号（Cultivation Manager連携） */}
                {product.data.cultivationNo && (
                  <span class="font-mono text-xs tracking-widest text-warm-gray-500">
                    No.{product.data.cultivationNo}
                  </span>
                )}
              </div>

              <!-- Product Title (カテゴリ名は除去済み) -->
              <h1 class:list={[
                "font-serif text-3xl md:text-4xl mb-4 leading-tight",
                isDiscontinued ? "text-warm-gray-500" : "text-dark-slate"
              ]}>
                {product.data.flowerType}
              </h1>

              {/* 出荷終了バッジ（市場出荷品） / 販売終了バッジ（その他） */}
              {isDiscontinued && (
                <div class="mb-4">
                  <span class="inline-block px-4 py-2 bg-warm-gray-300 text-warm-gray-600 font-mono text-xs tracking-widest">
                    {isMarket ? '出荷終了' : '販売終了'}
                  </span>
                </div>
              )}

              <p class="text-base text-warm-gray-600 leading-relaxed mb-6">
                {product.data.description}
              </p>
            </div>

            <!-- Price for Loss Flower -->
            {isLossFlower && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <h3 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
                  PRICE <span class="font-serif">ー価格（税込・送料別）ー</span>
                </h3>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-warm-gray-200">
                        <th class="text-left py-2 font-mono text-xs text-warm-gray-500">サイズ</th>
                        <th class="text-center py-2 font-mono text-xs text-warm-gray-500">本数目安</th>
                        <th class="text-right py-2 font-mono text-xs text-warm-gray-500">価格</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr class="border-b border-warm-gray-100">
                        <td class="py-3 font-serif text-wet-soil">小箱（60サイズ）</td>
                        <td class="py-3 text-center font-mono text-xs text-warm-gray-600">約80輪</td>
                        <td class="py-3 text-right">
                          <span class="font-mono text-old-copper font-medium">¥1,300</span>
                          <span class="block text-xs text-warm-gray-500">個人クラフト・撮影に</span>
                        </td>
                      </tr>
                      <tr class="border-b border-warm-gray-100">
                        <td class="py-3 font-serif text-wet-soil">中箱（80サイズ）</td>
                        <td class="py-3 text-center font-mono text-xs text-warm-gray-600">約160輪</td>
                        <td class="py-3 text-right">
                          <span class="font-mono text-old-copper font-medium">¥2,000</span>
                          <span class="block text-xs text-warm-gray-500">中規模アレンジに</span>
                        </td>
                      </tr>
                      <tr>
                        <td class="py-3 font-serif text-wet-soil">大箱（100サイズ）</td>
                        <td class="py-3 text-center font-mono text-xs text-warm-gray-600">約320輪</td>
                        <td class="py-3 text-right">
                          <span class="font-mono text-old-copper font-medium">¥3,200</span>
                          <span class="block text-xs text-eolica-green">単価18%お得</span>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <p class="text-xs text-warm-gray-500 mt-4">
                  ※税込・送料別です。下記の見積もりフォームで都道府県別の送料が確認できます。<br />
                  ※目安数量はトルコキキョウの花頭換算のため、ストックなど花の種類によって数量は前後します。<br />
                  詳しくは<a href="/products/loss-flower" class="text-old-copper hover:underline">ロスフラワーページ</a>もご確認ください。
                </p>
              </div>
            )}

            <!-- Price Tiers for Imperfect (本数ベース単価表) -->
            {isImperfect && product.data.priceTiers && product.data.priceTiers.length > 0 && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <h3 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
                  PRICE <span class="font-serif">ー単価表（税込・送料別）ー</span>
                </h3>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-warm-gray-200">
                        <th class="text-left py-2 font-mono text-xs text-warm-gray-500">ご注文本数</th>
                        <th class="text-right py-2 font-mono text-xs text-warm-gray-500">単価（税込）</th>
                      </tr>
                    </thead>
                    <tbody>
                      {product.data.priceTiers
                        .sort((a: {minQuantity: number}, b: {minQuantity: number}) => a.minQuantity - b.minQuantity)
                        .map((tier: { minQuantity: number; unitPrice: number }, index: number) => {
                          const nextTier = product.data.priceTiers
                            .sort((a: {minQuantity: number}, b: {minQuantity: number}) => a.minQuantity - b.minQuantity)[index + 1];
                          const rangeLabel = nextTier
                            ? `${tier.minQuantity}〜${nextTier.minQuantity - 1}${product.data.unit}`
                            : `${tier.minQuantity}${product.data.unit}〜`;
                          const isLowest = index === product.data.priceTiers.length - 1;
                          return (
                            <tr class:list={[
                              "border-b border-warm-gray-100",
                              index === product.data.priceTiers.length - 1 && "border-b-0"
                            ]}>
                              <td class="py-3 font-serif text-wet-soil">{rangeLabel}</td>
                              <td class="py-3 text-right">
                                <span class="font-mono text-old-copper font-medium">¥{tier.unitPrice}/{product.data.unit}</span>
                                {isLowest && product.data.priceTiers.length > 1 && (
                                  <span class="block text-xs text-eolica-green">まとめ買いがお得</span>
                                )}
                              </td>
                            </tr>
                          );
                        })}
                    </tbody>
                  </table>
                </div>

                {/* ダンボールサイズ容量ガイド */}
                {product.data.boxCapacity && product.data.boxCapacity.length > 0 && (
                  <div class="mt-4 pt-4 border-t border-warm-gray-200">
                    <p class="font-mono text-xs text-warm-gray-500 mb-2">BOX SIZE GUIDE</p>
                    <div class="flex flex-wrap gap-3">
                      {product.data.boxCapacity.map((box: { size: string; maxStems: number; maxLength?: number }) => (
                        <span class="inline-block px-3 py-1.5 bg-warm-gray-50 border border-warm-gray-200 text-xs font-serif text-warm-gray-600">
                          {box.size}: {box.maxLength ? `${box.maxLength}cm` : ''}{box.maxLength ? '・' : ''}目安 {box.maxStems}{product.data.unit}まで
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                <div class="mt-4 pt-4 border-t border-warm-gray-200 space-y-2">
                  <p class="text-xs text-warm-gray-500">
                    ※規格外品の特性上、品質が一定でない場合があります。<br />
                    細い・弱いなどの場合は多めに入れるなどで対応いたします。
                  </p>
                  <p class="text-xs text-warm-gray-500">
                    ※ご要望があれば事前にお知らせください。できる限り対応いたします。
                  </p>
                </div>
              </div>
            )}

            <!-- Legacy Price Table for Imperfect (旧サイズベース: priceTableのみの場合) -->
            {isImperfect && !product.data.priceTiers && product.data.priceTable && product.data.priceTable.length > 0 && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <h3 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
                  PRICE TABLE <span class="font-serif">ー価格表（税込・送料別）ー</span>
                </h3>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-warm-gray-200">
                        <th class="text-left py-2 font-mono text-xs text-warm-gray-500">サイズ</th>
                        <th class="text-center py-2 font-mono text-xs text-warm-gray-500">本数目安</th>
                        <th class="text-center py-2 font-mono text-xs text-warm-gray-500">切花長</th>
                        <th class="text-right py-2 font-mono text-xs text-warm-gray-500">価格</th>
                      </tr>
                    </thead>
                    <tbody>
                      {product.data.priceTable.map((item: { size: string; quantity: string; price: number; stemLength?: string; note?: string }, index: number) => (
                        <tr class:list={[
                          "border-b border-warm-gray-100",
                          index === product.data.priceTable.length - 1 && "border-b-0"
                        ]}>
                          <td class="py-3 font-serif text-wet-soil">{item.size}</td>
                          <td class="py-3 text-center font-mono text-xs text-warm-gray-600">{item.quantity}</td>
                          <td class="py-3 text-center font-mono text-xs text-warm-gray-600">{item.stemLength || '-'}</td>
                          <td class="py-3 text-right">
                            <span class="font-mono text-old-copper font-medium">¥{item.price.toLocaleString()}</span>
                            {item.note && (
                              <span class="block text-xs text-eolica-green">{item.note}</span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- Price Table for Dried Flower (ヘッドはクリックポスト / ロングステムは宅配便80サイズ) -->
            {isDriedFlower && product.data.priceTable && product.data.priceTable.length > 0 && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <h3 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
                  PRICE <span class="font-serif">ー価格（税込・送料別）ー</span>
                </h3>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-warm-gray-200">
                        <th class="text-left py-2 font-mono text-xs text-warm-gray-500">サイズ</th>
                        <th class="text-center py-2 font-mono text-xs text-warm-gray-500">内容</th>
                        {isLongStem && (
                          <th class="text-center py-2 font-mono text-xs text-warm-gray-500">茎長</th>
                        )}
                        <th class="text-right py-2 font-mono text-xs text-warm-gray-500">価格</th>
                      </tr>
                    </thead>
                    <tbody>
                      {product.data.priceTable.map((item: { size: string; quantity: string; price: number; stemLength?: string; note?: string }, index: number) => (
                        <tr class:list={[
                          "border-b border-warm-gray-100",
                          index === product.data.priceTable.length - 1 && "border-b-0"
                        ]}>
                          <td class="py-3 font-serif text-wet-soil">{item.size}</td>
                          <td class="py-3 text-center font-mono text-xs text-warm-gray-600">{item.quantity}</td>
                          {isLongStem && (
                            <td class="py-3 text-center font-mono text-xs text-warm-gray-600">{item.stemLength || '-'}</td>
                          )}
                          <td class="py-3 text-right">
                            <span class="font-mono text-dried-gold font-medium">¥{item.price.toLocaleString()}</span>
                            {item.note && (
                              <span class="block text-xs text-warm-gray-500">{item.note}</span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <div class="mt-4 pt-4 border-t border-warm-gray-200">
                  <p class="font-mono text-[10px] tracking-widest text-dried-gold mb-2">SHIPPING</p>
                  {isLongStem ? (
                    <>
                      <p class="text-sm font-serif text-warm-gray-700">
                        送料: <span class="font-mono text-dried-gold">宅配便80サイズ・地域別運賃（佐川急便）</span>
                      </p>
                      <ul class="mt-2 space-y-1 text-xs text-warm-gray-500 font-serif">
                        <li>・茎付きで厚みがあるためクリックポスト対象外</li>
                        <li>・茎長30cmで切り揃え、緩衝材で花と茎を保護してダンボール梱包</li>
                        <li>・日時指定可能／追跡番号付き</li>
                        <li>・下記の見積もりフォームで都道府県別の送料が確認できます</li>
                      </ul>
                    </>
                  ) : (
                    <>
                      <p class="text-sm font-serif text-warm-gray-700">
                        送料: <span class="font-mono text-dried-gold">クリックポスト 全国一律 ¥185</span>
                      </p>
                      <ul class="mt-2 space-y-1 text-xs text-warm-gray-500 font-serif">
                        <li>・厚さ3cmまでのハードケースで発送</li>
                        <li>・お受け取り時のご在宅不要（郵便ポストへ投函）</li>
                        <li>・追跡番号付き／到着日時の指定はできません</li>
                      </ul>
                    </>
                  )}
                </div>
              </div>
            )}

            <!-- Price for other categories (market除外) -->
            {!isLossFlower && !isImperfect && !isMarket && !isDriedFlower && product.data.price && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <div class="flex items-baseline gap-2 mb-2">
                  <p class="font-mono text-3xl text-rust">
                    ¥{product.data.price.toLocaleString()}
                  </p>
                  <span class="text-warm-gray-500 font-mono text-sm">/ {product.data.unit}</span>
                </div>
              </div>
            )}

            <!-- Specs -->
            <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
              <h3 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
                SPECIFICATIONS
              </h3>
              <dl class="space-y-3 text-sm">
                {product.data.flowerType && (
                  <div class="flex justify-between border-b border-warm-gray-200 pb-2">
                    <dt class="text-warm-gray-500 font-mono">品目</dt>
                    <dd class="text-dark-slate font-serif">{product.data.flowerType}</dd>
                  </div>
                )}
                {product.data.varieties && product.data.varieties.length > 0 && (
                  <div class="flex justify-between border-b border-warm-gray-200 pb-2">
                    <dt class="text-warm-gray-500 font-mono">品種</dt>
                    <dd class="text-dark-slate font-serif text-right">{product.data.varieties.join('、')}</dd>
                  </div>
                )}
                {product.data.spec?.color && (
                  <div class="flex justify-between border-b border-warm-gray-200 pb-2">
                    <dt class="text-warm-gray-500 font-mono">カラー</dt>
                    <dd class="text-dark-slate font-serif">{product.data.spec.color}</dd>
                  </div>
                )}
                {product.data.availableSeason && (
                  <div class="flex justify-between border-b border-warm-gray-200 pb-2">
                    <dt class="text-warm-gray-500 font-mono">発送時期</dt>
                    <dd class="text-dark-slate font-serif">{product.data.availableSeason}</dd>
                  </div>
                )}
                {product.data.season && product.data.season.length > 0 && !product.data.availableSeason && (
                  <div class="flex justify-between border-b border-warm-gray-200 pb-2">
                    <dt class="text-warm-gray-500 font-mono">旬の季節</dt>
                    <dd class="text-dark-slate font-serif">
                      {product.data.season.map(s => seasonLabels[s]).join('・')}
                    </dd>
                  </div>
                )}
              </dl>
            </div>

            {/* Estimate Calculator - 本数ベース（規格外品の新モデル） */}
            {hasQuantityPricing && isAvailable && (
              <div class="mb-8">
                <QuantityEstimateCalculator
                  client:visible
                  priceTiers={product.data.priceTiers}
                  boxOptions={product.data.boxCapacity}
                  unit={product.data.unit}
                  defaultCool={false}
                  productName={product.data.flowerType || product.data.name}
                />
              </div>
            )}

            {/* Estimate Calculator
                - ヘッド/ロスフラワー: clickpost モード（全国一律・クール便無し）
                - ロングステム: standard モード（宅配便80サイズ・都道府県別、ドライ品なのでクール便無し）
                - 規格外切花: standard モード */}
            {!hasQuantityPricing && estimateOptions.length > 0 && isAvailable && (
              <div class="mb-8">
                <EstimateCalculator
                  client:visible
                  options={estimateOptions}
                  defaultCool={false}
                  productName={product.data.flowerType || product.data.name}
                  shippingMode={isDriedHead ? 'clickpost' : 'standard'}
                  hideCoolOption={isLongStem || isDriedFlower}
                  shippingNote={isLongStem ? '茎長30cmで切り揃え／緩衝材で花と茎を保護してダンボール梱包／日時指定可' : undefined}
                />
              </div>
            )}

            <!-- Market: 出荷ステータス表示 (購入ボタンの代わり) -->
            {isMarket && (
              <div class="bg-stone-white/95 backdrop-blur-sm p-6 shadow-lab-lg mb-6">
                <div class="flex items-center gap-3">
                  <span class:list={[
                    "w-3 h-3 rounded-full",
                    isAvailable ? "bg-eolica-green animate-pulse" : "bg-warm-gray-400"
                  ]} />
                  <span class="font-mono text-sm text-wet-soil">
                    {isAvailable ? '現在出荷中' : isDiscontinued ? '出荷終了' : '出荷準備中'}
                  </span>
                </div>
                {product.data.availableSeason && (
                  <p class="font-mono text-xs text-warm-gray-500 mt-2 ml-6">
                    出荷時期: {product.data.availableSeason}
                  </p>
                )}
                <p class="text-xs text-warm-gray-500 mt-3 ml-6">
                  ※市場経由での販売のため、直接購入はできません。<br />
                  品質の詳細は下記の独自品質規格をご確認ください。
                </p>
              </div>
            )}

            <!-- Purchase Buttons (market以外。見積もり計算機の「この内容で問い合わせる」CTAでフォーム誘導するため、ここはInstaDMのみ) -->
            {!isMarket && isAvailable ? (
              <div class="space-y-4">
                <a
                  href={SITE_CONFIG.sns.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full text-center px-8 py-4 text-xs tracking-widest uppercase font-mono border-2 border-rust hover:bg-rust hover:text-white transition-all duration-300"
                >
                  Instagram DMで購入・問い合わせ
                </a>
              </div>
            ) : !isMarket && (
              <div class="space-y-4">
                <div class="block w-full text-center px-8 py-4 text-xs tracking-widest font-mono border-2 border-warm-gray-300 text-warm-gray-400">
                  {isDiscontinued ? 'この商品の販売は終了しました' : product.data.saleStatus === 'seasonal' ? '出荷準備中（まもなくご案内します）' : '現在販売していません'}
                </div>
                <a
                  href={SITE_CONFIG.sns.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full text-center px-8 py-4 text-xs tracking-widest uppercase font-mono border-2 border-lab-green hover:bg-lab-green hover:text-white transition-all duration-300"
                >
                  他の商品について問い合わせ
                </a>
              </div>
            )}

            {product.data.tags && product.data.tags.length > 0 && (
              <div class="mt-6">
                <div class="flex flex-wrap gap-2">
                  {product.data.tags.map((tag) => (
                    <span class="px-3 py-1 text-xs font-mono bg-warm-gray-100 text-warm-gray-600 rounded-full">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Quality Grades (市場出荷品: ストーリーより先に表示) -->
    {isMarket && product.data.qualityGrades && product.data.qualityGrades.length > 0 && (
      <section class="mb-16" data-animate>
        <div class="max-w-4xl mx-auto px-6 lg:px-12">
          <QualityGradeTabs
            client:visible
            grades={product.data.qualityGrades.map(g => ({
              code: g.code,
              label: g.label,
              description: g.description,
              criteria: g.criteria,
              sampleSrcs: g.samples?.map(s => s.src) || [],
              options: g.options?.map(o => ({
                label: o.label,
                description: o.description,
                sampleSrcs: o.samples?.map(s => s.src) || [],
              })),
            }))}
          />
        </div>
      </section>
    )}

    <!-- Product Story (Markdown Content) -->
    <section class="mb-16" data-animate>
      <div class="max-w-4xl mx-auto px-6 lg:px-12">
        <div class="bg-stone-white/95 backdrop-blur-sm p-8 md:p-12 shadow-lab-lg">
          <div class="prose prose-slate max-w-none
            prose-p:leading-loose prose-p:mb-6 prose-p:text-warm-gray-600
            prose-headings:font-serif prose-headings:text-wet-soil prose-headings:mb-4 prose-headings:mt-8
            prose-strong:text-wet-soil prose-strong:font-medium
            prose-ul:my-4 prose-ul:space-y-2 prose-li:text-warm-gray-600
            prose-hr:my-8 prose-hr:border-warm-gray-200
            first:prose-p:mt-0 last:prose-p:mb-0">
            <Content />
          </div>
        </div>
      </div>
    </section>

    <!-- Feedback CTA (市場出荷品のみ) -->
    {isMarket && (
      <section class="mb-16" data-animate>
        <div class="max-w-4xl mx-auto px-6 lg:px-12">
          <div class="bg-stone-white/95 backdrop-blur-sm p-6 md:p-8 shadow-lab-lg text-center">
            <p class="font-mono text-xs tracking-widest text-warm-gray-500 mb-4">
              FEEDBACK
            </p>
            <p class="font-serif text-sm text-warm-gray-600 leading-relaxed mb-6">
              この品質規格についてのご意見・アドバイス・メッセージがありましたら、<br class="hidden md:inline" />
              気兼ねなくお寄せください。勉強させていただきます。
            </p>
            <a
              href="/contact"
              class="inline-block px-8 py-3 text-xs tracking-widest uppercase font-mono border-2 border-eolica-green text-eolica-green hover:bg-eolica-green hover:text-white transition-all duration-300"
            >
              お問い合わせフォームへ
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Gallery (写真2枚以上ある場合のみ表示。クリックで拡大ライトボックス) -->
    {combinedImages.length > 1 && (
      <section class="mb-16" data-animate>
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <h2 class="font-mono text-xs tracking-widest text-warm-gray-500 mb-8 text-center">
            GALLERY
          </h2>
          <ProductGalleryGrid
            client:visible
            images={combinedImages}
            productName={product.data.flowerType || product.data.name}
          />
        </div>
      </section>
    )}

    <!-- Back to Products (Bottom) -->
    <div class="text-center" data-animate>
      <a
        href={backUrl}
        class="inline-block text-xs tracking-widest uppercase font-mono border-b-2 border-rust pb-1 hover:border-lab-green transition-colors duration-300"
      >
        ← {categoryLabels[product.data.category]}一覧に戻る
      </a>
    </div>
  </div>

  <!-- GA4: view_item event -->
  <script define:vars={{
    productName: product.data.name,
    productCategory: categoryLabels[product.data.category] || product.data.category,
    productPrice: product.data.price || 0,
    flowerType: product.data.flowerType || '',
  }}>
    if (typeof window !== 'undefined' && window.gtag) {
      window.gtag('event', 'view_item', {
        item_name: flowerType || productName,
        item_category: productCategory,
        price: productPrice,
        currency: 'JPY',
      });
    }
  </script>
</Layout>
